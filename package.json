{
  "name": "davidhoang-dot-com",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npx astro dev",
    "start": "npx astro dev",
    "build": "node scripts/optimize-images.mjs && node scripts/audit-theme-contrast.mjs && npx astro build && node scripts/copy-assets.js",
    "analyze": "ANALYZE=1 npm run build",
    "budget": "node scripts/check-bundle-budget.mjs",
    "preview": "npx astro preview",
    "clean": "rm -rf dist .vercel node_modules",
    "rebuild": "npm run clean && npm install && npm run build",
    "bio:status": "node scripts/test-bio-summary.js status",
    "bio:generate": "node scripts/test-bio-summary.js generate",
    "generate-theme": "node scripts/generate-daily-theme.mjs",
    "optimize-images": "node scripts/optimize-images.mjs",
    "generate-favicons": "node scripts/generate-favicons.mjs",
    "audit-contrast": "node scripts/audit-theme-contrast.mjs",
    "audit:design": "node scripts/audit-design-compliance.mjs",
    "audit:design:check": "node scripts/audit-design-compliance.mjs --check",
    "audit:design:changed": "node scripts/audit-design-compliance.mjs --changed",
    "audit:design:strict": "node scripts/audit-design-compliance.mjs --strict",
    "audit:ui": "node scripts/audit-ui.mjs",
    "audit:ui:changed": "node scripts/audit-ui.mjs --changed",
    "check": "npx astro check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@astrojs/react": "^4.4.0",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^8.0.4",
    "@json-render/core": "^0.11.0",
    "@json-render/react": "^0.11.0",
    "@paper-design/shaders-react": "^0.0.68",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^5.14.1",
    "dialkit": "^1.3.0",
    "framer-motion": "^12.23.24",
    "geist": "^1.5.1",
    "markdown-it": "^14.1.1",
    "motion": "^12.42.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sanitize-html": "^2.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/sanitize-html": "^2.16.1",
    "baseline-browser-mapping": "^2.10.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}

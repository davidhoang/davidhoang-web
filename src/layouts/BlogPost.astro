---
import MainLayout from './MainLayout.astro';
import BlogMeta from '../components/BlogMeta.astro';
import { Image } from 'astro:assets';
import SidebarWriting from '../components/SidebarWriting.astro';
import CommentsSection from '../components/CommentsSection.astro';

const { data, relatedPosts = [], headings = [] } = Astro.props;
const { title, description, pubDate } = data;
const slug = Astro.url.pathname.split('/').filter(Boolean).pop();
// Only render a hero image when explicitly provided.
// Note: we intentionally do NOT fall back to `ogImage` here so that
// default OG images (e.g. David's portrait) don't render on the page.
const coverImage = data.coverImage;

// Use the post description for MainLayout as well
const pageDescription = description || "An article by David Hoang on design, engineering, AI, and entrepreneurship.";
// For social previews, fall back to a dynamically generated OG image when
// the post doesn't provide one. This fallback should NOT affect the rendered hero.
const ogImage = data.ogImage || coverImage || `/api/og?title=${encodeURIComponent(title)}&description=${encodeURIComponent(pageDescription)}&type=writing`;

// Structured data helpers
const siteUrl = 'https://www.davidhoang.com';
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage.startsWith('/') ? ogImage : `/${ogImage}`}`;
const isoDate = pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString();

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": pageDescription,
  "datePublished": isoDate,
  "dateModified": isoDate,
  "author": {
    "@type": "Person",
    "name": "David Hoang",
    "url": "https://www.davidhoang.com"
  },
  "image": ogImageUrl,
  "url": canonicalUrl,
  "publisher": {
    "@type": "Person",
    "name": "David Hoang"
  }
};
---

<MainLayout title={title} description={pageDescription} ogImage={ogImage}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <BlogMeta
    title={title}
    description={description}
    ogImage={ogImage}
    publishDate={pubDate}
    url={Astro.url.pathname}
  />
  <article class="blog-post" transition:animate="fade">
    {coverImage && (
      <div class="hero-section">
        <img src={coverImage} alt={title} loading="lazy" decoding="async" />
      </div>
    )}
    <div class="content-grid">
      <div class="main-content">
        <h1 transition:name={`title-${slug}`}>{title}</h1>
        <time datetime={pubDate}>
          {new Date(pubDate).toLocaleDateString()}
        </time>
        <div class="prose-content">
          <slot />
        </div>
        {relatedPosts.length > 0 && (
          <section class="related-posts">
            <h2 class="related-posts__heading">Related</h2>
            <div class="related-posts__grid">
              {relatedPosts.map((rp: any) => (
                <a href={`/writing/${rp.slug}`} class="related-posts__card">
                  <span class="related-posts__title">{rp.data.title}</span>
                  <time datetime={rp.data.pubDate.toISOString()}>
                    {new Date(rp.data.pubDate).toLocaleDateString()}
                  </time>
                </a>
              ))}
            </div>
          </section>
        )}
        <CommentsSection />
      </div>
      <SidebarWriting headings={headings} />
    </div>
  </article>
</MainLayout>

<style>
  .hero-section {
    width: 100%;
    margin-bottom: var(--section-spacing, 4rem);
  }

  .hero-section img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 3fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .post-image {
    margin: 2rem 0;
  }
  
  .post-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  
  time {
    color: #666;
    font-size: 0.9rem;
    display: block;
    margin: 1rem 0;
  }

  .related-posts {
    margin-top: var(--section-spacing, 4rem);
    padding-top: var(--spacing-xl, 2rem);
    border-top: 1px solid var(--color-border);
  }

  .related-posts__heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin: 0 0 1.25rem;
  }

  .related-posts__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .related-posts__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.3s var(--ease-inertia), transform 0.3s var(--ease-inertia);
  }

  .related-posts__card::after {
    display: none !important;
  }

  .related-posts__card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .related-posts__title {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .related-posts__card time {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: clamp(2rem, 7vw, 3rem);
      line-height: 1.15;
      letter-spacing: -0.025em;
    }

    .prose-content {
      font-size: 1.15rem;
      line-height: 1.75;
    }

    .related-posts__grid {
      grid-template-columns: 1fr;
    }

    .related-posts__title {
      font-size: 1.05rem;
      line-height: 1.35;
    }
  }
</style>

---
import MainLayout from './MainLayout.astro';
import BlogMeta from '../components/BlogMeta.astro';
import { Image } from 'astro:assets';
import SidebarWriting from '../components/SidebarWriting.astro';
import CommentsSection from '../components/CommentsSection.astro';

const { data, relatedPosts = [], headings = [] } = Astro.props;
const tocHeadings = headings.filter((h: { depth: number }) => h.depth === 2);
const { title, description, pubDate, tags } = data;
const slug = Astro.url.pathname.split('/').filter(Boolean).pop();

const blogContent = {
  forwards: {
    old: { name: 'contentFadeOut', duration: '0.15s', easing: 'ease-in', fillMode: 'forwards' },
    new: { name: 'blogSlideIn', duration: '0.4s', delay: '0.08s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'backwards' },
  },
  backwards: {
    old: { name: 'blogSlideOut', duration: '0.2s', easing: 'ease-in', fillMode: 'forwards' },
    new: { name: 'contentSlideBack', duration: '0.35s', delay: '0.05s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'backwards' },
  },
};
// Only render a hero image when explicitly provided.
// Note: we intentionally do NOT fall back to `ogImage` here so that
// default OG images (e.g. David's portrait) don't render on the page.
const coverImage = data.coverImage;

// Use the post description for MainLayout as well
const pageDescription = description || "An article by David Hoang on design, engineering, AI, and entrepreneurship.";
// For social previews, fall back to a dynamically generated OG image when
// the post doesn't provide one. This fallback should NOT affect the rendered hero.
const ogImage = data.ogImage || coverImage || `/api/og?title=${encodeURIComponent(title)}&description=${encodeURIComponent(pageDescription)}&type=writing`;

// Structured data helpers
const siteUrl = 'https://www.davidhoang.com';
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage.startsWith('/') ? ogImage : `/${ogImage}`}`;
const isoDate = pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString();

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": pageDescription,
  "datePublished": isoDate,
  "dateModified": isoDate,
  "author": {
    "@type": "Person",
    "name": "David Hoang",
    "url": "https://www.davidhoang.com"
  },
  "image": ogImageUrl,
  "url": canonicalUrl,
  "publisher": {
    "@type": "Person",
    "name": "David Hoang"
  }
};
---

<MainLayout title={title} description={pageDescription} ogImage={ogImage} disableContentMoodFilter>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <BlogMeta
    title={title}
    description={description}
    ogImage={ogImage}
    publishDate={pubDate}
    url={Astro.url.pathname}
    tags={tags}
  />
  <article class="blog-post" transition:animate={blogContent}>
    {coverImage && (
      <div class="hero-section">
        <img src={coverImage} alt={title} loading="eager" decoding="async" width="1200" height="630" />
      </div>
    )}
    <div class="content-grid">
      <div class="main-content">
        <h1 transition:name={`title-${slug}`}>{title}</h1>
        <time datetime={pubDate}>
          {new Date(pubDate).toLocaleDateString()}
        </time>
        <div class="prose-content">
          <slot />
        </div>
        <SidebarWriting variant="meta-only" />
        {relatedPosts.length > 0 && (
          <section class="related-posts">
            <h2 class="related-posts__heading">Related articles</h2>
            <div class="related-posts__grid">
              {relatedPosts.map((rp: any) => {
                const thumb = rp.data.coverImage || rp.data.ogImage || `/api/og?title=${encodeURIComponent(rp.data.title)}&type=writing`;
                return (
                  <a href={`/writing/${rp.slug}`} class="related-posts__card">
                    <div class="related-posts__thumb">
                      <img src={thumb} alt="" loading="lazy" decoding="async" />
                    </div>
                    <div class="related-posts__info">
                      <span class="related-posts__title">{rp.data.title}</span>
                      <time datetime={rp.data.pubDate.toISOString()}>
                        {new Date(rp.data.pubDate).toLocaleDateString()}
                      </time>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        )}
        <CommentsSection />
      </div>
      {tocHeadings.length > 0 && <SidebarWriting headings={headings} variant="toc-only" />}
    </div>
  </article>
  <button class="back-to-top" aria-label="Back to top" id="back-to-top">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M8 3L3 8.5M8 3l5 5.5M8 3v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <script>
    function initBackToTop() {
      const btn = document.getElementById('back-to-top');
      if (!btn) return;

      let visible = false;
      const toggle = () => {
        const show = window.scrollY > 400;
        if (show !== visible) {
          visible = show;
          btn.classList.toggle('visible', show);
        }
      };

      window.addEventListener('scroll', toggle, { passive: true });
      toggle();

      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    initBackToTop();
    document.addEventListener('astro:after-swap', initBackToTop);
  </script>
</MainLayout>

<style>
  .hero-section {
    width: 100%;
    margin-bottom: var(--section-spacing, 4rem);
  }

  .hero-section img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .content-grid {
    display: grid;
    /* minmax(0, …) lets columns shrink below min-content — avoids grid/track overflow */
    grid-template-columns: minmax(0, 3fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
    max-width: 56rem;
    margin: 0 auto;
  }

  .content-grid > .main-content {
    min-width: 0;
  }

  /* Writing post: TOC slot + full sidebar both direct-child asides */
  .content-grid > aside {
    min-width: 0;
    min-height: min-content;
    align-self: start;
  }

  /* Stretch TOC column to full article row height so the inner panel can position:sticky */
  .content-grid > aside.sidebar-toc-slot {
    align-self: stretch;
  }

  .post-image {
    margin: 2rem 0;
  }
  
  .post-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  
  time {
    color: var(--color-muted);
    font-size: 0.9rem;
    display: block;
    margin: 1rem 0;
  }

  /* "Originally posted on" attribution */
  .prose-content > hr:last-of-type {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0 1rem;
  }

  .prose-content > hr:last-of-type + p,
  .prose-content > hr:last-of-type + p em,
  .prose-content > p:last-child em {
    font-size: 0.875rem;
    color: var(--color-muted);
    font-style: normal;
  }

  .related-posts {
    margin-top: var(--section-spacing, 4rem);
    padding-top: var(--spacing-xl, 2rem);
    border-top: 1px solid var(--color-border);
  }

  .related-posts__heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin: 0 0 1.25rem;
  }

  .related-posts__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .related-posts__card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: box-shadow 0.3s var(--ease-inertia), transform 0.3s var(--ease-inertia);
  }

  .related-posts__card::after {
    display: none !important;
  }

  .related-posts__card:hover {
    box-shadow: var(--card-shadow, 0 4px 20px rgba(0, 0, 0, 0.06));
    transform: translateY(-2px);
  }

  .related-posts__thumb {
    width: 100%;
    aspect-ratio: 1200 / 630;
    overflow: hidden;
    background: var(--color-sidebar-bg);
  }

  .related-posts__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .related-posts__info {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .related-posts__title {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .related-posts__card time {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin: 0;
  }

  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease, background-color 0.15s ease;
    z-index: 100;
  }

  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .back-to-top:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }

  /* Wide screens: slightly wider article + TOC track (sticky sidebar uses the extra 1fr column) */
  @media (min-width: 1024px) {
    .content-grid {
      max-width: min(60rem, 100%);
      gap: 3.5rem;
    }
  }

  @media (min-width: 1280px) {
    .content-grid {
      max-width: min(62rem, 100%);
      gap: 4rem;
    }
  }

  @media (min-width: 1536px) {
    .content-grid {
      max-width: min(64rem, calc(100vw - 2 * var(--container-padding, 2rem)));
      gap: 4.5rem;
    }
  }

  @media (min-width: 1920px) {
    .content-grid {
      gap: 5rem;
    }
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: clamp(2rem, 7vw, 3rem);
      line-height: 1.15;
      letter-spacing: -0.025em;
    }

    .prose-content {
      font-size: 1.15rem;
      line-height: 1.75;
    }

    .related-posts__grid {
      grid-template-columns: 1fr;
    }

    .related-posts__card {
      flex-direction: row;
    }

    .related-posts__thumb {
      width: 120px;
      flex-shrink: 0;
      aspect-ratio: auto;
      align-self: stretch;
    }

    .related-posts__info {
      flex: 1;
      justify-content: center;
    }

    .related-posts__title {
      font-size: 1.05rem;
      line-height: 1.35;
    }
  }
</style>

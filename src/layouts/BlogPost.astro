---
import MainLayout from './MainLayout.astro';
import BlogMeta from '../components/BlogMeta.astro';
import { Image } from 'astro:assets';
import SidebarWriting from '../components/SidebarWriting.astro';
import CommentsSection from '../components/CommentsSection.astro';
import RelatedContentSection from '../components/RelatedContentSection.astro';
import CompanionPrototype from '../components/CompanionPrototype.astro';
import { formatLongDate } from '../utils/formatDate';
import { resolveAssetImage } from '../utils/assetImages';

const { data, relatedContent = [], headings = [], readingTime } = Astro.props;
const tocHeadings = headings.filter((h: { depth: number }) => h.depth === 2);
const { title, description, pubDate, tags } = data;
const slug = Astro.url.pathname.split('/').filter(Boolean).pop();

const blogContent = {
  forwards: {
    old: { name: 'contentFadeOut', duration: '0.15s', easing: 'ease-in', fillMode: 'forwards' },
    new: { name: 'blogSlideIn', duration: '0.4s', delay: '0.08s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'backwards' },
  },
  backwards: {
    old: { name: 'blogSlideOut', duration: '0.2s', easing: 'ease-in', fillMode: 'forwards' },
    new: { name: 'contentSlideBack', duration: '0.35s', delay: '0.05s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'backwards' },
  },
};
// Only render a hero image when explicitly provided.
// Note: we intentionally do NOT fall back to `ogImage` here so that
// default OG images (e.g. David's portrait) don't render on the page.
const coverImage = data.coverImage;
const coverAsset = resolveAssetImage(coverImage);

// Use the post description for MainLayout as well
const pageDescription = description || "An article by David Hoang on design, engineering, AI, and entrepreneurship.";
// For social previews, fall back to a dynamically generated OG image when
// the post doesn't provide one. This fallback should NOT affect the rendered hero.
const ogImage = data.ogImage || coverImage || `/api/og?title=${encodeURIComponent(title)}&description=${encodeURIComponent(pageDescription)}&type=writing`;

// Structured data helpers
const siteUrl = 'https://www.davidhoang.com';
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage.startsWith('/') ? ogImage : `/${ogImage}`}`;
const isoDate = pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString();

const isNote = Astro.url.pathname.startsWith('/notes/');
const sectionLabel = isNote ? 'Notes' : 'Writing';
const sectionPath = isNote ? '/notes' : '/writing';

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": pageDescription,
  "datePublished": isoDate,
  "dateModified": isoDate,
  "author": { "@id": "https://www.davidhoang.com/#person" },
  "image": ogImageUrl,
  "url": canonicalUrl,
  "publisher": { "@id": "https://www.davidhoang.com/#person" }
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": sectionLabel, "item": `${siteUrl}${sectionPath}` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalUrl }
  ]
};
---

<MainLayout title={title} description={pageDescription} ogImage={ogImage} disableContentMoodFilter>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <BlogMeta slot="head" ogImage={ogImage} publishDate={pubDate} tags={tags} />
  <article class="blog-post" transition:animate={blogContent}>
    {coverImage && (
      <div class="hero-section">
        {coverAsset ? (
          <Image
            src={coverAsset}
            alt={title}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            widths={[800, 1200, 1800, 2400]}
            sizes="(max-width: 1280px) 100vw, 1200px"
          />
        ) : (
          <img src={coverImage} alt={title} loading="eager" decoding="async" fetchpriority="high" width="1200" height="630" />
        )}
      </div>
    )}
    <div class="content-grid">
      <div class="main-content">
        <a href={sectionPath} class="text-eyebrow text-eyebrow--link link-plain">{sectionLabel}</a>
        <h1 transition:name={`title-${slug}`}>{title}</h1>
        <div class="post-meta">
          <time datetime={pubDate}>
            {formatLongDate(new Date(pubDate))}
          </time>
          {readingTime && (
            <span class="reading-time" aria-label={`${readingTime} minute read`}> · {readingTime} min read</span>
          )}
        </div>
        {data.companionPrototype && (
          <CompanionPrototype slug={data.companionPrototype} />
        )}
        <div class="prose-content prose-mobile">
          <slot />
        </div>
        {tags && tags.length > 0 && (
          <ul class="post-tags" aria-label="Tags">
            {tags.map((tag: string) => (
              <li class="post-tags__item text-eyebrow">{tag}</li>
            ))}
          </ul>
        )}
        <SidebarWriting variant="meta-only" />
        <RelatedContentSection items={relatedContent} heading="Keep reading" />
        <CommentsSection />
      </div>
      {tocHeadings.length > 0 && <SidebarWriting headings={headings} variant="toc-only" />}
    </div>
  </article>
  <button class="back-to-top" aria-label="Back to top" id="back-to-top">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M8 3L3 8.5M8 3l5 5.5M8 3v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <script>
    function initBackToTop() {
      const btn = document.getElementById('back-to-top');
      if (!btn) return;

      let visible = false;
      const toggle = () => {
        const show = window.scrollY > 400;
        if (show !== visible) {
          visible = show;
          btn.classList.toggle('visible', show);
        }
      };

      window.addEventListener('scroll', toggle, { passive: true });
      toggle();

      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    initBackToTop();
    document.addEventListener('astro:after-swap', initBackToTop);
  </script>
</MainLayout>

<style>
  .hero-section {
    width: 100%;
    margin-bottom: var(--section-spacing, 4rem);
  }

  .hero-section img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .post-image {
    margin: 2rem 0;
  }
  
  .post-image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
  }

  .main-content > h1 {
    text-wrap: balance;
    margin-bottom: 0.75rem;
  }

  .main-content > .post-meta {
    color: var(--color-muted);
    font-size: 0.9375rem;
    letter-spacing: 0.01em;
    margin: 0 0 2.25rem;
  }

  .main-content > .text-eyebrow {
    margin-bottom: 0.85rem;
  }

  .post-tags {
    list-style: none;
    padding: 1rem 0 0;
    margin: 2.5rem 0 0;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.85rem;
  }

  .post-tags__item {
    color: var(--color-muted);
    position: relative;
  }

  .post-tags__item:not(:last-child)::after {
    content: "·";
    position: absolute;
    right: -0.55rem;
    color: var(--color-border);
    font-weight: 400;
  }

  /* "Originally posted on" attribution */
  .prose-content > hr:last-of-type {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0 1rem;
  }

  .prose-content > hr:last-of-type + p,
  .prose-content > hr:last-of-type + p em,
  .prose-content > p:last-child em {
    font-size: 0.875rem;
    color: var(--color-muted);
    font-style: normal;
  }

  .related-posts {
    margin-top: var(--section-spacing, 4rem);
    content-visibility: auto;
    contain-intrinsic-size: 0 420px;
  }

  .related-posts__heading {
    margin: 0 0 1.5rem;
  }

  .related-posts__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .related-posts__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .related-posts__thumb {
    width: 100%;
    aspect-ratio: 1200 / 630;
    overflow: hidden;
    background: var(--color-sidebar-bg);
    border-radius: var(--radius-md);
  }

  .related-posts__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (hover: hover) {
    .related-posts__card:hover .related-posts__title {
      color: var(--color-link);
    }
  }

  .related-posts__info {
    padding: 0.85rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .related-posts__title {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: var(--letter-spacing-heading-md, -0.01em);
    text-wrap: balance;
    transition: color var(--duration-normal, 0.2s) var(--ease-inertia, ease);
  }

  .related-posts__card time {
    font-size: var(--text-eyebrow-size);
    font-weight: 600;
    letter-spacing: var(--text-eyebrow-tracking);
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0;
  }

  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease, background-color 0.15s ease;
    z-index: 100;
  }

  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .back-to-top:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  @media (max-width: 768px) {
    h1 {
      font-size: clamp(2rem, 7vw, 3rem);
      line-height: 1.15;
      letter-spacing: var(--letter-spacing-display);
    }

    .related-posts__grid {
      grid-template-columns: 1fr;
    }

    .related-posts__card {
      flex-direction: row;
    }

    .related-posts__thumb {
      width: 120px;
      flex-shrink: 0;
      aspect-ratio: auto;
      align-self: stretch;
    }

    .related-posts__info {
      flex: 1;
      justify-content: center;
      padding: 0 0 0 1rem;
    }

    .related-posts__title {
      font-size: 1.05rem;
      line-height: 1.35;
    }
  }
</style>

---
import '../styles/reset.css';
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import DailyThemeToggle from '../components/DailyThemeToggle.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import ShaderBackground from '../components/ShaderBackground';
import FontPreloader from '../components/FontPreloader.astro';
import { ViewTransitions } from 'astro:transitions';
import themesData from '../data/daily-themes.json';

const contentSlide = {
  forwards: {
    old: {
      name: 'contentFadeOut',
      duration: '0.15s',
      easing: 'ease-in',
      fillMode: 'forwards',
    },
    new: {
      name: 'contentSlideIn',
      duration: '0.35s',
      delay: '0.05s',
      easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
      fillMode: 'backwards',
    },
  },
  backwards: {
    old: {
      name: 'contentFadeOut',
      duration: '0.15s',
      easing: 'ease-in',
      fillMode: 'forwards',
    },
    new: {
      name: 'contentSlideBack',
      duration: '0.35s',
      delay: '0.05s',
      easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
      fillMode: 'backwards',
    },
  },
};

const footerReveal = {
  forwards: {
    old: { name: 'footerFadeOut', duration: '0.1s', easing: 'ease-in', fillMode: 'forwards' },
    new: { name: 'footerFadeIn', duration: '0.4s', delay: '0.2s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'backwards' },
  },
  backwards: {
    old: { name: 'footerFadeOut', duration: '0.1s', easing: 'ease-in', fillMode: 'forwards' },
    new: { name: 'footerFadeIn', duration: '0.4s', delay: '0.2s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'backwards' },
  },
};

const blogContent = {
  forwards: {
    old: { name: 'contentFadeOut', duration: '0.15s', easing: 'ease-in', fillMode: 'forwards' },
    new: { name: 'blogSlideIn', duration: '0.4s', delay: '0.08s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'backwards' },
  },
  backwards: {
    old: { name: 'blogSlideOut', duration: '0.2s', easing: 'ease-in', fillMode: 'forwards' },
    new: { name: 'contentSlideBack', duration: '0.35s', delay: '0.05s', easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fillMode: 'backwards' },
  },
};

// Fonts already self-hosted in /public/fonts/ (no external request needed)
const SELF_HOSTED_FONTS = new Set([
  'Inter', 'Space Grotesk', 'Cormorant Garamond', 'Bodoni Moda', 'Crimson Text',
]);

// Get today's theme fonts for early preloading (reduces FOUT)
const today = new Date().toISOString().split('T')[0];
const todayTheme = (themesData as any).themes.find((t: any) => t.date === today) || (themesData as any).themes[0];
const themeFonts = [todayTheme?.fonts?.heading, todayTheme?.fonts?.body]
  .filter((f: any) => f?.url)
  .filter((f: any, i: number, arr: any[]) => arr.findIndex((x: any) => x.url === f.url) === i);

// Only fonts that aren't already self-hosted need external loading
const externalThemeFonts = themeFonts.filter((f: any) => !SELF_HOSTED_FONTS.has(f.name));
const needsGoogleFonts = externalThemeFonts.length > 0;

// Load only the @font-face declarations needed by today's theme (not all 1,900 lines)
// Vite ?raw imports give us CSS as strings at build time
import cormorantGaramondCSS from '../styles/fonts/cormorant-garamond.css?raw';
import frauncesCSS from '../styles/fonts/fraunces.css?raw';
import interCSS from '../styles/fonts/inter.css?raw';
import sourceSerif4CSS from '../styles/fonts/source-serif-4.css?raw';
import spaceGroteskCSS from '../styles/fonts/space-grotesk.css?raw';
const FONT_CSS_RAW: Record<string, string> = {
  'Cormorant Garamond': cormorantGaramondCSS,
  'Fraunces': frauncesCSS,
  'Inter': interCSS,
  'Source Serif 4': sourceSerif4CSS,
  'Space Grotesk': spaceGroteskCSS,
};
const neededFontFamilies = new Set<string>();
if (todayTheme?.fonts?.heading?.name) neededFontFamilies.add(todayTheme.fonts.heading.name);
if (todayTheme?.fonts?.body?.name) neededFontFamilies.add(todayTheme.fonts.body.name);
let themeFontCSS = '';
for (const name of neededFontFamilies) {
  if (FONT_CSS_RAW[name]) themeFontCSS += FONT_CSS_RAW[name] + '\n';
}

// --- SSR daily theme: bake today's theme into HTML to prevent CLS ---
function getNestedValue(obj: any, path: string) {
  return path.split('.').reduce((o: any, k: string) => o && o[k], obj);
}
function clampMinContentPadding(raw: string | null) {
  if (!raw) return '1rem';
  const s = String(raw).trim();
  const m = s.match(/^([\d.]+)\s*(rem|px|em)?$/i);
  if (!m) return '1rem';
  let n = parseFloat(m[1]);
  const unit = (m[2] || 'rem').toLowerCase();
  if (isNaN(n) || n <= 0) return '1rem';
  if (unit === 'px') n = n / 16;
  return `${Math.max(1, n)}rem`;
}

const THEME_PROPS: [string, string][] = [
  ['typography.headingWeight', '--heading-weight'],
  ['typography.bodyWeight', '--body-weight'],
  ['typography.bodyLineHeight', '--body-line-height'],
  ['typography.letterSpacing', '--letter-spacing'],
  ['typography.headingLetterSpacing', '--heading-letter-spacing'],
  ['typography.headingTransform', '--heading-transform'],
  ['typography.scaleRatio', '--scale-ratio'],
  ['cards.borderWidth', '--card-border-width'],
  ['cards.padding', '--card-padding'],
  ['layout.containerMaxWidth', '--container-max-width'],
  ['layout.sectionSpacing', '--section-spacing'],
  ['layout.contentPadding', '--content-padding'],
  ['images.opacity', '--image-opacity'],
  ['images.borderRadius', '--image-border-radius'],
];

const THEME_ATTRS: [string, string, string][] = [
  ['cards.style', 'data-card-style', 'elevated'],
  ['hero.layout', 'data-hero-layout', 'stacked-fan'],
  ['links.style', 'data-link-style', 'underline'],
  ['background.texture', 'data-bg-texture', 'none'],
  ['images.style', 'data-image-style', 'vivid'],
  ['images.hover', 'data-image-hover', 'zoom'],
  ['footer.style', 'data-footer-style', 'classic'],
];

/** Build the styles + attrs needed to apply a theme client-side without re-running heavy logic.
 * Used by both the SSR bake of todayTheme and the pre-paint client script that swaps to the
 * user's selected theme before paint when they've chosen a non-today date in the calendar. */
function buildThemeApply(theme: any) {
  const styles: Record<string, string> = {};
  const lightColors: Record<string, string> = theme?.colors?.light || {};
  const darkColors: Record<string, string> = theme?.colors?.dark || {};

  for (const [path, prop] of THEME_PROPS) {
    const val = getNestedValue(theme, path);
    if (val) styles[prop] = prop === '--content-padding' ? clampMinContentPadding(val) : val;
  }
  if (theme?.fonts?.heading?.stack) styles['--font-heading'] = theme.fonts.heading.stack;
  if (theme?.fonts?.body?.stack) {
    styles['--font-body'] = theme.fonts.body.stack;
    styles['--font-primary'] = theme.fonts.body.stack;
  }
  if (theme?.cards?.shadow && theme.cards.shadow !== 'none') {
    styles['--card-shadow'] = theme.cards.shadow;
  }
  if (theme?.layout?.borderRadius) {
    const br = theme.layout.borderRadius;
    styles['--radius-sm'] = br === '0px' ? '0px' : `calc(${br} * 0.5)`;
    styles['--radius-md'] = br;
    styles['--radius-lg'] = `calc(${br} * 1.5)`;
    styles['--radius-xl'] = `calc(${br} * 2)`;
  }
  if (theme?.typography?.fontVariationSettings && theme.typography.fontVariationSettings !== 'normal') {
    styles['--font-variation-settings'] = theme.typography.fontVariationSettings;
  }

  const attrs: Record<string, string> = {};
  for (const [path, attr, defaultVal] of THEME_ATTRS) {
    attrs[attr] = getNestedValue(theme, path) || defaultVal;
  }
  attrs['data-daily-theme'] = theme?.date || '';
  attrs['data-shader'] = theme?.shader?.type || 'none';
  if (theme?.shader?.colors) attrs['data-shader-colors'] = JSON.stringify(theme.shader.colors);
  if (theme?.layout?.gridStyle && theme.layout.gridStyle !== 'standard') {
    attrs['data-grid-style'] = theme.layout.gridStyle;
  }
  if (theme?.colors?.contrastMode && theme.colors.contrastMode !== 'standard') {
    attrs['data-contrast-mode'] = theme.colors.contrastMode;
  }

  return { styles, lightColors, darkColors, attrs };
}

// Build CSS custom properties for today's theme (light mode default)
const ssrThemeStyle: string[] = [];
const ssrThemeAttrs: Record<string, string> = {};
if (todayTheme) {
  const { styles, lightColors, attrs } = buildThemeApply(todayTheme);
  for (const [key, value] of Object.entries(lightColors)) {
    ssrThemeStyle.push(`${key}:${value}`);
  }
  for (const [prop, value] of Object.entries(styles)) {
    ssrThemeStyle.push(`${prop}:${value}`);
  }
  Object.assign(ssrThemeAttrs, attrs);
}

// Map of every theme keyed by date — passed to the pre-paint script so it can swap
// to the user's calendar selection before first paint (no flash of today's theme).
const themesApplyMap: Record<string, ReturnType<typeof buildThemeApply>> = {};
for (const t of (themesData as any).themes || []) {
  themesApplyMap[t.date] = buildThemeApply(t);
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  hideFooter?: boolean;
  pageType?: 'home' | 'blog' | 'about';
  /** When true, skip mood filter on .content-filter-wrapper so position:sticky works (filter breaks sticky/fixed descendants). */
  disableContentMoodFilter?: boolean;
  /** Value for `<meta name="robots">` (e.g. `noindex, nofollow` for utility routes). */
  robots?: string;
}

const { 
  title, 
  description = "The official website of David Hoang", 
  ogImage = "/images/img-dh-web-light.webp",
  hideFooter = false,
  pageType,
  disableContentMoodFilter = false,
  robots = 'index, follow',
} = Astro.props;

// Auto-detect page type from URL if not provided
const detectedPageType = pageType || (() => {
  const pathname = Astro.url.pathname;
  if (pathname === '/' || pathname === '') return 'home';
  if (pathname.includes('/writing/') || pathname.includes('/notes/')) return 'blog';
  if (pathname.includes('/about')) return 'about';
  return 'home';
})();

// Get the canonical URL with fallback
// Normalize: strip trailing slash (except for root "/") for consistent canonical URLs
const rawPathname = Astro.url.pathname;
const normalizedPathname = rawPathname === '/' ? '/' : rawPathname.replace(/\/+$/, '');
const canonicalURL = Astro.site
  ? new URL(normalizedPathname, Astro.site).href
  : normalizedPathname;

// Construct full URL for ogImage
const siteUrl = (Astro.site ? Astro.site.toString() : 'https://www.davidhoang.com').replace(/\/$/, '');
const ogImageUrl = ogImage.startsWith('http') 
  ? ogImage 
  : `${siteUrl}${ogImage.startsWith('/') ? ogImage : `/${ogImage}`}`;
---

<!DOCTYPE html>
<html lang="en" style={ssrThemeStyle.join(';')} {...ssrThemeAttrs}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="David Hoang — Writing (RSS)" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="David Hoang — Notes (RSS)" href="/rss/notes.xml" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={detectedPageType === 'blog' ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="davidhoang.com" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@davidhoang" />
    <meta name="twitter:creator" content="@davidhoang" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <meta name="generator" content={Astro.generator} />

    {/* Inline @font-face declarations for today's theme fonts only */}
    {themeFontCSS && <Fragment set:html={`<style>${themeFontCSS}</style>`} />}
    <!-- Intelligent Font Preloading System -->
    <FontPreloader pageType={detectedPageType} priority={detectedPageType === 'home'} />
    
    <!-- Preconnect to Google Fonts only when today's theme needs external fonts -->
    {needsGoogleFonts && (
      <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    )}
    {needsGoogleFonts && (
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    )}

    <!-- Preload today's daily theme fonts to reduce FOUT (skip already self-hosted) -->
    {externalThemeFonts.map((font: any) => (
      <link rel="stylesheet" href={font.url} media="print" onload="this.media='all'" />
    ))}

    <!-- Browser theme color - blends browser UI with site -->
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />

    <!-- System stack font; remove external font preloads to reduce blocking. If reintroducing, prefer self-hosted and display=swap. -->
    <ViewTransitions fallback="swap" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "David Hoang",
      "url": "https://www.davidhoang.com",
      "description": description,
      "author": {
        "@type": "Person",
        "name": "David Hoang",
        "url": "https://www.davidhoang.com"
      }
    })} />

    <slot name="head" />

    <!-- Inline critical CSS -->
    <style is:inline>
      /* Critical CSS that prevents layout shift */
      :root {
        --color-text: #333;
        --color-bg: #fff;
        --nav-height: 40px;
        --font-primary: 'ABC Diatype', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', Inter, system-ui, Arial, sans-serif;
      }
      [data-theme="dark"] {
        --color-text: #e1e1e1;
        --color-bg: #111;
      }
      /* E-Ink mode - must be in critical CSS to prevent flash */
      [data-e-ink="true"] {
        --color-text: #000000;
        --color-bg: #f5f5f0;
      }
      [data-e-ink="true"][data-theme="dark"] {
        --color-text: #e0e0e0;
        --color-bg: #121212;
      }
      
      /* Font loading optimization states */
      html {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', Inter, system-ui, Arial, sans-serif;
        font-synthesis: none;
        text-rendering: optimizeLegibility;
      }
      
      /* Apply custom fonts only when critical fonts are loaded */
      html.critical-fonts-loaded {
        font-family: var(--font-primary);
      }
      
      /* Prevent layout shift during font loading */
      html.font-loading h1,
      html.font-loading h2,
      html.font-loading h3 {
        font-weight: 600; /* Match ABC Diatype weight more closely */
        letter-spacing: -0.02em; /* Closer to custom font metrics */
      }
      
      /* Smooth font loading transition */
      html.fonts-loaded * {
        transition: font-family 0.1s ease-out;
      }
      
      body {
        margin: 0;
        padding: 0;
        font-family: inherit;
        color: var(--color-text);
        background-color: var(--color-bg);
      }
      [data-e-ink="true"] body {
        background-color: #f5f5f0;
      }
      [data-e-ink="true"][data-theme="dark"] body {
        background-color: #121212;
      }
      /* Main site nav only — other pages use <nav> for TOCs, filters, etc. */
      nav.glass-border {
        height: var(--nav-height);
      }
      [data-e-ink="true"] nav.glass-border {
        background: #e8e8e3 !important;
      }
      [data-e-ink="true"][data-theme="dark"] nav.glass-border {
        background: #1a1a1a !important;
      }
      /* Page transition keyframes */
      @keyframes contentFadeOut {
        from { opacity: 1; transform: translateY(0); }
        to { opacity: 0; transform: translateY(-8px); }
      }
      @keyframes contentSlideIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes contentSlideBack {
        from { opacity: 0; transform: translateY(-12px); }
        to { opacity: 1; transform: translateY(0); }
      }
      /* Blog post entrance — slides up with a gentle scale */
      @keyframes blogSlideIn {
        from { opacity: 0; transform: translateY(20px) scale(0.99); }
        to { opacity: 1; transform: translateY(0) scale(1); }
      }
      @keyframes blogSlideOut {
        from { opacity: 1; transform: translateY(0) scale(1); }
        to { opacity: 0; transform: translateY(8px) scale(0.99); }
      }
      /* Footer — subtle fade up */
      @keyframes footerFadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes footerFadeOut {
        from { opacity: 1; }
        to { opacity: 0; }
      }
      /* Smooth crossfade for the page root (background) */
      ::view-transition-old(root) {
        animation: pageFadeOut 0.15s ease-in forwards;
      }
      ::view-transition-new(root) {
        animation: pageFadeIn 0.25s ease-out 0.05s backwards;
      }
      @keyframes pageFadeOut {
        from { opacity: 1; }
        to { opacity: 0; }
      }
      @keyframes pageFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      /* Respect reduced motion preference */
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-group(*),
        ::view-transition-old(*),
        ::view-transition-new(*) {
          animation-duration: 0.01s !important;
          animation-delay: 0s !important;
        }
      }
      /* Skip to main content link for keyboard users */
      .skip-link {
        position: absolute;
        top: -9999px;
        left: -9999px;
        background: var(--color-text);
        color: var(--color-bg);
        padding: 8px;
        text-decoration: none;
        border-radius: var(--radius-sm);
        z-index: 10000;
      }
      .skip-link:focus-visible {
        top: 6px;
        left: 6px;
      }
    </style>
    
    <!-- Apply theme and e-ink mode before paint to avoid flash.
         SSR bakes today's daily theme (light mode) into <html> style/attrs.
         This script handles: dark mode color swap, e-ink override, daily-off,
         and swapping in the user's calendar selection when it's not today. -->
    <script define:vars={{
      ssrDarkColors: todayTheme?.colors?.dark || {},
      ssrThemeStyleKeys: ssrThemeStyle.map((s: string) => s.split(':')[0]),
      ssrDate: todayTheme?.date || today,
      themesApplyMap,
    }}>
      (function(){
        try {
          var root = document.documentElement;
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'dark' : 'light');
          root.setAttribute('data-theme', theme);

          var eInkMode = localStorage.getItem('e-ink-mode') === 'true';
          var dailyOff = localStorage.getItem('daily-theme-mode') === 'false';
          var selectedDate = localStorage.getItem('daily-theme-date');
          var hasUserSelection = !eInkMode && !dailyOff && selectedDate && selectedDate !== ssrDate && themesApplyMap[selectedDate];

          if (eInkMode) {
            // E-ink: strip daily theme, apply e-ink attribute
            ssrThemeStyleKeys.forEach(function(k) { root.style.removeProperty(k); });
            root.setAttribute('data-e-ink', 'true');
            root.setAttribute('data-shader', 'none');
          } else if (dailyOff) {
            // User disabled daily theme: strip SSR theme properties
            ssrThemeStyleKeys.forEach(function(k) { root.style.removeProperty(k); });
            root.removeAttribute('data-daily-theme');
            root.removeAttribute('data-shader');
            root.removeAttribute('data-shader-colors');
            root.removeAttribute('data-grid-style');
            root.removeAttribute('data-contrast-mode');
            ['data-nav-style','data-card-style','data-hero-layout','data-link-style',
             'data-bg-texture','data-image-style','data-image-hover','data-footer-style'
            ].forEach(function(a) { root.removeAttribute(a); });
          } else if (hasUserSelection) {
            // User picked a non-today theme — swap SSR's today bake to their selection before paint.
            var apply = themesApplyMap[selectedDate];
            // Clear SSR styles that may not be present in the new theme so we don't bleed through.
            ssrThemeStyleKeys.forEach(function(k) { root.style.removeProperty(k); });
            // Apply target theme styles (non-color CSS vars).
            Object.keys(apply.styles).forEach(function(k) { root.style.setProperty(k, apply.styles[k]); });
            // Apply colors for the resolved color scheme.
            var pickColors = theme === 'dark' ? apply.darkColors : apply.lightColors;
            Object.keys(pickColors).forEach(function(k) { root.style.setProperty(k, pickColors[k]); });
            // Apply data attributes.
            Object.keys(apply.attrs).forEach(function(k) { root.setAttribute(k, apply.attrs[k]); });
            // Clear conditional attrs not present in the new theme.
            if (!apply.attrs['data-shader-colors']) root.removeAttribute('data-shader-colors');
            if (!apply.attrs['data-grid-style']) root.removeAttribute('data-grid-style');
            if (!apply.attrs['data-contrast-mode']) root.removeAttribute('data-contrast-mode');
          } else if (theme === 'dark') {
            // Dark mode: swap SSR light colors to dark
            Object.keys(ssrDarkColors).forEach(function(k) {
              root.style.setProperty(k, ssrDarkColors[k]);
            });
          }

          // Update browser theme-color
          var themeColor = theme === 'dark' ? '#111111' : '#ffffff';
          var metaThemeColor = document.querySelector('meta[name="theme-color"]');
          if (metaThemeColor) metaThemeColor.setAttribute('content', themeColor);

          // Initialize font loading optimization early for better LCP
          root.classList.add('font-loading');
        } catch(e) {
          // no-op
        }
      })();
    </script>
    
    <!-- Font Loading Optimization Script -->
    <script>
      // Critical font loading optimization for LCP improvement
      (function() {
        'use strict';
        
        // Font loading state management
        var fontState = {
          critical: false,
          theme: false,
          all: false
        };
        
        // Critical fonts for immediate loading
        var criticalFonts = [
          '/fonts/ABCDiatypeVariable.woff2',
          '/fonts/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2'
        ];
        
        function updateFontLoadingState() {
          var allCriticalLoaded = criticalFonts.every(function(font) {
            return document.querySelector('link[href="' + font + '"]');
          });
          
          if (allCriticalLoaded && !fontState.critical) {
            fontState.critical = true;
            document.documentElement.classList.add('critical-fonts-loaded');
            document.documentElement.classList.remove('font-loading');
          }
        }
        
        // Monitor font loading with Font Loading API
        if ('fonts' in document) {
          document.fonts.ready.then(function() {
            fontState.all = true;
            document.documentElement.classList.add('fonts-loaded');
            
            // Performance mark for LCP measurement
            if ('performance' in window && 'mark' in window.performance) {
              try {
                performance.mark('fonts-loaded');
              } catch(e) {}
            }
          });
          
          // Check specific critical fonts
          criticalFonts.forEach(function(fontUrl) {
            var fontName = fontUrl.includes('ABCDiatype') ? 'ABC Diatype' : 'Inter';
            document.fonts.load('400 16px ' + fontName).then(function() {
              updateFontLoadingState();
            }).catch(function() {
              // Fallback - mark as loaded after timeout
              setTimeout(updateFontLoadingState, 2000);
            });
          });
        } else {
          // Fallback for browsers without Font Loading API
          setTimeout(function() {
            fontState.critical = true;
            fontState.all = true;
            document.documentElement.classList.add('critical-fonts-loaded', 'fonts-loaded');
            document.documentElement.classList.remove('font-loading');
          }, 2000);
        }
        
        // Theme-specific font preloading
        function preloadThemeFonts() {
          var dailyTheme = document.documentElement.getAttribute('data-daily-theme');
          var themeMode = localStorage.getItem('daily-theme-mode');
          
          if (themeMode === 'daily' && dailyTheme && dailyTheme !== 'default') {
            // Preload theme-specific fonts lazily
            var themeLink = document.createElement('link');
            themeLink.rel = 'preload';
            themeLink.href = '/fonts/co3bmX5slCNuHLi8bLeY9MK7whWMhyjYqXtK.woff2'; // Cormorant Garamond
            themeLink.as = 'font';
            themeLink.type = 'font/woff2';
            themeLink.crossOrigin = 'anonymous';
            
            // Add with low priority to not block critical fonts
            requestIdleCallback(function() {
              document.head.appendChild(themeLink);
            }, { timeout: 1000 });
          }
        }
        
        // Initial theme font check
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', preloadThemeFonts);
        } else {
          preloadThemeFonts();
        }
        
        // Monitor theme changes for font optimization
        var observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(mutation) {
            if (mutation.type === 'attributes' && 
                mutation.attributeName === 'data-daily-theme') {
              preloadThemeFonts();
            }
          });
        });
        
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['data-daily-theme']
        });
        
      })();
    </script>

  </head>
  <body class:list={[{ 'layout-no-content-filter': disableContentMoodFilter }]}>
    <!-- Add inline SVG filter for noise texture -->
    <svg style="position: absolute; width: 0; height: 0;" aria-hidden="true">
      <filter id="noise">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.80"
          numOctaves="4"
          stitchTiles="stitch"
          result="noise"/>
        <feColorMatrix type="saturate" values="0"/>
        <feBlend in="SourceGraphic" in2="noise" mode="multiply"/>
      </filter>
    </svg>

    <a href="#main-content" class="skip-link">Skip to main content</a>
    <!-- Outside .content-filter-wrapper so position:fixed is viewport-based (filter on wrapper breaks fixed descendants). -->
    <Navigation />
    <!-- Filter wrapper for mood/intensity effects -->
    <div class="content-filter-wrapper">
      <ShaderBackground client:visible />
      <main id="main-content" class="container" tabindex="-1" data-pagefind-body transition:animate={contentSlide}>
        <slot />
      </main>
      {!hideFooter && <div transition:animate={footerReveal}><Footer /></div>}
    </div>
    <DailyThemeToggle />

    <MusicPlayer />
    <script>
      /** Mood filter on .content-filter-wrapper breaks position:sticky; disable on long-form posts (see theme-variations.css). */
      function syncBlogPostMoodFilterBypass() {
        document.body.classList.toggle(
          'layout-no-content-filter',
          Boolean(document.querySelector('article.blog-post')),
        );
      }
      syncBlogPostMoodFilterBypass();
      document.addEventListener('astro:page-load', syncBlogPostMoodFilterBypass);

      // Helper to update browser theme-color
      function updateBrowserThemeColor(theme) {
        const themeColor = theme === 'dark' ? '#111111' : '#ffffff';
        let metaThemeColor = document.querySelector('meta[name="theme-color"]:not([media])');
        if (!metaThemeColor) {
          metaThemeColor = document.querySelector('meta[name="theme-color"]');
        }
        if (metaThemeColor) {
          metaThemeColor.setAttribute('content', themeColor);
        }
      }

      // Persist theme and e-ink mode during view transitions
      document.addEventListener('astro:after-swap', () => {
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);

        // Persist e-ink mode
        const eInkMode = localStorage.getItem('e-ink-mode');
        if (eInkMode === 'true') {
          document.documentElement.setAttribute('data-e-ink', 'true');
        }

        // Update browser theme-color
        updateBrowserThemeColor(theme);

        // Re-init lazy loading after page swap
        initLazyImages();
      });

      // Listen for theme changes (from ThemeToggle component)
      document.addEventListener('theme-changed', (e) => {
        updateBrowserThemeColor(e.detail.theme);
      });

      // Lazy loading with fade-in effect
      function observeImage(img) {
        if (img.classList.contains('loaded')) return;
        if (img.complete && img.naturalWidth > 0) {
          img.classList.add('loaded');
        } else {
          img.addEventListener('load', () => img.classList.add('loaded'), { once: true });
          // Safety: if load event never fires, show the image after 4s
          img.addEventListener('error', () => img.classList.add('loaded'), { once: true });
        }
      }

      function initLazyImages() {
        document.querySelectorAll('img[loading="lazy"]').forEach(observeImage);
      }

      // Catch images added by client-side components (React, etc.)
      const imgObserver = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          for (const node of mutation.addedNodes) {
            if (node instanceof HTMLImageElement && node.loading === 'lazy') {
              observeImage(node);
            }
            if (node instanceof HTMLElement) {
              node.querySelectorAll?.('img[loading="lazy"]').forEach(observeImage);
            }
          }
        }
      });
      imgObserver.observe(document.body, { childList: true, subtree: true });

      // Init existing images
      initLazyImages();
    </script>
    <script>
      import { injectSpeedInsights } from '@vercel/speed-insights';
      injectSpeedInsights();
    </script>
  </body>
</html>
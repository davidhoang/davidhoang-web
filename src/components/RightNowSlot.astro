---
import { getCollection } from 'astro:content';
import { slotLabels } from '../utils/timeOfDay';

type SlotItem = {
  title: string;
  description: string;
  url: string;
  kind: 'writing' | 'notes';
};

function toItem(entry: any, kind: 'writing' | 'notes'): SlotItem {
  return {
    title: entry.data.title,
    description: entry.data.description ?? '',
    url: `/${kind}/${entry.id}`,
    kind,
  };
}

const isPublished = (p: { data: { draft?: boolean } }) => !p.data.draft;

const writing = (await getCollection('writing', isPublished)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const notes = (await getCollection('notes', isPublished)).sort((a, b) => {
  const aDate = (a.data.updatedDate ?? a.data.pubDate).valueOf();
  const bDate = (b.data.updatedDate ?? b.data.pubDate).valueOf();
  return bDate - aDate;
});

const morning = writing[0] ? toItem(writing[0], 'writing') : null;
const afternoon = notes[0] ? toItem(notes[0], 'notes') : null;

let evening: SlotItem | null = null;
{
  const candidates: { item: SlotItem; date: number }[] = [];
  if (writing[0]) {
    candidates.push({ item: toItem(writing[0], 'writing'), date: writing[0].data.pubDate.valueOf() });
  }
  if (notes[0]) {
    const d = (notes[0].data.updatedDate ?? notes[0].data.pubDate).valueOf();
    candidates.push({ item: toItem(notes[0], 'notes'), date: d });
  }
  candidates.sort((a, b) => b.date - a.date);
  evening = candidates[0]?.item ?? null;
}

const cutoffMs = Date.now() - 30 * 24 * 60 * 60 * 1000;
const nightOptions = writing
  .filter((p) => p.data.pubDate.valueOf() < cutoffMs)
  .map((p) => toItem(p, 'writing'));

// SSR default: evening pick is the safest fallback (most recent thinking).
const ssrDefault = evening ?? morning ?? afternoon ?? nightOptions[0] ?? null;
const ssrLabel = slotLabels.evening;

const picks = { morning, afternoon, evening, nightOptions };
---

{ssrDefault && (
  <section class="right-now" aria-labelledby="right-now-heading" data-right-now>
    <p class="right-now-label" id="right-now-heading" data-slot-label>{ssrLabel}</p>
    <a class="right-now-card" data-slot-link href={ssrDefault.url}>
      <span class="right-now-kind" data-slot-kind>{ssrDefault.kind === 'writing' ? 'Writing' : 'Note'}</span>
      <span class="right-now-title" data-slot-title>{ssrDefault.title}</span>
      {ssrDefault.description && (
        <span class="right-now-desc" data-slot-desc>{ssrDefault.description}</span>
      )}
    </a>
  </section>
)}

<script is:inline define:vars={{ picks, labels: slotLabels }}>
  (function () {
    const section = document.querySelector('[data-right-now]');
    if (!section) return;

    function getBucket() {
      const h = new Date().getHours();
      if (h >= 5 && h < 12) return 'morning';
      if (h >= 12 && h < 17) return 'afternoon';
      if (h >= 17 && h < 22) return 'evening';
      return 'night';
    }

    function pickForBucket(bucket) {
      if (bucket === 'night') {
        const opts = picks.nightOptions || [];
        if (!opts.length) return picks.evening;
        return opts[Math.floor(Math.random() * opts.length)];
      }
      return picks[bucket] || picks.evening;
    }

    function apply() {
      const bucket = getBucket();
      const item = pickForBucket(bucket);
      if (!item) return;
      section.dataset.bucket = bucket;
      const label = section.querySelector('[data-slot-label]');
      const link = section.querySelector('[data-slot-link]');
      const kind = section.querySelector('[data-slot-kind]');
      const title = section.querySelector('[data-slot-title]');
      const desc = section.querySelector('[data-slot-desc]');
      if (label) label.textContent = labels[bucket];
      if (link) link.setAttribute('href', item.url);
      if (kind) kind.textContent = item.kind === 'writing' ? 'Writing' : 'Note';
      if (title) title.textContent = item.title;
      if (desc) desc.textContent = item.description || '';
      section.classList.add('is-ready');
    }

    apply();

    // Refresh on bucket boundary
    function msUntilNextBucket() {
      const now = new Date();
      const h = now.getHours();
      const nextH = h < 5 ? 5 : h < 12 ? 12 : h < 17 ? 17 : h < 22 ? 22 : 29;
      const next = new Date(now);
      next.setHours(nextH, 0, 0, 0);
      return next.getTime() - now.getTime();
    }
    let timer;
    function scheduleNext() {
      timer = window.setTimeout(() => { apply(); scheduleNext(); }, msUntilNextBucket() + 1000);
    }
    scheduleNext();
    document.addEventListener('astro:before-swap', () => {
      if (timer) window.clearTimeout(timer);
    }, { once: true });
  })();
</script>

<style>
  .right-now {
    margin: var(--section-spacing, 4rem) 0 0 0;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    position: relative;
    z-index: 1;
  }

  .right-now-label {
    margin: 0 0 0.75rem 0;
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted, currentColor);
    opacity: 0.75;
  }

  .right-now-card {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 1rem;
    row-gap: 0.25rem;
    align-items: baseline;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md, 8px);
    border: 1px solid var(--color-border);
    background: var(--color-sidebar-bg, transparent);
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .right-now-card:hover {
    border-color: var(--color-link);
    transform: translateY(-1px);
  }

  .right-now-kind {
    grid-column: 1;
    grid-row: 1;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-link);
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-sm, 4px);
    background: color-mix(in srgb, var(--color-link) 12%, transparent);
    align-self: center;
  }

  .right-now-title {
    grid-column: 2;
    grid-row: 1;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .right-now-desc {
    grid-column: 2;
    grid-row: 2;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-muted, currentColor);
    opacity: 0.8;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .right-now-card { transition: none; }
    .right-now-card:hover { transform: none; }
  }

  @media (max-width: 768px) {
    .right-now-card {
      grid-template-columns: 1fr;
      row-gap: 0.5rem;
    }
    .right-now-kind {
      grid-column: 1;
      grid-row: 1;
      justify-self: start;
    }
    .right-now-title {
      grid-column: 1;
      grid-row: 2;
    }
    .right-now-desc {
      grid-column: 1;
      grid-row: 3;
    }
  }
</style>

---
import TextureCard from './TextureCard.astro';

export interface DesignStackItem {
  name: string;
  url: string;
  description: string;
  /** Path to SVG under /public, e.g. /images/logos/stack/cursor.svg */
  logo: string;
  /** When true, skip theme filters so multi-color / brand marks stay accurate */
  preserveLogoColor?: boolean;
}

interface Props {
  items: DesignStackItem[];
}

const { items } = Astro.props;

function stackUrlFootnote(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./i, '');
  } catch {
    return url;
  }
}
---

<ul class="design-stack-grid" role="list">
  {
    items.map((item, i) => (
      <li class="design-stack-item" style={`--stack-i: ${i}`}>
        <TextureCard href={item.url} target="_blank" rel="noopener noreferrer">
          <div class="texture-card__media">
            <img
              src={item.logo}
              alt=""
              width="72"
              height="72"
              loading="lazy"
              decoding="async"
              class:list={[
                'texture-card__logo',
                item.preserveLogoColor && 'texture-card__logo--color',
              ]}
            />
          </div>
          <div class="texture-card__body">
            <span class="texture-card__title">{item.name}</span>
            <p class="texture-card__desc">{item.description}</p>
            <p class="texture-card__footnote" aria-hidden="true">
              {stackUrlFootnote(item.url)}
            </p>
            <span class="sr-only">(opens in new tab)</span>
          </div>
        </TextureCard>
      </li>
    ))
  }
</ul>

<style>
  .design-stack-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 520px) {
    .design-stack-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 720px) {
    .design-stack-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.125rem;
    }
  }

  @media (min-width: 1000px) {
    .design-stack-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .design-stack-item {
    margin: 0;
    padding: 0;
    animation: stack-card-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    animation-delay: calc(var(--stack-i, 0) * 0.07s);
  }

  @keyframes stack-card-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .design-stack-item {
      animation: none;
    }
  }
</style>

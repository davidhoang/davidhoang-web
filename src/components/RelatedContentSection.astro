---
import type { RelatedContentItem } from '../utils/relatedContent';

interface Props {
  items: RelatedContentItem[];
  heading?: string;
}

const { items, heading = 'Related' } = Astro.props;

const kindLabel: Record<RelatedContentItem['kind'], string> = {
  writing: 'Essay',
  notes: 'Note',
};
---

{items.length > 0 && (
  <section class="related-content section-divider" aria-label={heading}>
    <h2 class="text-eyebrow related-content__heading">{heading}</h2>
    <div class="related-content__grid">
      {items.map((item) => {
        const thumb =
          item.coverImage ||
          `/api/og?title=${encodeURIComponent(item.title)}&type=${item.kind === 'writing' ? 'writing' : 'notes'}`;
        return (
          <a href={item.href} class="related-content__card link-plain">
            <div class="related-content__thumb img-frame">
              <img src={thumb} alt="" loading="lazy" decoding="async" width="1200" height="630" />
            </div>
            <div class="related-content__info">
              <span class="related-content__type">{kindLabel[item.kind]}</span>
              <span class="related-content__title">{item.title}</span>
              {item.description && (
                <span class="related-content__desc">{item.description}</span>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .related-content {
    margin-top: var(--section-spacing, 4rem);
    content-visibility: auto;
    contain-intrinsic-size: 0 420px;
  }

  .related-content__heading {
    margin: 0 0 1.5rem;
  }

  .related-content__grid {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .related-content__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .related-content__card {
    display: grid;
    grid-template-columns: 112px 1fr;
    gap: 1rem;
    align-items: start;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    background: var(--color-sidebar-bg, var(--color-bg));
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .related-content__card:hover {
    border-color: var(--color-accent, var(--color-text));
    transform: translateY(-1px);
  }

  .related-content__thumb {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: calc(var(--radius-md, 8px) - 2px);
    background: var(--color-border);
  }

  .related-content__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .related-content__info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .related-content__type {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .related-content__title {
    font-family: var(--font-heading, inherit);
    font-size: 1rem;
    line-height: 1.3;
    color: var(--color-text);
  }

  .related-content__desc {
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--color-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

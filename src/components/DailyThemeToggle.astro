---
import dailyThemes from '../data/daily-themes.json';

const themes = dailyThemes.themes || [];
const currentDate = dailyThemes.currentDate;
const hasThemes = themes.length > 0;
---

{hasThemes && (
  <div class="daily-theme-toggle">
    <!-- Calendar before FAB in DOM so the button paints on top (closed panel was stealing hits). -->
    <div id="theme-calendar" class="theme-calendar" role="dialog" aria-label="Theme calendar">
      <div class="calendar-header">
        <span class="calendar-title">Daily themes</span>
        <button type="button" id="close-calendar" class="close-btn" aria-label="Close calendar">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <div class="appearance-row">
        <span class="appearance-label">Appearance</span>
        <div class="appearance-toggle" id="appearance-toggle" role="radiogroup" aria-label="Color scheme">
          <button class="appearance-btn" data-scheme="light" role="radio" aria-checked="false" aria-label="Light mode">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
          </button>
          <button class="appearance-btn" data-scheme="dark" role="radio" aria-checked="false" aria-label="Dark mode">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
          <button class="appearance-btn" data-scheme="system" role="radio" aria-checked="false" aria-label="System preference">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </button>
        </div>
      </div>

      <div class="calendar-grid">
        <button id="default-theme-btn" class="calendar-day default-day" title="Use default theme">
          <span class="day-number">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
              <path d="M3 3v5h5"></path>
            </svg>
          </span>
          <span class="day-name">Default</span>
        </button>
        <button id="e-ink-theme-btn" class="calendar-day e-ink-day" title="E-Ink reading mode">
          <span class="day-number">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
            </svg>
          </span>
          <span class="day-name">E-Ink</span>
        </button>
        {themes.map((theme: any) => (
          <button
            class={`calendar-day ${theme.date === currentDate ? 'current' : ''}`}
            data-date={theme.date}
            data-theme-data={JSON.stringify(theme)}
            title={theme.name}
          >
            <span class="day-number">{new Date(theme.date + 'T12:00:00').getDate()}</span>
            <span class="day-name">{theme.name.split(' ')[0]}</span>
          </button>
        ))}
      </div>

      <div class="calendar-footer">
        <div class="calendar-footer-row">
          <span class="footer-text">AI-generated daily <span class="separator">|</span> <a href="https://arnaud.ai/" target="_blank" rel="noopener noreferrer" class="credit-link">arnaud.ai</a></span>
          <button id="sound-toggle-inline" class="sound-toggle-btn" aria-label="Toggle ambient sound" aria-pressed="false">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sound-icon">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07" class="sound-wave"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
    <button
      type="button"
      id="daily-theme-toggle"
      data-daily-theme-trigger
      aria-label="Toggle daily AI theme"
      aria-pressed="false"
      title="Toggle Daily AI Theme"
    >
      <svg class="palette-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"></circle>
        <circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"></circle>
        <circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"></circle>
        <circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"></circle>
        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.555C21.965 6.012 17.461 2 12 2z"></path>
      </svg>
      <span class="toggle-label">Daily</span>
    </button>
  </div>
)}


<script define:vars={{ themes, currentDate }}>
  // NOTE: This block is inlined into HTML as plain JS — no TypeScript (e.g. `as Foo`) or the whole script fails to parse and nothing runs.
  // Property maps — single source of truth for theme application and removal
  const THEME_PROPS = [
    ['typography.headingWeight', '--heading-weight'],
    ['typography.bodyWeight', '--body-weight'],
    ['typography.bodyLineHeight', '--body-line-height'],
    ['typography.letterSpacing', '--letter-spacing'],
    ['typography.headingLetterSpacing', '--heading-letter-spacing'],
    ['typography.headingTransform', '--heading-transform'],
    ['typography.scaleRatio', '--scale-ratio'],
    ['navigation.height', '--nav-height'],
    ['navigation.padding', '--nav-padding'],
    ['cards.borderWidth', '--card-border-width'],
    ['cards.padding', '--card-padding'],
    ['layout.containerMaxWidth', '--container-max-width'],
    ['layout.sectionSpacing', '--section-spacing'],
    ['layout.contentPadding', '--content-padding'],
    ['images.opacity', '--image-opacity'],
    ['images.borderRadius', '--image-border-radius'],
  ];

  const THEME_ATTRS = [
    ['navigation.style', 'data-nav-style', 'floating'],
    ['cards.style', 'data-card-style', 'elevated'],
    ['hero.layout', 'data-hero-layout', 'stacked-fan'],
    ['links.style', 'data-link-style', 'underline'],
    ['background.texture', 'data-bg-texture', 'none'],
    ['images.style', 'data-image-style', 'vivid'],
    ['images.hover', 'data-image-hover', 'zoom'],
    ['footer.style', 'data-footer-style', 'classic'],
  ];

  function getNestedValue(obj, path) {
    return path.split('.').reduce((o, k) => o && o[k], obj);
  }

  /** Daily themes must never set --content-padding below 1rem (flush text when .container side padding is zeroed for shaders). */
  function clampMinContentPadding(raw) {
    if (raw == null || raw === '') return '1rem';
    const s = String(raw).trim();
    const m = s.match(/^([\d.]+)\s*(rem|px|em)?$/i);
    if (!m) return '1rem';
    let n = parseFloat(m[1]);
    const unit = (m[2] || 'rem').toLowerCase();
    if (Number.isNaN(n) || n <= 0) return '1rem';
    if (unit === 'px') n = n / 16;
    const clamped = Math.max(1, n);
    return `${clamped}rem`;
  }

  /** Parse CSS font-weight 100–900 from theme strings */
  function parseThemeFontWeight(val) {
    if (val == null || val === '') return null;
    const s = String(val).trim();
    const m = s.match(/\b([1-9]\d{2})\b/);
    const n = m ? parseInt(m[1], 10) : parseInt(s, 10);
    if (Number.isNaN(n)) return null;
    const rounded = Math.round(n / 100) * 100;
    return Math.min(900, Math.max(100, rounded));
  }

  /** Ensure --heading-weight > --body-weight for daily themes (fixes legacy JSON). */
  function enforceTypographyWeightHierarchy(root, themeData) {
    const typo = themeData?.typography || {};
    const fromComputed = (prop) => {
      const v = getComputedStyle(root).getPropertyValue(prop).trim();
      return parseThemeFontWeight(v);
    };
    let heading = parseThemeFontWeight(typo.headingWeight) ?? fromComputed('--heading-weight') ?? 600;
    let body = parseThemeFontWeight(typo.bodyWeight) ?? fromComputed('--body-weight') ?? 400;
    const MIN_STEP = 100;
    if (heading <= body) {
      heading = Math.min(900, body + MIN_STEP);
      if (heading <= body) body = Math.max(100, heading - MIN_STEP);
    }
    root.style.setProperty('--heading-weight', String(heading));
    root.style.setProperty('--body-weight', String(body));
  }

  function clearCalendarSelections(cal) {
    if (!cal) return;
    cal.querySelectorAll('.calendar-day').forEach(b => {
      b.classList.remove('selected', 'active');
    });
  }

  /**
   * pointerdown + capture: runs before click handlers (e.g. command palette) and before the
   * closed calendar can participate in hit-testing quirks. Toggle uses pointerdown so we still
   * open if something cancels click.
   * FAB is last in DOM + z-index + pointer-events on closed panel so the trigger receives the hit.
   */
  function bindDailyThemePointerDelegationOnce() {
    if (globalThis.__dhDailyThemePointerDelegation) return;
    globalThis.__dhDailyThemePointerDelegation = true;

    document.addEventListener(
      'pointerdown',
      (e) => {
        if (e.button !== 0) return;
        if (!(e.target instanceof Element)) return;
        const cal = document.getElementById('theme-calendar');
        if (!cal) return;

        if (e.target.closest('[data-daily-theme-trigger]')) {
          e.stopPropagation();
          cal.classList.toggle('open');
          return;
        }

        if (!cal.classList.contains('open')) return;
        if (cal.contains(e.target)) return;
        cal.classList.remove('open');
      },
      true
    );
  }

  function bindDailyThemeEscapeOnce() {
    if (globalThis.__dhDailyThemeEscape) return;
    globalThis.__dhDailyThemeEscape = true;

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const cal = document.getElementById('theme-calendar');
      const tb = document.getElementById('daily-theme-toggle');
      if (!cal || !cal.classList.contains('open')) return;
      e.preventDefault();
      cal.classList.remove('open');
      tb?.focus();
    });
  }

  function initDailyTheme() {
    const toggleBtn = document.getElementById('daily-theme-toggle');
    const calendar = document.getElementById('theme-calendar');
    const closeBtn = document.getElementById('close-calendar');
    const defaultBtn = document.getElementById('default-theme-btn');
    const eInkBtn = document.getElementById('e-ink-theme-btn');

    if (!toggleBtn || !calendar) return;

    // Check if e-ink mode is active
    const isEInkMode = localStorage.getItem('e-ink-mode') === 'true';

    // Daily theme is ON by default (only off if explicitly set to 'false' or e-ink is on)
    const isDailyMode = !isEInkMode && localStorage.getItem('daily-theme-mode') !== 'false';
    const selectedDate = localStorage.getItem('daily-theme-date') || currentDate;

    if (isEInkMode) {
      toggleBtn.setAttribute('aria-pressed', 'false');
      if (eInkBtn) eInkBtn.classList.add('active');
      document.documentElement.setAttribute('data-e-ink', 'true');
      document.documentElement.setAttribute('data-shader', 'none');
    } else if (isDailyMode) {
      toggleBtn.setAttribute('aria-pressed', 'true');
      applyDailyTheme(selectedDate);

      let selectedBtn = calendar.querySelector(`[data-date="${selectedDate}"]`);
      if (!selectedBtn && themes.length > 0) {
        selectedBtn = calendar.querySelector(`[data-date="${themes[0].date}"]`);
      }
      if (selectedBtn) selectedBtn.classList.add('selected');
    } else {
      if (defaultBtn) defaultBtn.classList.add('active');
    }

    // Check if already initialized using data attribute
    if (toggleBtn.dataset.initialized === 'true') return;
    toggleBtn.dataset.initialized = 'true';

    // Close button
    if (closeBtn) {
      closeBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        calendar.classList.remove('open');
      });
    }

    // Default theme button
    if (defaultBtn) {
      defaultBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        localStorage.setItem('daily-theme-mode', 'false');
        localStorage.setItem('e-ink-mode', 'false');
        document.documentElement.setAttribute('data-e-ink', 'false');
        toggleBtn.setAttribute('aria-pressed', 'false');
        removeDailyTheme();
        clearCalendarSelections(calendar);
        defaultBtn.classList.add('active');
      });
    }

    // E-Ink theme button
    if (eInkBtn) {
      eInkBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        localStorage.setItem('e-ink-mode', 'true');
        localStorage.setItem('daily-theme-mode', 'false');
        document.documentElement.setAttribute('data-e-ink', 'true');
        document.documentElement.setAttribute('data-shader', 'none');
        toggleBtn.setAttribute('aria-pressed', 'false');
        removeDailyTheme();
        clearCalendarSelections(calendar);
        eInkBtn.classList.add('active');
      });
    }

    // Appearance toggle (light / dark / system)
    const appearanceToggle = document.getElementById('appearance-toggle');
    if (appearanceToggle) {
      // Determine current mode
      const stored = localStorage.getItem('theme');
      const currentScheme = stored || 'system';

      // Set initial active state
      appearanceToggle.querySelectorAll('.appearance-btn').forEach(btn => {
        const scheme = btn.getAttribute('data-scheme');
        const isActive = scheme === currentScheme;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-checked', isActive ? 'true' : 'false');
      });

      // Arrow key navigation for radiogroup
      appearanceToggle.addEventListener('keydown', (e) => {
        const buttons = Array.from(appearanceToggle.querySelectorAll('.appearance-btn'));
        const current = buttons.indexOf(document.activeElement);
        if (current === -1) return;
        let next = -1;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          e.preventDefault();
          next = (current + 1) % buttons.length;
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          next = (current - 1 + buttons.length) % buttons.length;
        }
        if (next >= 0) {
          const nextBtn = buttons[next];
          if (nextBtn) {
            nextBtn.focus();
            nextBtn.click();
          }
        }
      });

      appearanceToggle.addEventListener('click', (e) => {
        const btn = e.target.closest('.appearance-btn');
        if (!btn) return;
        e.stopPropagation();

        const scheme = btn.getAttribute('data-scheme');

        // Update active state
        appearanceToggle.querySelectorAll('.appearance-btn').forEach(b => {
          const isActive = b === btn;
          b.classList.toggle('active', isActive);
          b.setAttribute('aria-checked', isActive ? 'true' : 'false');
        });

        if (scheme === 'system') {
          localStorage.removeItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        } else {
          localStorage.setItem('theme', scheme);
          document.documentElement.setAttribute('data-theme', scheme);
        }

        // Dispatch event for browser theme-color update
        const resolvedTheme = document.documentElement.getAttribute('data-theme');
        document.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: resolvedTheme } }));
      });
    }

    // Calendar day selection (excluding default and e-ink buttons)
    calendar.querySelectorAll('.calendar-day:not(.default-day):not(.e-ink-day)').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const date = btn.getAttribute('data-date');

        clearCalendarSelections(calendar);
        btn.classList.add('selected');

        localStorage.setItem('daily-theme-mode', 'true');
        localStorage.setItem('daily-theme-date', date);
        localStorage.setItem('e-ink-mode', 'false');
        document.documentElement.setAttribute('data-e-ink', 'false');
        toggleBtn.setAttribute('aria-pressed', 'true');

        applyDailyTheme(date);

        // Dispatch event for preference tracking
        const themeDataStr = btn.getAttribute('data-theme-data');
        if (themeDataStr) {
          try {
            const themeData = JSON.parse(themeDataStr);
            window.dispatchEvent(new CustomEvent('theme-selected', { detail: themeData }));
          } catch (e) {
            // Ignore parse errors
          }
        }
      });
    });
  }

  function applyDailyTheme(date) {
    let themeData = themes.find(t => t.date === date);
    if (!themeData && themes.length > 0) themeData = themes[0];
    if (!themeData) return;

    const root = document.documentElement;
    const isDark = root.getAttribute('data-theme') === 'dark';
    const colors = isDark ? themeData.colors.dark : themeData.colors.light;

    // Apply colors
    Object.entries(colors).forEach(([key, value]) => {
      root.style.setProperty(key, value);
    });

    // Apply mapped CSS properties
    THEME_PROPS.forEach(([path, prop]) => {
      const val = getNestedValue(themeData, path);
      if (!val) return;
      if (prop === '--content-padding') {
        root.style.setProperty(prop, clampMinContentPadding(val));
        return;
      }
      root.style.setProperty(prop, val);
    });

    enforceTypographyWeightHierarchy(root, themeData);

    // Apply mapped data attributes
    THEME_ATTRS.forEach(([path, attr, defaultVal]) => {
      const val = getNestedValue(themeData, path);
      root.setAttribute(attr, val || defaultVal);
    });

    // Special cases: contrast mode
    if (themeData.colors.contrastMode && themeData.colors.contrastMode !== 'standard') {
      root.setAttribute('data-contrast-mode', themeData.colors.contrastMode);
    } else {
      root.removeAttribute('data-contrast-mode');
    }

    // Special cases: fonts
    if (themeData.fonts) {
      const headingFont = themeData.fonts.heading;
      const bodyFont = themeData.fonts.body;
      if (headingFont) root.style.setProperty('--font-heading', headingFont.stack);
      if (bodyFont) {
        root.style.setProperty('--font-body', bodyFont.stack);
        root.style.setProperty('--font-primary', bodyFont.stack);
      }
      loadFonts([headingFont, bodyFont].filter(Boolean));
    }

    // Special cases: font variation settings
    if (themeData.typography && themeData.typography.fontVariationSettings && themeData.typography.fontVariationSettings !== 'normal') {
      root.style.setProperty('--font-variation-settings', themeData.typography.fontVariationSettings);
    }

    // Special cases: card shadow
    if (themeData.cards) {
      root.style.setProperty('--card-shadow', (themeData.cards.shadow && themeData.cards.shadow !== 'none') ? themeData.cards.shadow : 'none');
    }

    // Special cases: border radius (computed values)
    if (themeData.layout && themeData.layout.borderRadius) {
      const br = themeData.layout.borderRadius;
      root.style.setProperty('--radius-sm', br === '0px' ? '0px' : `calc(${br} * 0.5)`);
      root.style.setProperty('--radius-md', br);
      root.style.setProperty('--radius-lg', `calc(${br} * 1.5)`);
      root.style.setProperty('--radius-xl', `calc(${br} * 2)`);
    }

    // Special cases: grid style (conditional remove)
    if (themeData.layout && themeData.layout.gridStyle && themeData.layout.gridStyle !== 'standard') {
      root.setAttribute('data-grid-style', themeData.layout.gridStyle);
    } else {
      root.removeAttribute('data-grid-style');
    }

    // Special cases: shader
    if (themeData.shader) {
      root.setAttribute('data-shader', themeData.shader.type || 'none');
      if (themeData.shader.colors) root.setAttribute('data-shader-colors', JSON.stringify(themeData.shader.colors));
    } else {
      root.setAttribute('data-shader', 'none');
    }

    root.setAttribute('data-daily-theme', date);
  }

  // Fonts already self-hosted locally — no need to load from Google Fonts
  const SELF_HOSTED_FONTS = new Set([
    'Inter', 'Space Grotesk', 'Cormorant Garamond', 'Bodoni Moda', 'Crimson Text',
  ]);

  function loadFonts(fonts) {
    // Remove old font links
    document.querySelectorAll('link[id^="daily-theme-font"]').forEach(el => el.remove());

    // Add new font links only for fonts not already self-hosted
    fonts.forEach((font, index) => {
      if (!font || !font.url) return;
      if (SELF_HOSTED_FONTS.has(font.name)) return;
      const link = document.createElement('link');
      link.id = `daily-theme-font-${index}`;
      link.rel = 'stylesheet';
      link.href = font.url;
      document.head.appendChild(link);
    });
  }

  function removeDailyTheme() {
    const root = document.documentElement;

    // Remove mapped CSS properties
    THEME_PROPS.forEach(([, prop]) => root.style.removeProperty(prop));

    // Remove color, font, and computed properties
    ['--color-text', '--color-bg', '--color-link', '--color-link-hover',
     '--color-border', '--color-muted', '--color-sidebar-bg',
     '--color-nav-bg', '--color-nav-text', '--color-card-bg',
     '--font-primary', '--font-heading', '--font-body',
     '--radius-sm', '--radius-md', '--radius-lg', '--radius-xl',
     '--card-shadow', '--font-variation-settings'
    ].forEach(prop => root.style.removeProperty(prop));

    // Remove font links
    document.querySelectorAll('link[id^="daily-theme-font"]').forEach(el => el.remove());

    // Remove mapped data attributes
    THEME_ATTRS.forEach(([, attr]) => root.removeAttribute(attr));

    // Remove extra data attributes
    ['data-daily-theme', 'data-shader', 'data-shader-colors',
     'data-grid-style', 'data-contrast-mode'
    ].forEach(attr => root.removeAttribute(attr));
  }

  // Listen for theme toggle changes to update daily theme colors
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'data-theme') {
        const isDailyMode = localStorage.getItem('daily-theme-mode') === 'true';
        if (isDailyMode) {
          const selectedDate = localStorage.getItem('daily-theme-date') || currentDate;
          applyDailyTheme(selectedDate);
        }
      }
    });
  });

  observer.observe(document.documentElement, { attributes: true });

  // Listen for system theme changes (when user is in "system" mode)
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      const newTheme = e.matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', newTheme);
      document.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: newTheme } }));
    }
  });

  bindDailyThemePointerDelegationOnce();
  bindDailyThemeEscapeOnce();

  function scheduleInitDailyTheme() {
    const run = () => initDailyTheme();
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run, { once: true });
    } else {
      run();
    }
  }

  scheduleInitDailyTheme();
  document.addEventListener('astro:page-load', scheduleInitDailyTheme);
</script>

<script>
  import { ambientSound, AmbientSound } from '../scripts/ambient-sound.js';

  function initSoundToggle() {
    const toggleBtn = document.getElementById('sound-toggle-inline');
    if (!toggleBtn) return;

    // Check if already initialized
    if (toggleBtn.dataset.initialized === 'true') return;
    toggleBtn.dataset.initialized = 'true';

    // Always start with sound OFF on page load/refresh
    // (Browser autoplay restrictions prevent auto-starting audio anyway)
    toggleBtn.setAttribute('aria-pressed', 'false');
    localStorage.setItem('ambient-sound-enabled', 'false');

    // Get current theme mood
    const getCurrentMood = () => {
      const root = document.documentElement;
      const themeDate = root.getAttribute('data-daily-theme');

      if (!themeDate) return 'calm';

      try {
        const themeDataEl = document.querySelector(`[data-date="${themeDate}"]`);
        if (themeDataEl) {
          const themeData = JSON.parse(themeDataEl.getAttribute('data-theme-data') || '{}');
          return AmbientSound.getThemeMood(themeData);
        }
      } catch (e) {
        // Fall back to calm
      }

      return 'calm';
    };

    // Toggle handler
    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isPlaying = toggleBtn.getAttribute('aria-pressed') === 'true';

      if (isPlaying) {
        ambientSound.stop();
        toggleBtn.setAttribute('aria-pressed', 'false');
        localStorage.setItem('ambient-sound-enabled', 'false');
      } else {
        const mood = getCurrentMood();
        ambientSound.play(mood);
        toggleBtn.setAttribute('aria-pressed', 'true');
        localStorage.setItem('ambient-sound-enabled', 'true');
      }
    });

    // Listen for theme changes to update mood
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'data-daily-theme') {
          const isPlaying = toggleBtn.getAttribute('aria-pressed') === 'true';
          if (isPlaying) {
            const mood = getCurrentMood();
            ambientSound.changeMood(mood);
          }
        }
      });
    });

    observer.observe(document.documentElement, { attributes: true });
  }

  // Initialize
  initSoundToggle();
  document.addEventListener('astro:page-load', initSoundToggle);
</script>

<script>
  import { trackThemeSelection } from '../scripts/preference-tracker';

  function initPreferenceTracking() {
    // Check if already initialized
    if ((window as any).__preferenceTrackingInitialized) return;
    (window as any).__preferenceTrackingInitialized = true;

    // Listen for theme selection events
    window.addEventListener('theme-selected', ((e: CustomEvent) => {
      if (e.detail) {
        trackThemeSelection(e.detail);
      }
    }) as EventListener);
  }

  // Initialize
  initPreferenceTracking();
  document.addEventListener('astro:page-load', initPreferenceTracking);
</script>

---
/**
 * PageHeader Component
 *
 * A declarative page header with consistent shader effects and parallax.
 * Use this for all main pages to ensure visual consistency.
 *
 * Usage:
 *   import headerImg from '../assets/images/header-images/img-about.webp';
 *   <PageHeader title="About" image={headerImg} />
 *   <PageHeader title="Notes" variant="text-only" subtitle="Welcome to my digital garden" />
 */

import { Image, type ImageMetadata } from 'astro:assets';
import HeroImageShader from './HeroImageShader.tsx';

interface Props {
  title: string;
  /** Accepts an imported image (optimized) or a string path (passthrough). */
  image?: ImageMetadata | string;
  alt?: string;
  variant?: 'image' | 'text-only';
  subtitle?: string;
  class?: string;
  priority?: boolean;
}

const {
  title,
  image,
  alt = title,
  variant = 'image',
  subtitle,
  class: className = '',
  priority = false
} = Astro.props;

const isImageVariant = variant === 'image' && image;
// Resolve to a string src for the shader (React component needs a URL string)
const imageSrc = typeof image === 'string' ? image : image?.src;
---

<header class:list={['page-header', { 'page-header--image': isImageVariant, 'page-header--text': !isImageVariant }, className]}>
  {isImageVariant ? (
    <div class="page-header__hero">
      {typeof image !== 'string' ? (
        <Image
          src={image}
          alt={alt}
          class="page-header__image"
          width={1920}
          height={600}
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          format="webp"
        />
      ) : (
        <img
          src={image}
          alt={alt}
          class="page-header__image"
          loading={priority ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={priority ? 'high' : undefined}
          width="1920"
          height="600"
        />
      )}
      <HeroImageShader client:visible src={imageSrc} alt={alt} priority={priority} />
      <h1 class="page-header__title">{title}</h1>
    </div>
  ) : (
    <div class="page-header__text">
      <h1 class="page-header__title">{title}</h1>
      {subtitle && <p class="page-header__subtitle">{subtitle}</p>}
      <slot />
    </div>
  )}
</header>

<!-- Parallax is handled via CSS scroll-driven animations below -->

<style>
  .page-header {
    width: 100%;
  }

  /* Image variant - full hero with shader */
  .page-header--image .page-header__hero {
    /* Full-bleed: break out of any parent container to span the viewport */
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    height: 75vh;
    min-height: 300px;
    max-height: 600px;
    margin-top: calc(-1 * var(--content-top-padding, 4rem));
    margin-bottom: var(--section-spacing, 4rem);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Static hero image - renders immediately via SSR, no JS needed */
  .page-header__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Shader/image container — CSS scroll-driven parallax (no JS) */
  .page-header--image .page-header__hero > :global(*:first-child) {
    transform-origin: center center;
  }

  /* Parallax via scroll-driven animation — runs entirely on compositor thread */
  @supports (animation-timeline: scroll()) {
    .page-header--image .page-header__hero {
      view-timeline-name: --page-hero;
      view-timeline-axis: block;
    }

    .page-header--image .page-header__image {
      animation: parallax-shift linear both;
      animation-timeline: --page-hero;
      animation-range: entry 0% exit 100%;
    }

    @keyframes parallax-shift {
      from { transform: translateY(-8%) scale(1); }
      to   { transform: translateY(8%) scale(1.12); }
    }
  }

  /* Overlay for text legibility */
  .page-header--image .page-header__hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.4) 100%
    );
    z-index: var(--z-content);
    pointer-events: none;
  }

  .page-header--image .page-header__title {
    position: relative;
    z-index: calc(var(--z-content) + 1);
    color: white;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    text-align: center;
    margin: 0;
    padding: var(--container-padding, 2rem);
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
    letter-spacing: -0.02em;
  }

  /* Text variant - simple header */
  .page-header--text {
    padding: 0 0 var(--section-spacing, 4rem);
  }

  .page-header--text .page-header__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .page-header__subtitle {
    font-size: 1.2rem;
    color: var(--color-muted);
    max-width: 600px;
    line-height: 1.6;
    margin: 0;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .page-header--image .page-header__hero {
      height: 50vh;
      min-height: 250px;
      margin-top: 0; /* No negative margin on mobile */
    }

    .page-header--image .page-header__title {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .page-header--text .page-header__title {
      font-size: clamp(2rem, 8vw, 3rem);
    }

    /* Disable parallax on mobile */
    .page-header--image .page-header__hero > :global(*:first-child) {
      transform: none !important;
    }

    .page-header--image .page-header__image {
      animation: none !important;
    }
  }

  /* Large screens */
  @media (min-width: 1920px) {
    .page-header--image .page-header__hero {
      max-height: 700px;
    }

    .page-header--image .page-header__title {
      font-size: 5rem;
    }
  }
</style>

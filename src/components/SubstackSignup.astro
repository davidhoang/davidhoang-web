---
interface Props {
  title?: string;
  description?: string;
  showTitle?: boolean;
  /** Set when this block is the sole newsletter region (avoids duplicate ids on example pages). */
  headingId?: string;
  /** Tighter typography and spacing (e.g. dedicated subscribe page). */
  compact?: boolean;
}

const {
  title = 'Proof of Concept',
  description = 'Get the weekly newsletter about design, technology, and experimentation.',
  showTitle = true,
  headingId,
  compact = false,
} = Astro.props;

const isBrandTitle = title === 'Proof of Concept';

const emailFieldId = headingId
  ? `${headingId.replace(/\s+/g, '-')}-email`
  : `poc-email-${Math.random().toString(36).slice(2, 11)}`;

const showHeader = showTitle || Boolean(description?.trim());
---

<div class:list={['substack-signup', { compact }]}>
  {
    showHeader && (
      <div class="signup-header">
        {showTitle && isBrandTitle && (
          <h2 class="signup-title signup-title--brand" id={headingId}>
            Proof of Concept
          </h2>
        )}
        {showTitle && !isBrandTitle && <h2 class="signup-title signup-title--custom" id={headingId}>{title}</h2>}
        {description && <p class="signup-description">{description}</p>}
      </div>
    )
  }

  <form
    action="https://www.proofofconcept.pub/api/v1/free"
    method="post"
    class="signup-form"
    data-substack-signup
  >
    <div class="signup-form-row">
      <div class="form-group">
        <div class="email-input-shell">
          <label for={emailFieldId} class="visually-hidden">Email for newsletter</label>
          <input
            type="email"
            id={emailFieldId}
            name="email"
            placeholder="you@vibes-and-prototypes.dev"
            required
            class="email-input"
            aria-label="Email address for newsletter signup"
            autocomplete="email"
            data-placeholder-rotate
          />
          <div class="email-input-rail" aria-hidden="true"></div>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="subscribe-button">
          <span class="subscribe-button-label">Subscribe</span>
          <span class="subscribe-button-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
        </button>
      </div>
    </div>
  </form>
</div>

<style>
  .substack-signup {
    container-type: inline-size;
    container-name: substack-signup;
    border-top: 1px solid var(--color-border);
    padding: 4rem 0 3rem 0;
    width: 100%;
  }

  .signup-header {
    margin-bottom: 2rem;
  }

  .signup-title {
    margin: 0 0 0.75rem 0;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.04em;
    line-height: 0.95;
  }

  .signup-title--brand {
    white-space: nowrap;
    font-size: clamp(1.45rem, min(5.4cqw + 0.45rem, 4.25vw + 1rem), 12rem);
  }

  .signup-title--custom {
    font-size: clamp(2rem, 8vw, 4rem);
    max-width: 20ch;
  }

  .signup-description {
    margin: 0;
    width: 100%;
    max-width: none;
    color: var(--color-muted);
    font-size: 1.15rem;
    line-height: 1.5;
  }

  .signup-form {
    width: 100%;
  }

  .signup-form-row {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    gap: 1rem 1.25rem;
    width: 100%;
  }

  .form-group {
    flex: 1;
    min-width: 0;
    width: auto;
  }

  .form-actions {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    flex-wrap: nowrap;
  }

  .email-input-shell {
    position: relative;
    width: 100%;
    min-width: 0;
  }

  .email-input {
    width: 100%;
    min-width: 0;
    padding: 0.25em 0;
    border: none;
    border-radius: 0;
    font-size: clamp(1.35rem, min(2.65cqw + 0.65rem, 3.8vw), 3.35rem);
    font-family: var(--font-primary);
    font-weight: 600;
    letter-spacing: -0.02em;
    background: transparent;
    color: var(--color-text);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-sizing: border-box;
  }

  .email-input-shell:focus-within .email-input {
    transform: translateY(-2px);
  }

  .email-input:focus {
    outline: none;
  }

  .email-input::placeholder {
    color: var(--color-muted);
    opacity: 0.35;
    font-weight: 600;
  }

  .email-input-rail {
    height: 4px;
    border-radius: 999px;
    margin-top: 0.15rem;
    background: color-mix(in srgb, var(--color-border) 85%, transparent);
    position: relative;
    overflow: hidden;
  }

  .email-input-rail::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--color-link);
    transform: scaleX(0.15);
    transform-origin: left center;
    opacity: 0.45;
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.35s ease,
      background-color 0.35s ease;
  }

  .email-input-shell:focus-within .email-input-rail::after {
    transform: scaleX(1);
    opacity: 1;
    background: var(--color-link-hover);
  }

  .subscribe-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 1.75rem 1rem 2rem;
    background: var(--color-link);
    color: var(--color-bg);
    border: none;
    border-radius: 999px;
    font-size: 1.15rem;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    white-space: nowrap;
    transition:
      transform var(--duration-normal, 0.25s) cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow var(--duration-normal, 0.25s) ease,
      background var(--duration-normal, 0.25s) ease;
    flex-shrink: 0;
    box-shadow: 0 4px 0 color-mix(in srgb, var(--color-text) 18%, transparent);
  }

  .subscribe-button-icon {
    display: flex;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .subscribe-button:hover {
    background: var(--color-link-hover);
    transform: translateY(-3px) rotate(-1deg);
    box-shadow:
      0 8px 24px color-mix(in srgb, var(--color-link) 35%, transparent),
      0 6px 0 color-mix(in srgb, var(--color-text) 12%, transparent);
  }

  .subscribe-button:hover .subscribe-button-icon {
    transform: translate(3px, -3px) rotate(12deg);
  }

  [data-theme='dark'] .subscribe-button {
    box-shadow: 0 4px 0 color-mix(in srgb, var(--color-bg) 25%, transparent);
  }

  [data-theme='dark'] .subscribe-button:hover {
    box-shadow:
      0 8px 28px color-mix(in srgb, var(--color-link) 45%, transparent),
      0 6px 0 color-mix(in srgb, var(--color-bg) 18%, transparent);
  }

  .subscribe-button:active {
    transform: translateY(0) rotate(0);
    box-shadow: 0 2px 0 color-mix(in srgb, var(--color-text) 15%, transparent);
  }

  .subscribe-button:active .subscribe-button-icon {
    transform: translate(1px, -1px);
  }

  .subscribe-button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .subscribe-button.is-loading {
    position: relative;
    color: transparent;
  }

  .subscribe-button.is-loading .subscribe-button-icon {
    opacity: 0;
  }

  .subscribe-button.is-loading::after {
    content: '';
    position: absolute;
    width: 18px;
    height: 18px;
    top: 50%;
    left: 50%;
    margin: -9px 0 0 -9px;
    border: 2px solid var(--color-bg);
    border-top-color: transparent;
    border-radius: 50%;
    animation: btn-spin 0.6s linear infinite;
  }

  @keyframes btn-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .subscribe-button:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 3px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .substack-signup.compact {
    padding: 1.5rem 0;
  }

  .substack-signup.compact .signup-title {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .substack-signup.compact .signup-title--brand {
    white-space: normal;
    font-size: 1.5rem;
    width: auto;
  }

  .substack-signup.compact .signup-description {
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .substack-signup.compact .email-input {
    font-size: 1.5rem;
  }

  .substack-signup.compact .signup-form-row {
    flex-direction: column;
    align-items: stretch;
  }

  .substack-signup.compact .subscribe-button {
    padding: 0.75rem 1.25rem 0.75rem 1.5rem;
    font-size: 1rem;
    box-shadow: none;
    width: 100%;
  }

  .substack-signup.compact .subscribe-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
  }

  @media (max-width: 768px) {
    .substack-signup {
      padding: 3rem 0 2rem 0;
    }

    .signup-title--brand {
      white-space: nowrap;
      font-size: clamp(1.2rem, 5.25vw + 0.65rem, 3.5rem);
    }

    .signup-form-row {
      flex-direction: column;
      align-items: stretch;
      gap: 1.25rem;
    }

    .form-actions {
      width: 100%;
    }

    .subscribe-button {
      width: 100%;
      justify-content: center;
    }

    .email-input {
      font-size: clamp(1.5rem, 6.5vw, 2.25rem);
    }
  }

  .email-input.error + .email-input-rail::after {
    background: #dc2626;
    transform: scaleX(1);
    opacity: 1;
    animation: none;
  }

  .email-input.success + .email-input-rail::after {
    background: #16a34a;
    transform: scaleX(1);
    opacity: 1;
    animation: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .email-input,
    .subscribe-button,
    .subscribe-button-icon {
      transition: none;
    }

    .subscribe-button:hover,
    .subscribe-button:hover .subscribe-button-icon {
      transform: none;
    }

    .email-input-shell:focus-within .email-input {
      transform: none;
    }
  }
</style>

<script>
  const PLACEHOLDER_ROTATION = [
    'you@vibes-and-prototypes.dev',
    'ship-it@experimental.news',
    'curious@late-sunday-reads.com',
    'hot-takes@inbox.engineering',
    'maybe@subscribe-anyway.org',
  ];

  document.querySelectorAll('form[data-substack-signup]').forEach((form) => {
    form.addEventListener('submit', () => {
      const button = form.querySelector('.subscribe-button') as HTMLButtonElement | null;
      if (button) {
        button.classList.add('is-loading');
        button.disabled = true;
      }
    });

    const rotateInput = form.querySelector('[data-placeholder-rotate]') as HTMLInputElement | null;
    if (rotateInput && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let i = 0;
      window.setInterval(() => {
        if (document.activeElement === rotateInput) return;
        i = (i + 1) % PLACEHOLDER_ROTATION.length;
        rotateInput.placeholder = PLACEHOLDER_ROTATION[i];
      }, 3200);
    }
  });
</script>
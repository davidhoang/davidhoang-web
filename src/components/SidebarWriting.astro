---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: Heading[];
  /** full: TOC + meta (default). toc-only: right-column TOC. meta-only: newsletter + links below article body on writing posts. */
  variant?: 'full' | 'toc-only' | 'meta-only';
}

const { headings = [], variant = 'full' } = Astro.props;
/** Only H2 (##) — keeps the block compact and avoids nested TOC scrollbars. */
const tocHeadings = headings.filter((h) => h.depth === 2);
const hasHeadings = tocHeadings.length > 0;

const showToc = (variant === 'full' || variant === 'toc-only') && hasHeadings;
const showMeta = variant === 'full' || variant === 'meta-only';

const showAside =
  variant === 'meta-only' || variant === 'full' || (variant === 'toc-only' && hasHeadings);

/* TOC column: outer slot is not sticky (avoids grid height ~1 line); inner panel is sticky + card */
const asideClass = [
  'sidebar',
  'glass-border',
  variant === 'meta-only' && 'sidebar--meta-inline',
]
  .filter(Boolean)
  .join(' ');

const asideAria =
  variant === 'meta-only'
    ? 'Newsletter and social links'
    : variant === 'toc-only'
      ? 'Table of contents'
      : 'Sidebar with additional information';
---

{
  showAside &&
    (variant === 'toc-only' ? (
      <aside class="sidebar-toc-slot" role="complementary" aria-label={asideAria}>
        <div class="sidebar-toc-panel glass-border" role="navigation" aria-label="Table of contents">
          <h2 class="toc-heading">On this page</h2>
          <ul class="toc-list" role="list">
            {tocHeadings.map((heading) => (
              <li class="toc-item">
                <a href={`#${heading.slug}`} class="toc-link" data-heading-slug={heading.slug}>
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    ) : (
      <aside class={asideClass} role="complementary" aria-label={asideAria}>
        {showToc && (
          <nav class="sidebar-section toc-section" aria-label="Table of contents">
            <h2>On this page</h2>
            <ul class="toc-list" role="list">
              {tocHeadings.map((heading) => (
                <li class="toc-item">
                  <a href={`#${heading.slug}`} class="toc-link" data-heading-slug={heading.slug}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        {showMeta && (
          <>
            <div class="sidebar-section">
              <h2>Newsletter</h2>
              <p>Subscribe to my newsletter Proof of Concept, sent every Sunday.</p>
              <a
                href="https://www.proofofconcept.pub/"
                target="_blank"
                rel="noopener noreferrer"
                class="sidebar-button glass-border-button"
                aria-label="Subscribe to Proof of Concept newsletter"
              >
                Subscribe →
              </a>
            </div>

            <div class="sidebar-section">
              <h2>Elsewhere</h2>
              <ul class="social-links" role="list" aria-label="Social media and other links">
                <li><a href="https://twitter.com/davidhoang" target="_blank" rel="noopener noreferrer">Twitter</a></li>
                <li><a href="https://github.com/davidhoang" target="_blank" rel="noopener noreferrer">GitHub</a></li>
                <li><a href="https://linkedin.com/in/dhoang2" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
                <li><a href="/rss.xml" target="_blank" aria-label="RSS feed for this website">RSS Feed</a></li>
              </ul>
            </div>
          </>
        )}
      </aside>
    ))
}

<script>
  function initSidebar() {
    initTocScrollSpy();
  }

  function initTocScrollSpy() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (tocLinks.length === 0) return;

    const headingElements: HTMLElement[] = [];
    tocLinks.forEach((link) => {
      const slug = link.dataset.headingSlug;
      if (slug) {
        const el = document.getElementById(slug);
        if (el) headingElements.push(el);
      }
    });

    if (headingElements.length === 0) return;

    function updateActiveHeading() {
      const scrollY = window.scrollY;
      const offset = 120;

      let activeSlug = headingElements[0]?.id;
      for (const heading of headingElements) {
        if (heading.offsetTop - offset <= scrollY) {
          activeSlug = heading.id;
        } else {
          break;
        }
      }

      tocLinks.forEach((link) => {
        if (link.dataset.headingSlug === activeSlug) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    }

    tocLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = link.dataset.headingSlug;
        if (!slug) return;
        const target = document.getElementById(slug);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.pushState(null, '', `#${slug}`);
        }
      });
    });

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateActiveHeading();
          ticking = false;
        });
        ticking = true;
      }
    });

    updateActiveHeading();
  }

  document.addEventListener('astro:page-load', initSidebar);
</script>

<style>
  /* TOC sidebar: aside stretches with the grid row for sticky to work */
  .sidebar-toc-slot {
    align-self: stretch;
    min-width: 0;
    justify-self: end;
  }

  /* TOC card: sticky + card styles on one element */
  .sidebar-toc-panel {
    position: sticky;
    top: calc(var(--nav-offset-top, 24px) + var(--nav-height, 40px) + 1.5rem);
    z-index: 2;
    width: 100%;
    max-width: 250px;
    padding: 1.25rem 1.25rem 1.25rem 1.5rem;
    box-sizing: border-box;
    background-color: var(--color-sidebar-bg);
    border: var(--border-default);
    border-radius: var(--radius-lg);
  }

  .toc-heading {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.5rem 0;
    color: var(--color-muted);
  }

  .sidebar {
    float: none;
    clear: none;
    align-self: start;
    justify-self: end;
    width: 100%;
    max-width: 250px;
    height: auto;
    /* At least as tall as all sections (flex column; avoids collapsed min-content quirks) */
    min-height: max-content;
    max-height: none;
    padding: 1.25rem 1.25rem 1.25rem 1.5rem;
    box-sizing: border-box;
    background-color: var(--color-sidebar-bg);
    border: var(--border-default);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    /* visible on both axes: hidden+visible forces y=auto and can collapse height with min-height:0 */
    overflow: visible;
    scrollbar-width: none;
    isolation: isolate;
  }

  .sidebar::-webkit-scrollbar {
    display: none;
  }

  /* Newsletter + links below article (main column; never sticky) */
  .sidebar--meta-inline {
    position: static;
    justify-self: start;
    width: 100%;
    max-width: min(100%, 20rem);
    margin-top: clamp(2rem, 4vw, 3rem);
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .sidebar-section {
    margin-bottom: 1.25rem;
    flex-shrink: 0;
  }

  .sidebar-section:last-child {
    margin-bottom: 0;
  }

  .sidebar-section h2 {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.5rem 0;
    color: var(--color-muted);
  }

  .sidebar-section p {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-muted);
    margin: 0 0 0.75rem 0;
  }

  /* Table of contents: H2-only list, no scroll containers, no scrollbars */
  .toc-section {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1rem;
    flex-shrink: 0;
    overflow: visible;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .toc-section::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    overflow: visible;
    scrollbar-width: none;
  }

  .toc-list::-webkit-scrollbar {
    display: none;
  }

  .toc-item {
    margin-bottom: 0.125rem;
  }

  .toc-link {
    display: block;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding: 0.35rem 0.5rem;
    font-size: 0.75rem;
    line-height: 1.4;
    overflow-wrap: anywhere;
    word-break: break-word;
    color: var(--color-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    border-bottom: none;
    /* Inner radius ≈ outer (--radius-lg) minus horizontal inset (padding + link pad) */
    border-radius: max(0px, calc(var(--radius-lg) - 1.25rem));
    transition:
      color var(--duration-normal, 0.2s) ease,
      border-color var(--duration-normal, 0.2s) ease,
      background-color var(--duration-normal, 0.2s) ease;
  }

  .toc-link::after {
    display: none;
  }

  .toc-link:hover {
    color: var(--color-text);
    text-decoration: none;
    background: color-mix(in srgb, var(--color-text) 5%, transparent);
  }

  .toc-link.active {
    color: var(--color-text);
    font-weight: 500;
    /* Real border spans full multi-line block; inset box-shadow clipped oddly on wrapped text */
    border-left-color: var(--color-link);
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
  }

  .category-list,
  .social-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .category-list li,
  .social-links li {
    margin-bottom: 0.25rem;
  }

  .category-list a,
  .social-links a {
    color: var(--color-link);
    text-decoration: none;
    font-size: 0.8rem;
    border-bottom: none;
  }

  .category-list a::after,
  .social-links a::after {
    display: none;
  }

  .category-list a:hover,
  .social-links a:hover {
    color: var(--color-link-hover);
  }

  .sidebar-button {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background-color: var(--color-link);
    color: var(--color-bg);
    text-decoration: none;
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 500;
    border-bottom: none;
    transition: background var(--duration-normal, 0.2s) ease, transform var(--duration-normal, 0.2s) ease;
  }

  .sidebar-button::after {
    display: none;
  }

  @media (hover: hover) {
    .sidebar-button:hover {
      background-color: var(--color-link-hover);
      color: var(--color-bg);
      text-decoration: none;
      transform: translateY(-1px);
    }
  }

  @media (max-width: 768px) {
    /* Right-column TOC hidden — meta already follows article in main column */
    .sidebar-toc-slot {
      display: none !important;
    }

    .sidebar {
      position: static;
      width: 100%;
      max-height: none;
      overflow: visible;
      display: block;
      margin-top: 2rem;
      padding: 1.25rem;
    }

    .sidebar--meta-inline {
      margin-top: 2rem;
      padding-top: 1.75rem;
      max-width: 100%;
    }

    .toc-section {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .sidebar {
      padding: 1rem;
      margin: 1rem 0;
    }
  }
</style>

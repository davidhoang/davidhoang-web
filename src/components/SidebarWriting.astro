---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: Heading[];
}

const { headings = [] } = Astro.props;
const hasHeadings = headings.length > 0;
---

<aside class:list={["sidebar", { "sidebar--with-toc": hasHeadings }]} role="complementary" aria-label="Sidebar with additional information">
  {hasHeadings && (
    <nav class="toc-section" aria-label="Table of contents">
      <h2 class="toc-heading">On this page</h2>
      <ul class="toc-list" role="list">
        {headings.map((heading) => (
          <li class={`toc-item toc-depth-${heading.depth}`}>
            <a href={`#${heading.slug}`} class="toc-link" data-heading-slug={heading.slug}>
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <div class="sidebar-meta glass-border">
    <div class="sidebar-section">
      <h2>Newsletter</h2>
      <p>Subscribe to my newsletter Proof of Concept, sent every Sunday.</p>
      <a href="https://www.proofofconcept.pub/" target="_blank" rel="noopener noreferrer" class="sidebar-button glass-border-button" aria-label="Subscribe to Proof of Concept newsletter">Subscribe →</a>
    </div>

    <div class="sidebar-section">
      <h2>Elsewhere</h2>
      <ul class="social-links" role="list" aria-label="Social media and other links">
        <li><a href="https://twitter.com/davidhoang" target="_blank" rel="noopener noreferrer">Twitter</a></li>
        <li><a href="https://github.com/davidhoang" target="_blank" rel="noopener noreferrer">GitHub</a></li>
        <li><a href="https://linkedin.com/in/dhoang2" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
        <li><a href="/rss.xml" target="_blank" aria-label="RSS feed for this website">RSS Feed</a></li>
      </ul>
    </div>
  </div>
</aside>

<script>
  function initTocScrollSpy() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (tocLinks.length === 0) return;

    const headingElements: HTMLElement[] = [];
    tocLinks.forEach((link) => {
      const slug = link.dataset.headingSlug;
      if (slug) {
        const el = document.getElementById(slug);
        if (el) headingElements.push(el);
      }
    });

    if (headingElements.length === 0) return;

    function updateActiveHeading() {
      const scrollY = window.scrollY;
      const offset = 120;

      let activeSlug = headingElements[0]?.id;
      for (const heading of headingElements) {
        if (heading.offsetTop - offset <= scrollY) {
          activeSlug = heading.id;
        } else {
          break;
        }
      }

      tocLinks.forEach((link) => {
        if (link.dataset.headingSlug === activeSlug) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    }

    // Smooth scroll on click
    tocLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = link.dataset.headingSlug;
        if (!slug) return;
        const target = document.getElementById(slug);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.pushState(null, '', `#${slug}`);
        }
      });
    });

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateActiveHeading();
          ticking = false;
        });
        ticking = true;
      }
    });

    updateActiveHeading();
  }

  // Support Astro view transitions
  document.addEventListener('astro:page-load', initTocScrollSpy);
</script>

<style>
  .sidebar {
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
    min-width: 0;
    height: fit-content;
  }

  /* When there's no TOC, the sidebar is just the meta card */
  .sidebar:not(.sidebar--with-toc) .sidebar-meta {
    /* Card styling applied via glass-border class */
  }

  /* When there IS a TOC, float it without a card box */
  .sidebar--with-toc {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* TOC section — no card, just floating text */
  .toc-section {
    padding: 0;
  }

  .toc-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-height: calc(100vh - var(--nav-height) - 16rem);
    overflow-y: auto;
  }

  .toc-item {
    margin-bottom: 0.125rem;
  }

  .toc-depth-3 {
    padding-left: 1rem;
  }

  .toc-depth-4 {
    padding-left: 2rem;
  }

  .toc-link {
    display: block;
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--color-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    border-bottom: none;
    border-radius: 0;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .toc-link::after {
    display: none;
  }

  .toc-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .toc-link.active {
    color: var(--color-text);
    border-left-color: var(--color-text);
    font-weight: 500;
  }

  /* Newsletter/Elsewhere card */
  .sidebar-meta {
    padding: 1.5rem;
    padding-left: 2rem;
    background-color: var(--color-sidebar-bg);
    border: var(--border-default);
    border-radius: var(--radius-lg);
  }

  .sidebar-section {
    margin-bottom: 1.5rem;
  }

  .sidebar-section:last-child {
    margin-bottom: 0;
  }

  .sidebar-section h2 {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .sidebar-section p {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .category-list,
  .social-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .category-list li,
  .social-links li {
    margin-bottom: 0.5rem;
  }

  .category-list a,
  .social-links a {
    color: var(--color-link);
    text-decoration: none;
    font-size: 0.9rem;
    border-bottom: none;
  }

  .category-list a:hover,
  .social-links a:hover {
    text-decoration: underline;
  }

  .sidebar-button {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 500;
    border-bottom: none;
  }

  .sidebar-button::after {
    display: none;
  }

  @media (hover: hover) {
    .sidebar-button:hover {
      color: var(--color-bg);
      text-decoration: none;
    }
  }

  @media (max-width: 1024px) {
    .toc-link {
      font-size: 0.75rem;
    }

    .sidebar-meta {
      padding: 1.25rem;
    }

    .sidebar-section h2 {
      font-size: 1rem;
    }

    .sidebar-section p {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 768px) {
    .sidebar {
      position: static;
      margin-top: 2rem;
      width: 100%;
    }

    .toc-section {
      display: none;
    }

    .sidebar-meta {
      padding: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .sidebar {
      margin: 1rem 0;
    }
  }
</style>

---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: Heading[];
}

const { headings = [] } = Astro.props;
const hasHeadings = headings.length > 0;
---

<aside class="sidebar glass-border" role="complementary" aria-label="Sidebar with additional information">
  {hasHeadings && (
    <nav class="sidebar-section toc-section" aria-label="Table of contents">
      <h2>On this page</h2>
      <ul class="toc-list" role="list">
        {headings.map((heading) => (
          <li class={`toc-item toc-depth-${heading.depth}`}>
            <a href={`#${heading.slug}`} class="toc-link" data-heading-slug={heading.slug}>
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <div class="sidebar-section">
    <h2>Newsletter</h2>
    <p>Subscribe to my newsletter Proof of Concept, sent every Sunday.</p>
    <a href="https://www.proofofconcept.pub/" target="_blank" rel="noopener noreferrer" class="sidebar-button glass-border-button" aria-label="Subscribe to Proof of Concept newsletter">Subscribe →</a>
  </div>

  <div class="sidebar-section">
    <h2>Elsewhere</h2>
    <ul class="social-links" role="list" aria-label="Social media and other links">
      <li><a href="https://twitter.com/davidhoang" target="_blank" rel="noopener noreferrer">Twitter</a></li>
      <li><a href="https://github.com/davidhoang" target="_blank" rel="noopener noreferrer">GitHub</a></li>
      <li><a href="https://linkedin.com/in/dhoang2" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
      <li><a href="/rss.xml" target="_blank" aria-label="RSS feed for this website">RSS Feed</a></li>
    </ul>
  </div>
</aside>

<script>
  function initSidebar() {
    initTocScrollSpy();
    initStickySidebar();
  }

  function initTocScrollSpy() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (tocLinks.length === 0) return;

    const headingElements: HTMLElement[] = [];
    tocLinks.forEach((link) => {
      const slug = link.dataset.headingSlug;
      if (slug) {
        const el = document.getElementById(slug);
        if (el) headingElements.push(el);
      }
    });

    if (headingElements.length === 0) return;

    const tocList = document.querySelector('.toc-list');

    function updateActiveHeading() {
      const scrollY = window.scrollY;
      const offset = 120;

      let activeSlug = headingElements[0]?.id;
      for (const heading of headingElements) {
        if (heading.offsetTop - offset <= scrollY) {
          activeSlug = heading.id;
        } else {
          break;
        }
      }

      tocLinks.forEach((link) => {
        if (link.dataset.headingSlug === activeSlug) {
          link.classList.add('active');
          if (tocList) {
            const item = link.closest('.toc-item') as HTMLElement;
            if (item) {
              const listTop = tocList.scrollTop;
              const listHeight = tocList.clientHeight;
              const itemTop = item.offsetTop - (tocList as HTMLElement).offsetTop;
              const itemBottom = itemTop + item.offsetHeight;
              if (itemTop < listTop || itemBottom > listTop + listHeight) {
                item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }
            }
          }
        } else {
          link.classList.remove('active');
        }
      });
    }

    tocLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = link.dataset.headingSlug;
        if (!slug) return;
        const target = document.getElementById(slug);
        if (target) {
          // Use the shared smoothScrollTo from BlogPost if available,
          // otherwise fall back to a local implementation
          const navOffset = 88;
          const targetY = target.getBoundingClientRect().top + window.scrollY - navOffset;
          const duration = 1000;

          const startY = window.scrollY;
          const distance = targetY - startY;
          let startTime: number | null = null;

          function ease(t: number): number {
            return t < 0.5
              ? 4 * t * t * t
              : 1 - Math.pow(-2 * t + 2, 3) / 2;
          }

          function step(timestamp: number) {
            if (!startTime) startTime = timestamp;
            const elapsed = timestamp - startTime;
            const progress = Math.min(elapsed / duration, 1);
            window.scrollTo(0, startY + distance * ease(progress));
            if (progress < 1) requestAnimationFrame(step);
          }

          if (Math.abs(distance) > 1) requestAnimationFrame(step);
          history.pushState(null, '', `#${slug}`);
        }
      });
    });

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateActiveHeading();
          ticking = false;
        });
        ticking = true;
      }
    });

    updateActiveHeading();
  }

  function initStickySidebar() {
    const sidebar = document.querySelector<HTMLElement>('.sidebar');
    const contentGrid = document.querySelector<HTMLElement>('.content-grid');
    if (!sidebar || !contentGrid || window.innerWidth <= 768) return;

    const style = getComputedStyle(document.documentElement);
    const navHeight = parseFloat(style.getPropertyValue('--nav-height')) || 40;
    // Nav sits at top: 24px on desktop, so its bottom edge is at 64px
    // Add 24px breathing room below
    const stickyTop = 24 + navHeight + 24;

    // Record the sidebar's initial page-Y position (before any transform)
    const initialPageTop = sidebar.getBoundingClientRect().top + window.scrollY;

    function update() {
      if (window.innerWidth <= 768) {
        sidebar.style.transform = '';
        return;
      }

      const sidebarHeight = sidebar.offsetHeight;
      const gridBottom = contentGrid.getBoundingClientRect().bottom + window.scrollY;
      const maxOffset = gridBottom - initialPageTop - sidebarHeight;

      // How far we need to push the sidebar down to keep it at stickyTop
      const desiredOffset = window.scrollY + stickyTop - initialPageTop;

      if (desiredOffset <= 0) {
        sidebar.style.transform = '';
      } else {
        const clamped = Math.min(desiredOffset, Math.max(0, maxOffset));
        sidebar.style.transform = `translateY(${clamped}px)`;
      }
    }

    window.addEventListener('scroll', update, { passive: true });

    window.addEventListener('resize', () => {
      sidebar.style.transform = '';
    });

    update();
  }

  document.addEventListener('astro:page-load', initSidebar);
</script>

<style>
  .sidebar {
    align-self: start;
    padding: 1.25rem 1.25rem 1.25rem 1.5rem;
    width: 250px;
    background-color: var(--color-sidebar-bg);
    border: var(--border-default);
    border-radius: var(--radius-lg);
    max-height: calc(100vh - var(--nav-height) - 4rem);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    /* no transition — sidebar position tracks scroll synchronously */
  }

  .sidebar-section {
    margin-bottom: 1.25rem;
    flex-shrink: 0;
  }

  .sidebar-section:last-child {
    margin-bottom: 0;
  }

  .sidebar-section h2 {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.5rem 0;
    color: var(--color-muted);
  }

  .sidebar-section p {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-muted);
    margin: 0 0 0.75rem 0;
  }

  /* Table of Contents */
  .toc-section {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1rem;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, var(--color-text) 12%, transparent) transparent;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin-bottom: 0.125rem;
  }

  .toc-depth-3 {
    padding-left: 0.75rem;
  }

  .toc-depth-4 {
    padding-left: 1.5rem;
  }

  .toc-link {
    display: block;
    padding: 0.2rem 0.5rem;
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--color-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    border-bottom: none;
    border-radius: 0;
    transition: color var(--duration-normal, 0.2s) ease, border-color var(--duration-normal, 0.2s) ease;
  }

  .toc-link::after {
    display: none;
  }

  .toc-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .toc-link.active {
    color: var(--color-text);
    border-left-color: var(--color-link);
    font-weight: 500;
  }

  .category-list,
  .social-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .category-list li,
  .social-links li {
    margin-bottom: 0.25rem;
  }

  .category-list a,
  .social-links a {
    color: var(--color-link);
    text-decoration: none;
    font-size: 0.8rem;
    border-bottom: none;
  }

  .category-list a::after,
  .social-links a::after {
    display: none;
  }

  .category-list a:hover,
  .social-links a:hover {
    color: var(--color-link-hover);
  }

  .sidebar-button {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background-color: var(--color-link);
    color: var(--color-bg);
    text-decoration: none;
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 500;
    border-bottom: none;
    transition: background var(--duration-normal, 0.2s) ease, transform var(--duration-normal, 0.2s) ease;
  }

  .sidebar-button::after {
    display: none;
  }

  @media (hover: hover) {
    .sidebar-button:hover {
      background-color: var(--color-link-hover);
      color: var(--color-bg);
      text-decoration: none;
      transform: translateY(-1px);
    }
  }

  @media (max-width: 768px) {
    .sidebar {
      position: static;
      width: 100%;
      max-height: none;
      overflow: visible;
      display: block;
      margin-top: 2rem;
      padding: 1.25rem;
    }

    .toc-section {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .sidebar {
      padding: 1rem;
      margin: 1rem 0;
    }
  }
</style>

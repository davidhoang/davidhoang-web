---
import type { ResolvedFeaturedMedia } from '../utils/linkPreview';

type Props = ResolvedFeaturedMedia;

const { url, kicker, title, description, hostname } = Astro.props;
const cta =
  /podcast/i.test(kicker) || /podcast/i.test(hostname) ? 'Listen to episode' : 'Read article';
---

<a
  class="editorial-media-card"
  href={url}
  target="_blank"
  rel="noopener noreferrer"
>
  <h3 class="editorial-media-card__title">{title}</h3>
  <p class="editorial-media-card__desc">{description}</p>
  <span class="editorial-media-card__cta">{cta}</span>
</a>

<style>
  .editorial-media-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    padding: clamp(1rem, 2.2vw, 1.25rem);
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    min-width: 0;
    box-shadow:
      0 1px 1px rgba(0, 0, 0, 0.02),
      0 2px 4px rgba(0, 0, 0, 0.03);
    transform: translateY(0);
    transition:
      transform 0.45s var(--ease-inertia, ease),
      border-color 0.3s var(--ease-inertia, ease),
      box-shadow 0.45s var(--ease-inertia, ease);
  }

  .editorial-media-card:hover {
    border-color: color-mix(in srgb, var(--color-text) 18%, transparent);
    transform: translateY(-3px);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 8px 14px rgba(0, 0, 0, 0.06),
      0 18px 32px rgba(0, 0, 0, 0.08);
  }

  .editorial-media-card:active {
    transform: translateY(-1px);
    transition-duration: 0.12s;
  }

  .editorial-media-card:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 3px;
  }

  /* Opt out of global a::before glow + a::after gradient underline */
  .editorial-media-card::before,
  .editorial-media-card::after {
    display: none;
    content: none;
  }

  .editorial-media-card__title {
    margin: 0;
    font-size: clamp(1.1rem, 2.3vw, 1.3rem);
    line-height: 1.28;
    letter-spacing: var(--letter-spacing-heading-md, -0.01em);
    font-weight: var(--heading-weight, 600);
    color: var(--color-text);
    transition: color var(--duration-normal, 0.2s) ease;
  }

  .editorial-media-card:hover .editorial-media-card__title {
    color: var(--color-link-hover);
  }

  .editorial-media-card__desc {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--color-muted);
    letter-spacing: var(--letter-spacing-body, 0.005em);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .editorial-media-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.15rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-link);
    text-decoration: none;
    transition: color var(--duration-normal, 0.2s) ease;
  }

  .editorial-media-card__cta::after {
    content: "→";
    display: inline-block;
    font-size: 0.95em;
    transform: translateX(0);
    transition: transform 0.35s var(--ease-inertia, ease);
  }

  .editorial-media-card:hover .editorial-media-card__cta {
    color: var(--color-link-hover);
  }

  .editorial-media-card:hover .editorial-media-card__cta::after {
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .editorial-media-card,
    .editorial-media-card:hover,
    .editorial-media-card:active,
    .editorial-media-card__cta::after,
    .editorial-media-card:hover .editorial-media-card__cta::after {
      transform: none;
    }
  }
</style>

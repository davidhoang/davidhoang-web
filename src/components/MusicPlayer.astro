---
import MusicPlayerLazy from './MusicPlayerLazy.tsx';
---

<div data-astro-transition-scope="music-player">
  <MusicPlayerLazy client:idle />
</div>

<style is:global>
  /* ========================================
     Winamp 2.x Classic Skin — Authentic Colors
     ======================================== */
  :root {
    /* Core chassis — the textured dark gray body */
    --wa-chassis: #29292d;
    --wa-chassis-light: #3a3a40;
    --wa-chassis-dark: #1a1a1e;
    --wa-chassis-highlight: #484850;
    --wa-chassis-shadow: #101014;

    /* Title bar — deep navy blue gradient */
    --wa-titlebar-from: #000040;
    --wa-titlebar-to: #0000c0;

    /* Display — the black LCD area */
    --wa-display-bg: #000000;
    --wa-display-border: #0e0e12;

    /* Green LCD palette */
    --wa-green: #00ff00;
    --wa-green-bright: #66ff66;
    --wa-green-dim: #00b800;
    --wa-green-dark: #006400;
    --wa-green-ghost: #002200;

    /* Spectrum analyzer palette */
    --wa-spectrum-low: #00c800;
    --wa-spectrum-mid: #c8c800;
    --wa-spectrum-high: #c80000;

    /* Slider thumbs — olive/khaki classic look */
    --wa-thumb: #9ca078;
    --wa-thumb-hi: #c0c0a0;
    --wa-thumb-lo: #606048;

    /* Playlist */
    --wa-pl-bg: #1a1a2e;
    --wa-pl-text: #00ff00;
    --wa-pl-current: #ffffff;
    --wa-pl-highlight: #0000c0;

    /* Misc */
    --wa-orange: #ff8800;
    --wa-red: #ff0000;
  }

  /* ========================================
     Container & Toggle
     ======================================== */
  .winamp-player {
    position: fixed;
    bottom: 0;
    left: 0;
    z-index: var(--z-texture);
    font-family: 'Tahoma', 'MS Sans Serif', 'Arial', sans-serif;
    font-size: 11px;
    user-select: none;
    transform: translateZ(0);
    will-change: transform;
    image-rendering: pixelated;
  }

  .winamp-player.dragging {
    cursor: grabbing !important;
  }

  .winamp-player.dragging * {
    pointer-events: none;
  }

  .winamp-player.dragging .winamp-titlebar {
    pointer-events: auto;
  }

  .winamp-minimized {
    position: fixed;
    bottom: 0;
    left: 0;
    z-index: var(--z-texture);
  }

  .winamp-minimized .winamp-toggle-btn {
    background: linear-gradient(180deg, #3a3a40 0%, #29292d 60%, #1a1a1e 100%);
    border: 1px solid #101014;
    border-top-color: #484850;
    border-left-color: #484850;
    padding: 5px 10px;
    font-size: 9px;
    font-weight: bold;
    letter-spacing: 1px;
    cursor: pointer;
    color: #b0b0b0;
    text-shadow: 0 1px 0 #000;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      inset 0 -1px 0 rgba(0, 0, 0, 0.4),
      0 2px 6px rgba(0, 0, 0, 0.5);
  }

  .winamp-minimized .winamp-toggle-btn:hover {
    color: var(--wa-green);
    text-shadow: 0 0 6px rgba(0, 255, 0, 0.4);
  }

  /* ========================================
     Shared Panel Skin — textured embossed metal
     ======================================== */
  .winamp-main,
  .winamp-equalizer,
  .winamp-playlist {
    width: 275px;
    background:
      repeating-linear-gradient(
        0deg,
        transparent 0px,
        transparent 1px,
        rgba(255, 255, 255, 0.015) 1px,
        rgba(255, 255, 255, 0.015) 2px
      ),
      linear-gradient(180deg, #33333a 0%, #29292d 40%, #222228 100%);
    border: 1px solid var(--wa-chassis-shadow);
    box-shadow:
      inset 1px 1px 0 var(--wa-chassis-highlight),
      inset -1px -1px 0 var(--wa-chassis-shadow),
      0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .winamp-main {
    border-bottom: none;
  }

  .winamp-equalizer {
    border-top: none;
    border-bottom: none;
  }

  .winamp-playlist {
    border-top: none;
    max-height: 300px;
    display: flex;
    flex-direction: column;
  }

  /* ========================================
     Title Bar — deep navy gradient with emboss
     ======================================== */
  .winamp-titlebar {
    background: linear-gradient(90deg, var(--wa-titlebar-from) 0%, var(--wa-titlebar-to) 50%, var(--wa-titlebar-from) 100%);
    color: #fff;
    padding: 2px 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 9px;
    font-weight: bold;
    letter-spacing: 0.5px;
    cursor: move;
    border-bottom: 1px solid #000020;
    box-shadow:
      inset 0 1px 0 rgba(100, 100, 255, 0.2),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    min-height: 16px;
  }

  .winamp-logo {
    font-size: 7px;
    letter-spacing: 1.5px;
    opacity: 0.7;
  }

  .winamp-title {
    flex: 1;
    text-align: center;
    text-shadow: 0 0 4px rgba(100, 100, 255, 0.4);
  }

  .winamp-window-controls {
    display: flex;
    gap: 1px;
  }

  .winamp-btn-minimize,
  .winamp-btn-close {
    background: linear-gradient(180deg, #4a4a52 0%, #2a2a30 100%);
    border: 1px solid #000;
    border-top-color: #5a5a62;
    border-left-color: #5a5a62;
    width: 9px;
    height: 9px;
    font-size: 8px;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    line-height: 1;
    color: #ccc;
    box-shadow: inset -1px -1px 0 #111;
  }

  .winamp-btn-minimize:hover,
  .winamp-btn-close:hover {
    background: linear-gradient(180deg, #5a5a64 0%, #3a3a44 100%);
    color: #fff;
  }

  .winamp-btn-close:hover {
    background: linear-gradient(180deg, #cc0000 0%, #880000 100%);
    color: #fff;
  }

  /* ========================================
     Display Area — the black LCD panel
     ======================================== */
  .winamp-display {
    background: var(--wa-display-bg);
    padding: 6px;
    margin: 3px 4px;
    border: 1px solid var(--wa-display-border);
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.8),
      inset 2px 2px 4px rgba(0, 0, 0, 0.5);
    min-height: 140px;
  }

  /* ========================================
     Time Display — green LED segment style
     ======================================== */
  .winamp-time-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
    padding: 3px 6px;
  }

  .winamp-time-display {
    font-family: 'Courier New', monospace;
    font-size: 26px;
    color: var(--wa-green);
    text-shadow:
      0 0 6px var(--wa-green),
      0 0 12px rgba(0, 255, 0, 0.4);
    font-weight: bold;
    letter-spacing: 2px;
    display: flex;
    gap: 1px;
  }

  .winamp-digit {
    display: inline-block;
    min-width: 16px;
    text-align: center;
    background: var(--wa-green-ghost);
    padding: 1px 2px;
  }

  .winamp-digit.colon {
    min-width: 8px;
    background: transparent;
    animation: blink-colon 1s step-end infinite;
  }

  @keyframes blink-colon {
    50% { opacity: 0.3; }
  }

  .winamp-time-remaining {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: var(--wa-green-dim);
    text-shadow: 0 0 3px var(--wa-green-dark);
    font-weight: bold;
  }

  /* ========================================
     Seek Bar — thin groove with colored fill
     ======================================== */
  .winamp-seek-container {
    position: relative;
    height: 8px;
    background: #0a0a0a;
    border: 1px solid #050505;
    margin: 0 2px 5px;
    cursor: pointer;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.8);
  }

  .winamp-seek-slider {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    z-index: 2;
    -webkit-appearance: none;
    appearance: none;
    margin: 0;
  }

  .winamp-seek-progress {
    position: absolute;
    height: 100%;
    background: linear-gradient(180deg, #80c080 0%, #40a040 50%, #208020 100%);
    box-shadow: 0 0 3px rgba(0, 200, 0, 0.3);
    transition: width 0.15s linear;
    pointer-events: none;
  }

  .winamp-seek-slider:disabled + .winamp-seek-progress {
    background: #1a1a1a;
    box-shadow: none;
  }

  /* ========================================
     Track Info Marquee
     ======================================== */
  .winamp-track-info-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
    gap: 6px;
  }

  .winamp-track-info {
    flex: 1;
    color: var(--wa-green);
    font-size: 8px;
    font-family: 'Tahoma', 'Arial', sans-serif;
    overflow: hidden;
    position: relative;
    padding: 2px 0;
    text-shadow: 0 0 4px rgba(0, 255, 0, 0.3);
    height: 14px;
    line-height: 14px;
  }

  .winamp-track-scrolling {
    display: inline-block;
    white-space: nowrap;
    animation: wa-marquee 12s linear infinite;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  @keyframes wa-marquee {
    0% { transform: translateX(100%); }
    100% { transform: translateX(-100%); }
  }

  .winamp-track-info:hover .winamp-track-scrolling {
    animation-play-state: paused;
  }

  .winamp-bitrate-display {
    display: flex;
    gap: 4px;
    color: var(--wa-green);
    font-size: 7px;
    font-family: 'Courier New', monospace;
    white-space: nowrap;
  }

  .winamp-bitrate::after {
    content: 'kbps';
    margin-left: 1px;
    color: var(--wa-green-dim);
  }

  .winamp-khz::after {
    content: 'kHz';
    margin-left: 1px;
    color: var(--wa-green-dim);
  }

  /* ========================================
     Spectrum Analyzer — segmented colored bars
     ======================================== */
  .winamp-spectrum {
    display: flex;
    align-items: flex-end;
    gap: 1px;
    height: 26px;
    margin-bottom: 5px;
    padding: 2px;
    background: rgba(0, 10, 0, 0.3);
  }

  .winamp-spectrum-bar {
    flex: 1;
    min-height: 1px;
    transition: height 0.08s ease-out;
    /* Segmented look via repeating-gradient */
    background:
      repeating-linear-gradient(
        to top,
        transparent 0px,
        transparent 1px,
        rgba(0, 0, 0, 0.6) 1px,
        rgba(0, 0, 0, 0.6) 2px
      );
    background-color: var(--wa-green);
    border-radius: 0;
  }

  /* ========================================
     Volume & Balance
     ======================================== */
  .winamp-volume-balance-container {
    display: flex;
    gap: 8px;
    margin-bottom: 4px;
    padding: 3px 4px;
    align-items: center;
  }

  .winamp-volume-control,
  .winamp-balance-control {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
  }

  .winamp-label {
    font-size: 7px;
    color: var(--wa-green-dim);
    font-weight: bold;
    min-width: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* -- Horizontal slider shared styles -- */
  .winamp-volume-slider,
  .winamp-balance-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 68px;
    height: 10px;
    background: transparent;
    cursor: pointer;
  }

  .winamp-volume-slider::-webkit-slider-runnable-track,
  .winamp-balance-slider::-webkit-slider-runnable-track {
    background:
      linear-gradient(180deg, #0a0a0a 0%, #1a1a1a 40%, #0a0a0a 100%);
    border: 1px solid #000;
    height: 4px;
    box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.8);
  }

  .winamp-volume-slider::-webkit-slider-thumb,
  .winamp-balance-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 12px;
    margin-top: -5px;
    background: linear-gradient(180deg, var(--wa-thumb-hi) 0%, var(--wa-thumb) 50%, var(--wa-thumb-lo) 100%);
    border: 1px solid #2a2a20;
    border-top-color: var(--wa-thumb-hi);
    border-left-color: var(--wa-thumb-hi);
    cursor: pointer;
    box-shadow:
      inset -1px -1px 0 var(--wa-thumb-lo),
      0 1px 2px rgba(0, 0, 0, 0.5);
  }

  .winamp-volume-slider::-moz-range-track,
  .winamp-balance-slider::-moz-range-track {
    background:
      linear-gradient(180deg, #0a0a0a 0%, #1a1a1a 40%, #0a0a0a 100%);
    border: 1px solid #000;
    height: 4px;
    box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.8);
  }

  .winamp-volume-slider::-moz-range-thumb,
  .winamp-balance-slider::-moz-range-thumb {
    width: 14px;
    height: 12px;
    background: linear-gradient(180deg, var(--wa-thumb-hi) 0%, var(--wa-thumb) 50%, var(--wa-thumb-lo) 100%);
    border: 1px solid #2a2a20;
    border-top-color: var(--wa-thumb-hi);
    border-left-color: var(--wa-thumb-hi);
    cursor: pointer;
    box-shadow:
      inset -1px -1px 0 var(--wa-thumb-lo),
      0 1px 2px rgba(0, 0, 0, 0.5);
    border-radius: 0;
  }

  .winamp-volume-display,
  .winamp-balance-display {
    font-size: 7px;
    color: var(--wa-green-dim);
    font-family: 'Courier New', monospace;
    min-width: 18px;
    text-align: right;
  }

  /* ========================================
     Mode Buttons (mono/stereo) & Toggle (EQ/PL)
     ======================================== */
  .winamp-mode-buttons {
    display: flex;
    gap: 3px;
    margin-bottom: 3px;
  }

  .winamp-mode-btn {
    background: transparent;
    border: none;
    color: var(--wa-green-dark);
    padding: 1px 4px;
    font-size: 7px;
    font-family: 'Tahoma', sans-serif;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.1s;
  }

  .winamp-mode-btn.active {
    color: var(--wa-green);
    text-shadow: 0 0 6px rgba(0, 255, 0, 0.5);
    font-weight: bold;
  }

  .winamp-toggle-buttons {
    display: flex;
    gap: 3px;
  }

  .winamp-toggle-btn {
    background: transparent;
    border: 1px solid var(--wa-chassis-dark);
    color: var(--wa-green-dark);
    padding: 1px 6px;
    font-size: 8px;
    font-weight: bold;
    font-family: 'Tahoma', sans-serif;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: all 0.1s;
  }

  .winamp-toggle-btn:hover {
    color: var(--wa-green-dim);
  }

  .winamp-toggle-btn.active {
    color: var(--wa-green);
    text-shadow: 0 0 6px rgba(0, 255, 0, 0.5);
    border-color: var(--wa-green-dark);
  }

  /* ========================================
     Transport Controls — chunky beveled buttons
     ======================================== */
  .winamp-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 4px 6px 5px;
    background: linear-gradient(180deg, #2e2e34 0%, #26262c 100%);
    border-top: 1px solid var(--wa-chassis-shadow);
  }

  .winamp-control-btn {
    background: linear-gradient(180deg, #4a4a52 0%, #36363c 40%, #2a2a30 100%);
    border: 1px solid #101014;
    border-top-color: #5a5a64;
    border-left-color: #5a5a64;
    padding: 0;
    font-size: 11px;
    cursor: pointer;
    width: 28px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c0c0c0;
    box-shadow:
      inset -1px -1px 0 #151518,
      inset 0 0 0 0.5px rgba(255, 255, 255, 0.03);
    transition: none;
  }

  .winamp-control-btn:hover:not(:disabled) {
    background: linear-gradient(180deg, #5a5a64 0%, #44444c 40%, #36363c 100%);
    color: #fff;
  }

  .winamp-control-btn:active:not(:disabled) {
    background: linear-gradient(180deg, #222228 0%, #2a2a30 100%);
    border-top-color: #101014;
    border-left-color: #101014;
    border-bottom-color: #5a5a64;
    border-right-color: #5a5a64;
    box-shadow: inset 1px 1px 2px rgba(0, 0, 0, 0.6);
    padding-top: 1px;
    padding-left: 1px;
  }

  .winamp-control-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* ========================================
     Equalizer Window
     ======================================== */
  .winamp-eq-controls {
    display: flex;
    gap: 3px;
    padding: 3px 4px;
  }

  .winamp-eq-btn {
    background: linear-gradient(180deg, #4a4a52 0%, #36363c 40%, #2a2a30 100%);
    border: 1px solid #101014;
    border-top-color: #5a5a64;
    border-left-color: #5a5a64;
    padding: 2px 6px;
    font-size: 8px;
    font-weight: bold;
    cursor: pointer;
    color: #a0a0a0;
    font-family: 'Tahoma', sans-serif;
    box-shadow: inset -1px -1px 0 #151518;
  }

  .winamp-eq-btn:hover {
    color: #d0d0d0;
    background: linear-gradient(180deg, #5a5a64 0%, #44444c 40%, #36363c 100%);
  }

  .winamp-eq-btn:active {
    background: linear-gradient(180deg, #222228 0%, #2a2a30 100%);
    border-top-color: #101014;
    border-left-color: #101014;
    box-shadow: inset 1px 1px 2px rgba(0, 0, 0, 0.5);
  }

  .winamp-eq-btn.active {
    color: var(--wa-green);
    text-shadow: 0 0 4px rgba(0, 255, 0, 0.3);
  }

  .winamp-eq-sliders {
    display: flex;
    padding: 6px 8px;
    gap: 6px;
  }

  .winamp-eq-scale {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    font-size: 7px;
    color: var(--wa-green-dark);
    padding-right: 4px;
    height: 100px;
    font-family: 'Courier New', monospace;
  }

  .winamp-eq-scale-label {
    text-align: right;
  }

  .winamp-eq-slider-group {
    display: flex;
    gap: 3px;
    flex: 1;
  }

  .winamp-eq-slider-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .winamp-eq-slider-container label {
    font-size: 7px;
    color: var(--wa-green-dark);
    font-weight: bold;
    font-family: 'Tahoma', sans-serif;
  }

  .winamp-eq-slider {
    -webkit-appearance: slider-vertical;
    writing-mode: bt-lr;
    width: 16px;
    height: 80px;
    background: transparent;
    cursor: pointer;
  }

  .winamp-eq-slider::-webkit-slider-track {
    background: linear-gradient(180deg, #0a0a0a, #1a1a1a);
    border: 1px solid #000;
    width: 6px;
  }

  .winamp-eq-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 8px;
    background: linear-gradient(180deg, var(--wa-thumb-hi) 0%, var(--wa-thumb) 50%, var(--wa-thumb-lo) 100%);
    border: 1px solid #2a2a20;
    border-top-color: var(--wa-thumb-hi);
    border-left-color: var(--wa-thumb-hi);
    cursor: pointer;
    box-shadow: inset -1px -1px 0 var(--wa-thumb-lo);
  }

  .winamp-eq-slider::-moz-range-track {
    background: linear-gradient(180deg, #0a0a0a, #1a1a1a);
    border: 1px solid #000;
    width: 6px;
  }

  .winamp-eq-slider::-moz-range-thumb {
    width: 14px;
    height: 8px;
    background: linear-gradient(180deg, var(--wa-thumb-hi) 0%, var(--wa-thumb) 50%, var(--wa-thumb-lo) 100%);
    border: 1px solid #2a2a20;
    border-top-color: var(--wa-thumb-hi);
    border-left-color: var(--wa-thumb-hi);
    cursor: pointer;
    box-shadow: inset -1px -1px 0 var(--wa-thumb-lo);
    border-radius: 0;
  }

  /* ========================================
     Playlist Window — dark bg, green text
     ======================================== */
  .winamp-playlist-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }

  .winamp-playlist-tracks {
    flex: 1;
    overflow-y: auto;
    padding: 2px;
    background: var(--wa-pl-bg);
    border: 1px solid #0a0a14;
    margin: 3px 4px;
    font-size: 10px;
    font-family: 'Tahoma', 'Arial', sans-serif;
    color: var(--wa-pl-text);
    max-height: 200px;
    box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.5);
  }

  .winamp-playlist-track {
    padding: 1px 4px;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.5;
    display: flex;
    justify-content: space-between;
  }

  .winamp-playlist-track:hover {
    background: rgba(0, 100, 200, 0.2);
  }

  .winamp-playlist-track.active {
    background: var(--wa-pl-highlight);
    color: var(--wa-pl-current);
  }

  .winamp-playlist-controls {
    display: flex;
    gap: 2px;
    padding: 3px 4px;
  }

  .winamp-playlist-btn {
    background: linear-gradient(180deg, #4a4a52 0%, #36363c 40%, #2a2a30 100%);
    border: 1px solid #101014;
    border-top-color: #5a5a64;
    border-left-color: #5a5a64;
    padding: 2px 5px;
    font-size: 7px;
    font-weight: bold;
    cursor: pointer;
    color: #a0a0a0;
    font-family: 'Tahoma', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    box-shadow: inset -1px -1px 0 #151518;
  }

  .winamp-playlist-btn:hover {
    color: #d0d0d0;
    background: linear-gradient(180deg, #5a5a64 0%, #44444c 40%, #36363c 100%);
  }

  .winamp-playlist-btn:active {

    <section aria-label="Footer navigation">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Social</h4>
          <ul role="list">
            <li><a href="https://github.com/davidhoang" target="_blank" rel="noopener noreferrer" aria-label="David Hoang on GitHub (opens in new tab)">GitHub</a></li>
            <li><a href="https://linkedin.com/in/dhoang2" target="_blank" rel="noopener noreferrer" aria-label="David Hoang on LinkedIn (opens in new tab)">LinkedIn</a></li>
            <li><a href="https://sublime.app/davidhoang" target="_blank" rel="noopener noreferrer" aria-label="David Hoang on Sublime (opens in new tab)">Sublime</a></li>
            <li><a href="https://twitter.com/davidhoang" target="_blank" rel="noopener noreferrer" aria-label="David Hoang on Twitter (opens in new tab)">Twitter</a></li>

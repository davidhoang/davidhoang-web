---
import { footerBrand, footerSections } from '../data/navigation';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo" aria-label="Site footer">
  <div class="container">
    <section class="footer-nav" aria-label="Footer navigation">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label="David Hoang homepage">DH</a>
          <p class="footer-tagline">{footerBrand.tagline}</p>
          <a href={footerBrand.emailHref} class="footer-link footer-email-link">Email me</a>
        </div>

        {footerSections.map((section) => (
          <nav class="footer-col" aria-label={section.title}>
            <details class="footer-col__details">
              <summary class="footer-col__heading">{section.title}</summary>
              <ul role="list">
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="footer-link"
                      aria-label={link.ariaLabel}
                      target={link.external ? '_blank' : undefined}
                      rel={link.external ? 'noopener noreferrer' : undefined}
                    >
                      {link.label}
                      {link.external && (
                        <span class="footer-external" aria-hidden="true">↗</span>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          </nav>
        ))}
      </div>
    </section>

    <section class="footer-meta" aria-label="Copyright and colophon">
      <p class="footer-copyright">
        &copy; 2002–{currentYear} David Hoang. All rights reserved.
        <span class="footer-quote">
          “Sometimes to create, one must first destroy.” —David, <cite>Prometheus</cite>
        </span>
      </p>
      <p class="footer-tools-footnote">
        Built with <a href="https://paper.design" target="_blank" rel="noopener noreferrer" aria-label="Paper (opens in new tab)">Paper</a> and <a href="https://astro.build" target="_blank" rel="noopener noreferrer" aria-label="Astro (opens in new tab)">Astro</a>.
      </p>
    </section>
  </div>
</footer>

---
import { footerSections, footerUtilityLinks } from '../data/navigation';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo" aria-label="Site footer">
  <div class="container">
    <section aria-label="Footer navigation">
      <div class="footer-grid">
        {footerSections.map((section) => (
          <div class="footer-col">
            <h4>{section.title}</h4>
            <ul role="list">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    aria-label={link.ariaLabel}
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
    <div class="footer-bottom">
      <p class="footer-status">&copy; {currentYear} David Hoang. Design, writing, and experiments.</p>
      <ul class="footer-utility" role="list" aria-label="Footer utility links">
        {footerUtilityLinks.map((link) => (
          <li>
            <a href={link.href} type={link.type} aria-label={link.ariaLabel}>{link.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>

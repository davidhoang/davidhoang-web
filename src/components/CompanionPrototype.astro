---
interface Props {
  slug: string;
  title?: string;
  description?: string;
}

const {
  slug,
  title = 'Interactive companion',
  description = 'Explore the tectonic cross-section — hover each stage to read the friction at the collision front.',
} = Astro.props;

const href = `/prototypes/${slug}`;
---

<aside class="companion-prototype" aria-label="Interactive companion">
  <p class="companion-prototype__eyebrow">Interactive companion</p>
  <h2 class="companion-prototype__title">{title}</h2>
  <p class="companion-prototype__desc">{description}</p>
  <a class="companion-prototype__link" href={href}>
    Open the cross-section
    <span aria-hidden="true">→</span>
  </a>
</aside>

<style>
  .companion-prototype {
    margin: var(--spacing-xl) 0 calc(var(--spacing-xl) + var(--spacing-sm));
    padding: calc(var(--spacing-md) + var(--spacing-xs)) 1.35rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent, var(--color-text));
    border-radius: var(--radius-md, 8px);
    background: var(--color-sidebar-bg, var(--color-bg));
  }

  .companion-prototype__eyebrow {
    margin: 0 0 var(--spacing-sm);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .companion-prototype__title {
    margin: 0 0 var(--spacing-sm);
    font-family: var(--font-heading, inherit);
    font-size: 1.25rem;
    line-height: 1.25;
    font-weight: 500;
  }

  .companion-prototype__desc {
    margin: 0 0 var(--spacing-md);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .companion-prototype__link {
    display: inline-flex;
    align-items: center;
    gap: calc(var(--spacing-xs) + 0.1rem);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  .companion-prototype__link:hover {
    color: var(--color-accent, var(--color-text));
  }
</style>

---
import MainLayout from '../layouts/MainLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const pageDescription =
  'Labs experiments are paused. This page is kept for existing links.';
const ogImage = '/images/img-dh.webp';
---

<MainLayout title="Labs - David Hoang" description={pageDescription} ogImage={ogImage}>
  <PageHeader title="Labs" image="/images/highlights/img-highlights-proof-of-concept.webp" alt="Labs" />
  <div class="container labs-deprecation">
    <p class="labs-deprecation__lead">
      The Labs experiments on this page are <strong>deprecated for now</strong>. Interactive demos and generative previews have been turned off while the section is on hold.
    </p>
    <p class="labs-deprecation__muted">
      You can still browse the rest of the site from <a href="/">the homepage</a> or see ongoing experiments at
      <a href="https://www.proofofconcept.pub" target="_blank" rel="noopener">Proof of Concept</a>.
    </p>
  </div>
</MainLayout>

<style>
  .labs-deprecation {
    max-width: 42rem;
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
  }

  .labs-deprecation__lead {
    font-size: 1.1rem;
    line-height: 1.55;
    margin: 0 0 var(--spacing-md);
  }

  .labs-deprecation__muted {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0;
  }

  .labs-deprecation__muted a {
    color: var(--color-link);
  }
</style>

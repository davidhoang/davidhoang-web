---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import MainLayout from '../layouts/MainLayout.astro';
import SubstackSignup from '../components/SubstackSignup.astro';
import { AnimatedPhilosophyGrid, AnimatedPortfolioGrid } from '../components/AnimatedSections';
import CardStackHeroLazy from '../components/CardStackHeroLazy';
import '../styles/pages/home.css';
import '../styles/modules/card-stack-hero.css';
import dhWebLightAsset from '../assets/images/img-dh-web-light.webp';
import imgHatch from '../assets/images/highlights/img-highlights-hatch-conference.webp';
import imgReplit from '../assets/images/highlights/img-highlights-replit.webp';
import imgPlay from '../assets/images/highlights/img-highlights-play.webp';
import imgPoc from '../assets/images/highlights/img-highlights-proof-of-concept.webp';

const PORTFOLIO_SIZES = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 600px';

async function optimizePortfolioImage(src: ImageMetadata) {
  const result = await getImage({
    src,
    widths: [400, 800, 1200],
    sizes: PORTFOLIO_SIZES,
    format: 'webp',
  });
  return {
    src: result.src,
    srcSet: result.srcSet.attribute,
    sizes: PORTFOLIO_SIZES,
    width: src.width,
    height: src.height,
  };
}

// Pre-resolve the 'about' card thumbnail to an optimized hashed URL so the
// preload tag and the React-side card share the exact same href (cache hit
// instead of double download). Card thumbnails render as CSS background-image,
// so a single right-sized variant is what we want; no srcset needed.
const dhWebOptimized = await getImage({ src: dhWebLightAsset, width: 480, format: 'webp' });

// Page metadata
const pageDescription = "David Hoang is a designer, investor, and builder focused on tools that revolutionize the internet. VP and Head of Design, Rovo & AI and Ecosystem at Atlassian. Previously at Replit, Webflow, and One Medical.";
const ogImage = "/images/img-dh-web-light.webp";

// Philosophy items data
const philosophyItems = [
  { content: '<strong>Seek paradigm shifts.</strong> Imagine the future and build it now. Those who can spot trends of shifts will have enduring success.' },
  { content: '<strong>Embrace the entrepreneurial spirit.</strong> Act like the owner of everything you do.', id: 'e3d275' },
  { content: '<strong>Software is beautiful.</strong> Making high quality software is a calling and privilege to do so.' },
  { content: '<strong>Method makes magic.</strong> Design is not magic. It\'s a method—a rigorous process of exploration, iteration, and validation until you reach a result that feels magical.', id: '647f3a' },
  { content: '<strong>Iteration over perfectionism.</strong> The number one way to be more productive is to reduce the iteration cycle.' },
];

// Portfolio items data — images pre-optimized via astro:assets so the React
// component just renders the resolved src/srcSet without re-deriving them.
const portfolioItems = [
  {
    text: 'September 2024: Keynote talk at Hatch Conference: Design & (Blank)',
    link: 'https://www.youtube.com/watch?v=4lWYcr53kyI',
    linkText: 'Keynote talk at Hatch Conference: Design & (Blank)',
    image: await optimizePortfolioImage(imgHatch),
    imageAlt: 'David Hoang speaking at Hatch Conference 2024, presenting on stage',
  },
  {
    text: 'April 2024: Replit Developer Day and rebrand.',
    link: 'https://www.youtube.com/watch?v=T6R9nx89bY4',
    linkText: 'Replit Developer Day',
    image: await optimizePortfolioImage(imgReplit),
    imageAlt: 'Replit Developer Day 2024 event branding and visual identity',
  },
  {
    text: 'April 2023: Joined Play as Advisor.',
    link: 'https://createwithplay.com',
    linkText: 'Play',
    image: await optimizePortfolioImage(imgPlay),
    imageAlt: 'Play app interface and branding design',
  },
  {
    text: 'December 2019: Launched Proof of Concept, a newsletter about design, technology, and entrepreneurship.',
    link: 'https://www.proofofconcept.pub',
    linkText: 'Proof of Concept',
    image: await optimizePortfolioImage(imgPoc),
    imageAlt: 'Proof of Concept newsletter branding and design layout',
  },
];
---

<MainLayout title="David Hoang — Designer, Investor & Builder" description={pageDescription} ogImage={ogImage}>
  {/* Preload hero card images early — Astro SSR preloads <img> sources inside
      the island, but the "about" thumbnail uses background-image (invisible to
      the preload scanner) and config-still benefits from an earlier head hint. */}
  <link slot="head" rel="preload" as="image" href={dhWebOptimized.src} type="image/webp" />
  <link slot="head" rel="preload" as="image" href="/images/davidhoang-web-config-still.webp" type="image/webp" fetchpriority="high" />
  <!-- Card Stack Hero -->
  <section class="card-stack-section" aria-label="Current activities and projects">
    <CardStackHeroLazy
      client:idle
      aboutThumbnailSrc={dhWebOptimized.src}
      lcpImageSrc="/images/davidhoang-web-config-still.webp"
    />
  </section>

  <section class="design-philosophy" aria-labelledby="philosophy-heading">
    <h2 id="philosophy-heading" class="home-section-heading text-heading">Design philosophy</h2>
    <AnimatedPhilosophyGrid items={philosophyItems} client:visible />
  </section>

  <!-- Portfolio Section -->
  <section class="portfolio-section" aria-labelledby="highlights-heading">
    <h2 id="highlights-heading" class="home-section-heading text-heading">Highlights</h2>
    <AnimatedPortfolioGrid items={portfolioItems} client:visible />
  </section>

  <!-- Full Newsletter Signup Section -->
  <section class="newsletter-section" aria-labelledby="newsletter-heading">
    <SubstackSignup headingId="newsletter-heading" />
  </section>

</MainLayout>

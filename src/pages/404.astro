---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 — Page not found" description="The page you're looking for doesn't exist.">
  <div class="not-found">
    <p class="error-code">404</p>
    <h1>Page not found</h1>
    <p class="message">The page you're looking for doesn't exist or has been moved.</p>
    <nav class="suggestions" aria-label="Suggested pages">
      <a href="/">Home</a>
      <a href="/writing">Writing</a>
      <a href="/notes">Notes</a>
      <a href="/about">About</a>
    </nav>
  </div>

  <style>
    .not-found {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      min-height: 60vh;
      padding: 2rem 1rem;
    }

    .error-code {
      font-size: clamp(6rem, 15vw, 10rem);
      font-weight: 700;
      line-height: 1;
      margin: 0;
      color: var(--color-muted);
      opacity: 0.15;
      letter-spacing: -0.04em;
    }

    h1 {
      font-size: clamp(1.5rem, 4vw, 2.25rem);
      font-weight: 600;
      margin: -1rem 0 0.75rem;
      letter-spacing: -0.02em;
    }

    .message {
      color: var(--color-muted);
      font-size: 1.05rem;
      margin: 0 0 2rem;
      max-width: 40ch;
    }

    .suggestions {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .suggestions a {
      color: var(--color-text);
      text-decoration: none;
      font-weight: 500;
      padding: 0.5rem 1.25rem;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      font-size: 0.9rem;
      transition: background-color 0.15s ease, border-color 0.15s ease;
    }

    .suggestions a:hover {
      background-color: var(--color-text);
      color: var(--color-bg);
      border-color: var(--color-text);
    }

    .suggestions a:focus-visible {
      outline: 2px solid var(--color-link);
      outline-offset: 2px;
    }
  </style>
</MainLayout>

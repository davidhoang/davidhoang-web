---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 — Page not found" description="The page you're looking for doesn't exist." hideFooter={true}>
  <div class="not-found">
    <div class="error-code" aria-hidden="true">
      <span class="digit" style="--i:0">4</span>
      <span class="digit" style="--i:1">0</span>
      <span class="digit" style="--i:2">4</span>
    </div>
    <h1>Page not found</h1>
    <p class="message">The page you're looking for doesn't exist or has been moved.</p>
    <nav class="suggestions" aria-label="Suggested pages">
      <a href="/">Home</a>
      <a href="/writing">Writing</a>
      <a href="/about">About</a>
    </nav>
    <p class="cmd-hint">
      Or press <kbd>⌘</kbd><kbd>K</kbd> to search
    </p>
  </div>

  <style>
    .not-found {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      min-height: 70vh;
      padding: 2rem 1rem;
    }

    .error-code {
      display: flex;
      gap: 0.05em;
      font-size: clamp(7rem, 18vw, 12rem);
      font-weight: 700;
      line-height: 1;
      margin: 0;
      color: var(--color-muted);
      letter-spacing: -0.04em;
      user-select: none;
    }

    .digit {
      display: inline-block;
      opacity: 0;
      animation: digitReveal 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      animation-delay: calc(var(--i) * 0.08s + 0.1s);
    }

    @keyframes digitReveal {
      from {
        opacity: 0;
        transform: translateY(20px) scale(0.95);
        filter: blur(4px);
      }
      to {
        opacity: 0.12;
        transform: translateY(0) scale(1);
        filter: blur(0);
      }
    }

    h1 {
      font-size: clamp(1.5rem, 4vw, 2.25rem);
      font-weight: 600;
      margin: -0.5rem 0 0.75rem;
      letter-spacing: -0.02em;
      opacity: 0;
      animation: fadeUp 0.4s ease-out 0.35s forwards;
    }

    .message {
      color: var(--color-muted);
      font-size: 1.05rem;
      margin: 0 0 2rem;
      max-width: 36ch;
      line-height: 1.5;
      opacity: 0;
      animation: fadeUp 0.4s ease-out 0.45s forwards;
    }

    .suggestions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: center;
      opacity: 0;
      animation: fadeUp 0.4s ease-out 0.55s forwards;
    }

    .suggestions a {
      color: var(--color-text);
      text-decoration: none;
      font-weight: 500;
      padding: 0.5rem 1.25rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-full, 999px);
      font-size: 0.9rem;
      transition:
        background-color var(--duration-fast, 0.15s) ease,
        border-color var(--duration-fast, 0.15s) ease,
        color var(--duration-fast, 0.15s) ease,
        transform var(--duration-fast, 0.15s) ease;
    }

    .suggestions a::after {
      display: none;
    }

    @media (hover: hover) {
      .suggestions a:hover {
        background-color: var(--color-link);
        color: var(--color-bg);
        border-color: var(--color-link);
        transform: translateY(-1px);
      }
    }

    .suggestions a:focus-visible {
      outline: 2px solid var(--color-link);
      outline-offset: 2px;
    }

    .cmd-hint {
      margin-top: 2rem;
      font-size: 0.8rem;
      color: var(--color-muted);
      opacity: 0;
      animation: fadeUp 0.4s ease-out 0.65s forwards;
    }

    kbd {
      display: inline-block;
      padding: 0.15em 0.4em;
      font-size: 0.8em;
      font-family: inherit;
      line-height: 1;
      color: var(--color-muted);
      background: color-mix(in srgb, var(--color-text) 6%, transparent);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm, 4px);
      box-shadow: 0 1px 0 color-mix(in srgb, var(--color-text) 8%, transparent);
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .digit,
      h1,
      .message,
      .suggestions,
      .cmd-hint {
        animation: none;
        opacity: 1;
      }
      .digit {
        opacity: 0.12;
      }
    }

    @media (max-width: 480px) {
      .not-found {
        min-height: 60vh;
      }

      .suggestions {
        gap: 0.5rem;
      }

      .suggestions a {
        padding: 0.4rem 1rem;
        font-size: 0.85rem;
      }
    }
  </style>
</MainLayout>

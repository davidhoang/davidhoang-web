---
import MainLayout from '../layouts/MainLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { Image } from 'astro:assets';
import imgDavidSydney from '../assets/images/img-david-sydney.webp';
import imgDavidNow from '../assets/images/img-david-now.webp';
import imgDavidHawaii from '../assets/images/img-david-hawaii.webp';

// Page metadata
const pageDescription = "What I'm currently up to: working on AI at Atlassian, taking care of a new kitten, vibe coding Tapestry, writing Proof of Concept newsletter, and more.";
const ogImage = "/images/img-david-now.webp";
---

<MainLayout title="Now | David Hoang" description={pageDescription} ogImage={ogImage}>
  <PageHeader
    title="Now"
    image={imgDavidNow}
    alt="David Hoang portrait photo, current headshot"
  />
  <div class="now-content">
    <p>Last updated: Thursday, November 27, 2025. Learn more about <a href="https://nownownow.com/" target="_blank">Now pages</a></p>
    <div class="now-section">
      <div class="now-grid">
        <div class="now-grid-item">
          <Image src={imgDavidSydney} alt="David Hoang standing in Sydney, Australia with city skyline in the background" width={600} height={400} loading="lazy" />
        </div>
        <div class="now-grid-item">
          <Image src={imgDavidNow} alt="David Hoang portrait photo, current headshot" width={600} height={400} loading="lazy" />
        </div>
        <div class="now-grid-item">
          <Image src={imgDavidHawaii} alt="David Hoang in Hawaii, casual outdoor setting" width={600} height={400} loading="lazy" />
        </div>
      </div>
    </div>
    <div class="now-section">
      <h2>What I'm currently up to</h2>
      <ul role="list" aria-label="Current activities and projects">
          <li>Working on AI at Atlassian</li>
          <li><a href="https://blog.davidhoang.com/2025/06/10/the-cat-distribution-system-at-work/" target="_blank" rel="noopener noreferrer">Taking care of a new kitten</a></li>
          <li>Vibe coding <a href="https://tapestry.design" target="_blank" rel="noopener noreferrer">Tapestry</a></li>
          <li>Writing lazy reviews on <a href="https://letterboxd.com/davidhoang/" target="_blank" rel="noopener noreferrer">Letterboxd</a></li>
          <li>Aspiring to get the Juggernaught kill streak on Call of Duty</li>
          <li>Writing a newsletter called <a href="https://www.proofofconcept.pub/" target="_blank" rel="noopener noreferrer">Proof of Concept</a> focused on creativity and experimentation</li>
          <li>Getting back into cycling with my <a href="https://www.instagram.com/p/Cq0-_0Jv-0/" target="_blank" rel="noopener noreferrer">Salsa bike</a></li>
      </ul>
    </div>
  </div>
</MainLayout>

<style>

  .now-content {
    max-width: var(--container-narrow-width);
    margin: 0 auto;
    padding: var(--spacing-xl) 0;
  }

  .subtitle {
    color: var(--color-muted);
    font-size: 1.2rem;
    margin-bottom: var(--spacing-2xl);
  }

  .now-section {
    margin-bottom: var(--spacing-2xl);
  }

  .now-section h2 {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
  }

  .now-section ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
  }

  .now-section li {
    margin-bottom: var(--spacing-sm);
    margin-left: var(--spacing-xl);
    font-size: 1.1rem;
    list-style-type: disc;
  }

  .now-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
    margin: var(--spacing-xl) 0;
  }

  .now-grid-item img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
  }

  .now-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .now-page-info {
    margin-top: 0.5rem;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .now-content {
      padding: var(--spacing-md);
    }

    .subtitle {
      font-size: 1.1rem;
      margin-bottom: var(--spacing-xl);
    }

    .now-section {
      margin-bottom: var(--spacing-xl);
    }

    .now-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }
  }
</style> 
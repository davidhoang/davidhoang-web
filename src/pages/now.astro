---
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import imgDavidSydney from '../assets/images/img-david-sydney.webp';
import imgDavidNow from '../assets/images/img-david-now.webp';
import imgDavidHawaii from '../assets/images/img-david-hawaii.webp';

// Page metadata
const pageDescription = "What I'm currently up to: working on AI and Ecosystem at Atlassian, writing Proof of Concept, learning Agent Experience, angel investing, and traveling between California and Sydney.";
const ogImage = "/images/img-david-now.webp";
---

<MainLayout title="Now | David Hoang" description={pageDescription} ogImage={ogImage}>
  <PageHeader
    title="Now"
    image={imgDavidNow.src}
    alt="David Hoang portrait photo, current headshot"
  />
  <div class="now-content">
    <p class="now-meta">
      Last updated: Saturday, June 6, 2026. Learn more about
      <a href="https://nownownow.com/" target="_blank" rel="noopener noreferrer">Now pages</a>.
    </p>
    <div class="now-section">
      <div class="now-grid">
        <div class="now-grid-item">
          <Image src={imgDavidSydney} alt="David Hoang standing in Sydney, Australia with city skyline in the background" loading="lazy" decoding="async" />
        </div>
        <div class="now-grid-item">
          <Image src={imgDavidNow} alt="David Hoang portrait photo, current headshot" loading="lazy" decoding="async" />
        </div>
        <div class="now-grid-item">
          <Image src={imgDavidHawaii} alt="David Hoang in Hawaii, casual outdoor setting" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
    <div class="now-section">
      <h2>What I'm currently up to</h2>
      <ul role="list" aria-label="Current activities and projects">
          <li>Working at Atlassian on AI and Ecosystem</li>
          <li>Writing <a href="https://www.proofofconcept.pub/" target="_blank" rel="noopener noreferrer">Proof of Concept</a></li>
          <li>Learning Agent Experience</li>
          <li>Angel investing</li>
          <li>Living in California and traveling to Sydney</li>
      </ul>
    </div>
  </div>
</MainLayout>

<style>

  .now-content {
    max-width: var(--container-narrow-width);
    margin: 0 auto;
    padding: var(--spacing-xl) 0 var(--spacing-3xl);
  }

  .now-meta {
    margin: 0 0 var(--spacing-xl);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-muted);
  }

  .now-section {
    margin-bottom: var(--spacing-3xl);
  }

  .now-section h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.15;
    letter-spacing: var(--letter-spacing-heading-md);
    margin: 0 0 var(--spacing-lg);
    color: var(--color-text);
    text-wrap: balance;
  }

  .now-section ul {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .now-section li {
    position: relative;
    padding-left: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-muted);
  }

  .now-section li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72em;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-link) 55%, var(--color-muted));
  }

  .now-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    margin: var(--spacing-xl) 0 0;
  }

  .now-grid-item img {
    width: 100%;
    aspect-ratio: 4 / 5;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
  }

  @media (max-width: 768px) {
    .now-content {
      padding: var(--spacing-md) var(--spacing-md) var(--spacing-2xl);
    }

    .now-section {
      margin-bottom: var(--spacing-2xl);
    }

    .now-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .now-grid-item img {
      aspect-ratio: 16 / 11;
    }
  }
</style> 

<script>
  import { initObductionPhysics } from '../../scripts/obduction-physics';

  const wrap = document.querySelector('.diagram-wrap');
  if (wrap) {
    const INTRO_MS = 8800;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const coarse = window.matchMedia('(hover: none)').matches;

    const svg = wrap.querySelector('svg.cross-section');

    const physics =
      svg &&
      initObductionPhysics({
        wrap,
        svg,
        onStageChange: (stage) => {
          if (stage) {
            wrap.dataset.activeStage = String(stage);
          } else {
            wrap.removeAttribute('data-active-stage');
          }
        },
      });

    const settle = () => {
      wrap.classList.remove('diagram-epoch');
      wrap.classList.add('diagram-settled');
      physics?.enable();
    };

    if (reduced || coarse) {
      settle();
    } else {
      window.setTimeout(settle, INTRO_MS);
    }

    if (svg && physics) {
      const zones = [
        { el: svg.querySelector('.stage-one-hit'), stage: '1' as const },
        { el: svg.querySelector('.stage-two-hit'), stage: '2' as const },
        { el: svg.querySelector('.stage-three-hit'), stage: '3' as const },
      ].filter((z) => z.el);

      const resolveActiveStage = () => {
        const hovered = [...zones].reverse().find(({ el }) => el?.matches(':hover'));
        physics.setStage(hovered ? hovered.stage : null);
      };

      for (const { el, stage } of zones) {
        el.addEventListener('mouseenter', () => physics.setStage(stage));
        el.addEventListener('mouseleave', () => window.requestAnimationFrame(resolveActiveStage));
      }
    }
  }
</script>

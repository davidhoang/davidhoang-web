<script is:inline>
  (() => {
    const wrap = document.querySelector('.diagram-wrap');
    if (!wrap) return;

    const INTRO_MS = 13200;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const coarse = window.matchMedia('(hover: none)').matches;

    const settle = () => {
      wrap.classList.remove('diagram-epoch');
      wrap.classList.add('diagram-settled');
    };

    if (reduced || coarse) {
      settle();
    } else {
      window.setTimeout(settle, INTRO_MS);
    }

    const svg = wrap.querySelector('svg.cross-section');
    if (!svg) return;

    const zones = [
      { el: svg.querySelector('.stage-one-zone'), stage: '1' },
      { el: svg.querySelector('.stage-two-zone'), stage: '2' },
      { el: svg.querySelector('.stage-three-zone'), stage: '3' },
    ].filter((z) => z.el);

    const syncActiveStage = () => {
      let active = 0;
      for (const { el, stage } of zones) {
        if (el.matches(':hover') || el.contains(document.activeElement)) {
          active = Math.max(active, Number(stage));
        }
      }
      if (active === 0) {
        wrap.removeAttribute('data-active-stage');
      } else {
        wrap.dataset.activeStage = String(active);
      }
    };

    for (const { el } of zones) {
      el.addEventListener('mouseenter', syncActiveStage);
      el.addEventListener('mouseleave', syncActiveStage);
      el.addEventListener('focusin', syncActiveStage);
      el.addEventListener('focusout', syncActiveStage);
    }

    const legendPanel = wrap.querySelector('.legend-panel');
    const measureLayout = () => {
      if (!legendPanel || window.innerWidth <= 900) {
        wrap.style.removeProperty('--legend-panel-min-h');
        wrap.style.removeProperty('--commentary-slot-h');
        return;
      }

      const prevStage = wrap.dataset.activeStage;
      let maxPanel = 0;
      let maxCommentary = 0;

      for (const stage of ['1', '2', '3']) {
        wrap.dataset.activeStage = stage;
        maxPanel = Math.max(maxPanel, legendPanel.scrollHeight);

        const commentary = legendPanel.querySelector(
          `.legend-item[data-stage="${stage}"] .legend-commentary__inner`
        );
        if (commentary) {
          maxCommentary = Math.max(maxCommentary, commentary.scrollHeight);
        }
      }

      if (prevStage) {
        wrap.dataset.activeStage = prevStage;
      } else {
        wrap.removeAttribute('data-active-stage');
      }

      wrap.style.setProperty('--legend-panel-min-h', `${maxPanel}px`);
      wrap.style.setProperty('--commentary-slot-h', `${maxCommentary}px`);
    };

    const queueMeasure = () => window.requestAnimationFrame(measureLayout);

    queueMeasure();
    window.addEventListener('resize', queueMeasure);
    if (document.fonts?.ready) {
      document.fonts.ready.then(queueMeasure);
    }
  })();
</script>

---
import PrototypeLayout from '../../layouts/PrototypeLayout.astro';
import TectonicCrossSection from '../../components/prototypes/TectonicCrossSection';
import '../../styles/prototypes/design-leadership-obduction.css';

const pageTitle = 'The Plate Tectonics of Design Leadership — Tectonic Cross-Section';
const pageDescription =
  'A cross-section of design leadership geology: Stage I Initial Uplift, Stage II Sustained Thrust, and Stage III New Mountain Range.';
const fonts =
  'https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700&family=JetBrains+Mono:wght@400;500;600&display=swap';
---

<PrototypeLayout title={pageTitle} description={pageDescription} fonts={fonts}>
<div class="container">
    <div class="header">
      <div class="eyebrow">— Issue 302 · The Plate Tectonics of Design Leadership —</div>
      <h1>Tectonic Cross-Section</h1>
      <div class="subtitle">Three stages in one geology: compress, thrust, grow — hover each zone in order.</div>
    </div>

    <TectonicCrossSection client:visible />

    <div class="footnote">
      <div>Issue 302 · Proof of Concept · Hoang · 2026</div>
      <div><em>To survive disruption, you must become disruption.</em></div>
      <div>Stages I–III · Tectonic Cross-Section · v1</div>
    </div>
  </div>
</PrototypeLayout>

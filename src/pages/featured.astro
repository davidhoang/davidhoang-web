---
import MainLayout from '../layouts/MainLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import EditorialMediaCard from '../components/EditorialMediaCard.astro';
import SpeakingEntryTitle from '../components/SpeakingEntryTitle.tsx';
import FeaturedSpeakingPreviewPanel from '../components/FeaturedSpeakingPreviewPanel.tsx';
import { featuredSpeaking } from '../data/featuredSpeaking';
import { featuredMedia } from '../data/featuredMedia';
import { resolveFeaturedMedia } from '../utils/featuredMedia';

const pageDescription =
  'A collection of conference talks, podcasts, and interviews. Speaking engagements at Config, Hatch Conference, UX Cambridge, and more.';
const ogImage = '/images/highlights/img-highlights-hatch-conference.webp';

const mediaResolved = await resolveFeaturedMedia(featuredMedia);

---

<MainLayout title="Featured" description={pageDescription} ogImage={ogImage}>
  <PageHeader
    title="Featured"
    image="/images/header-images/img-highlights-featured.webp"
    alt="Featured speaking and media"
  />
  <div class="featured-editorial">
    <div class="featured-editorial__speaking">
      <h2 class="featured-editorial__section-title">Speaking</h2>
      <div class="speaking-chronicle">
        <div class="speaking-inquiry" role="region" aria-label="Speaking inquiries">
          <p class="speaking-inquiry__label">Open for speaking</p>
          <p class="speaking-inquiry__copy">
            For inquiries, email{' '}
            <a class="speaking-inquiry__link" href="mailto:david@davidhoang.com">david@davidhoang.com</a>.
          </p>
        </div>

        {
          featuredSpeaking.map((block) => (
            <section class="speaking-chronicle__year" aria-labelledby={`speaking-${block.year}`}>
              <h3 class="speaking-chronicle__year-label" id={`speaking-${block.year}`}>
                <span class="speaking-chronicle__year-num">{block.year}</span>
              </h3>
              <ul class="speaking-chronicle__list">
                {block.entries.map((entry) => (
                  <li class={`speaking-chronicle__entry${entry.href ? ' speaking-chronicle__entry--linked' : ''}`}>
                    {entry.meta ? (
                      <span class="speaking-chronicle__when">{entry.meta}</span>
                    ) : (
                      <span class="speaking-chronicle__when speaking-chronicle__when--empty" aria-hidden="true" />
                    )}
                    <span class="speaking-chronicle__title">
                      <SpeakingEntryTitle
                        client:visible
                        title={entry.title}
                        href={entry.href}
                        detailKey={entry.detailKey}
                      />
                    </span>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>

    <aside class="featured-editorial__media" aria-label="Media and publications">
      <h2 class="featured-editorial__section-title featured-editorial__section-title--media">Media &amp; publications</h2>
      <p class="featured-editorial__lede featured-editorial__lede--compact">
        Essays and appearances — titles and descriptions are pulled from each page when the build runs.
      </p>
      <div class="media-stack">
        {mediaResolved.map((item) => <EditorialMediaCard {...item} />)}
      </div>
    </aside>
    <FeaturedSpeakingPreviewPanel client:visible />
  </div>
</MainLayout>

<style>
  .featured-editorial {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(20rem, 1.12fr);
    gap: clamp(2rem, 5vw, 3.5rem);
    margin: calc(var(--spacing-md) + var(--spacing-xs)) 0 var(--spacing-2xl);
    align-items: start;
  }

  .featured-editorial__section-title {
    margin: 0 0 calc(var(--spacing-xs) + 0.1rem);
    font-size: var(--h2-size);
    line-height: var(--h2-line-height);
    letter-spacing: var(--h2-letter-spacing);
    overflow-wrap: break-word;
  }

  .featured-editorial__section-title--media {
    text-wrap: balance;
    max-width: 22ch;
  }

  .featured-editorial__speaking .featured-editorial__section-title {
    margin-bottom: 1.25rem;
  }

  .featured-editorial__lede {
    margin: 0 0 calc(var(--spacing-lg) + var(--spacing-sm));
    max-width: 42rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-muted);
    letter-spacing: var(--letter-spacing-body);
  }

  .featured-editorial__lede--compact {
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .speaking-chronicle {
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 4vw, 2.5rem);
  }

  .speaking-inquiry {
    margin: 0;
    padding: clamp(0.85rem, 2vw, 1rem) clamp(1rem, 2.4vw, 1.15rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-sidebar-bg) 42%, var(--color-bg));
  }

  .speaking-inquiry__label {
    margin: 0 0 calc(var(--spacing-xs) + 0.1rem);
    font-size: var(--text-eyebrow-size, 0.6875rem);
    font-weight: 600;
    letter-spacing: var(--text-eyebrow-tracking, 0.14em);
    text-transform: uppercase;
    color: var(--color-link);
  }

  .speaking-inquiry__copy {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.45;
    letter-spacing: var(--letter-spacing-body);
    color: var(--color-text);
  }

  .featured-editorial .speaking-inquiry__link {
    color: var(--color-link);
    text-decoration: none;
    font-weight: 600;
    transition: color var(--duration-normal) var(--ease-standard);
  }

  .featured-editorial .speaking-inquiry__link:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .speaking-chronicle__year {
    display: grid;
    grid-template-columns: minmax(3.25rem, 4.25rem) minmax(0, 1fr);
    gap: 0 clamp(1rem, 2.8vw, 1.5rem);
    align-items: start;
  }

  .speaking-chronicle__year-label {
    margin: 0;
    position: sticky;
    top: calc(var(--nav-height, 48px) + var(--nav-offset-top, 24px) + 1rem);
  }

  .speaking-chronicle__year-num {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.8vw, 1.85rem);
    font-weight: var(--heading-weight);
    line-height: 1;
    letter-spacing: var(--letter-spacing-display);
    font-variant-numeric: tabular-nums;
    color: color-mix(in srgb, var(--color-muted) 58%, var(--color-text));
    transform: translateY(0.08em);
  }

  .speaking-chronicle__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .speaking-chronicle__entry {
    display: grid;
    grid-template-columns: minmax(4.75rem, 6.25rem) minmax(0, 1fr);
    gap: 0.65rem clamp(0.85rem, 2vw, 1.25rem);
    padding: 0.7var(--spacing-xl) 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 90%, transparent);
    align-items: baseline;
  }

  .speaking-chronicle__entry--linked {
    position: relative;
    margin-inline: calc(-1 * clamp(0.45rem, 1.4vw, 0.65rem));
    padding-inline: clamp(0.45rem, 1.4vw, 0.65rem);
    border-radius: var(--radius-sm);
    transition:
      background-color var(--duration-normal) var(--ease-standard),
      transform var(--duration-slower) var(--ease-inertia);
  }

  .speaking-chronicle__entry--linked:hover {
    background: color-mix(in srgb, var(--color-sidebar-bg) 55%, var(--color-bg));
    transform: translateX(2px);
  }

  .speaking-chronicle__when {
    font-size: 0.8125rem;
    line-height: 1.35;
    letter-spacing: var(--letter-spacing-caption);
    font-variant-numeric: tabular-nums;
    color: var(--color-muted);
  }

  .speaking-chronicle__when--empty {
    visibility: hidden;
  }

  .speaking-chronicle__title {
    font-size: clamp(0.94rem, 1.6vw, 1rem);
    line-height: 1.45;
    letter-spacing: var(--letter-spacing-body);
    color: var(--color-text);
  }

  .featured-editorial .speaking-chronicle__title a.speaking-entry__link {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-link) 35%, transparent);
    transition:
      color var(--duration-normal) var(--ease-standard),
      border-color var(--duration-normal) var(--ease-standard);
  }

  .featured-editorial .speaking-chronicle__title a.speaking-entry__link:hover {
    color: var(--color-link-hover);
    border-bottom-color: color-mix(in srgb, var(--color-link-hover) 55%, transparent);
  }

  .featured-editorial .speaking-chronicle__title a.speaking-entry__link--preview::after {
    content: '↗';
    display: inline-block;
    margin-left: 0.28em;
    font-size: 0.82em;
    opacity: 0;
    transform: translate(-2px, 1px);
    transition:
      opacity var(--duration-normal) var(--ease-standard),
      transform var(--duration-slower) var(--ease-inertia);
  }

  .featured-editorial .speaking-chronicle__title a.speaking-entry__link--preview:hover::after {
    opacity: 0.72;
    transform: translate(0, 0);
  }

  .featured-editorial__media {
    overflow: visible;
  }

  @media (max-width: 768px) {
    .speaking-chronicle__entry {
      grid-template-columns: 1fr;
      gap: 0.var(--spacing-xl);
      padding-block: 0.85rem;
      align-items: start;
    }

    .speaking-chronicle__when {
      font-size: 0.75rem;
      line-height: 1.3;
    }

    .speaking-chronicle__when--empty {
      display: none;
    }

    .speaking-chronicle__title {
      font-size: 1rem;
      line-height: 1.5;
    }

    .speaking-chronicle__entry--linked {
      padding-block: 0.95rem;
    }

    .featured-editorial .speaking-chronicle__title a.speaking-entry__link {
      display: block;
      padding-block: 0.125rem;
    }

    .speaking-chronicle__entry--linked:hover {
      transform: none;
    }
  }

  @media (max-width: 520px) {
    .speaking-chronicle__year {
      grid-template-columns: 1fr;
      gap: calc(var(--spacing-sm) + calc(var(--spacing-xs) - 0.2rem));
    }

    .speaking-chronicle__year-label {
      position: static;
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
    }

    .speaking-chronicle__year-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--color-border);
    }

    .speaking-chronicle__year-num {
      font-size: 1.15rem;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .speaking-chronicle__entry--linked,
    .speaking-chronicle__entry--linked:hover,
    .featured-editorial .speaking-chronicle__title a.speaking-entry__link--preview::after,
    .featured-editorial .speaking-chronicle__title a.speaking-entry__link--preview:hover::after {
      transform: none;
      transition: none;
    }
  }

  .media-stack {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing-md) + var(--spacing-sm));
  }

  @media (max-width: 900px) {
    .featured-editorial {
      grid-template-columns: 1fr;
    }

    .featured-editorial__media {
      padding-top: 0.5rem;
      border-top: 1px solid var(--color-border);
    }
  }
</style>

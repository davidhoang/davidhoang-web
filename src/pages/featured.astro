---
import MainLayout from '../layouts/MainLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import EditorialMediaCard from '../components/EditorialMediaCard.astro';
import { featuredSpeaking } from '../data/featuredSpeaking';
import { featuredMedia } from '../data/featuredMedia';
import { resolveFeaturedMedia } from '../utils/linkPreview';

const pageDescription =
  'A collection of conference talks, podcasts, and interviews. Speaking engagements at Config, Hatch Conference, UX Cambridge, and more.';
const ogImage = '/images/highlights/img-highlights-hatch-conference.webp';

const mediaResolved = await resolveFeaturedMedia(featuredMedia);
---

<MainLayout title="Featured" description={pageDescription} ogImage={ogImage}>
  <PageHeader
    title="Featured"
    image="/images/header-images/img-highlights-featured.webp"
    alt="Featured speaking and media"
  />
  <div class="featured-editorial">
    <div class="featured-editorial__speaking">
      <h2 class="featured-editorial__section-title">Speaking</h2>
      <div class="speaking-timeline">
        {
          featuredSpeaking.map((block) => (
            <section class="speaking-year" aria-labelledby={`speaking-${block.year}`}>
              <h3 class="speaking-year__label" id={`speaking-${block.year}`}>
                {block.year}
              </h3>
              <ul class="speaking-year__list">
                {block.entries.map((entry) => (
                  <li class="speaking-entry">
                    {entry.meta ? (
                      <span class="speaking-entry__meta">{entry.meta}</span>
                    ) : (
                      <span class="speaking-entry__meta speaking-entry__meta--empty" />
                    )}
                    <span class="speaking-entry__title">
                      {entry.href ? (
                        <a
                          class="speaking-entry__link"
                          href={entry.href}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {entry.title}
                        </a>
                      ) : (
                        entry.title
                      )}
                    </span>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>

    <aside class="featured-editorial__media" aria-label="Media and publications">
      <h2 class="featured-editorial__section-title featured-editorial__section-title--media">Media &amp; publications</h2>
      <p class="featured-editorial__lede featured-editorial__lede--compact">
        Essays and appearances — titles and descriptions are pulled from each page when the build runs.
      </p>
      <div class="media-stack">
        {mediaResolved.map((item) => <EditorialMediaCard {...item} />)}
      </div>
    </aside>
  </div>
</MainLayout>

<style>
  .featured-editorial {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(20rem, 1.12fr);
    gap: clamp(2rem, 5vw, 3.5rem);
    margin: 1.25rem 0 3rem;
    align-items: start;
  }

  .featured-editorial__section-title {
    margin: 0 0 0.35rem;
    font-size: var(--h2-size);
    line-height: var(--h2-line-height);
    letter-spacing: var(--h2-letter-spacing);
    overflow-wrap: break-word;
  }

  .featured-editorial__section-title--media {
    text-wrap: balance;
    max-width: 22ch;
  }

  .featured-editorial__speaking .featured-editorial__section-title {
    margin-bottom: 1.25rem;
  }

  .featured-editorial__lede {
    margin: 0 0 1.75rem;
    max-width: 42rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-muted);
    letter-spacing: var(--letter-spacing-body);
  }

  .featured-editorial__lede--compact {
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .speaking-timeline {
    --tl-pad: clamp(1.2rem, 3.2vw, 2rem);
    --tl-spine-x: 1px;
    position: relative;
    margin-left: 0.2rem;
    padding-left: var(--tl-pad);
    border-left: none;
    overflow: visible;
  }

  /* Vertical spine */
  .speaking-timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.2rem;
    bottom: 0.35rem;
    width: 2px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-link) 42%, var(--color-border)) 0%,
      var(--color-border) 42%,
      color-mix(in srgb, var(--color-border) 88%, var(--color-bg)) 100%
    );
    opacity: 0.95;
  }

  .speaking-year {
    position: relative;
    margin-bottom: 2rem;
    z-index: 0;
  }

  .speaking-year:last-child {
    margin-bottom: 0;
  }

  .speaking-year__label {
    margin: 0 0 0.75rem;
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    line-height: 1.2;
    letter-spacing: var(--letter-spacing-heading-md);
    font-weight: var(--heading-weight);
    color: var(--color-text);
    position: relative;
    padding-left: 0.15rem;
  }

  /* Year marker — ring on the spine */
  .speaking-year__label::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--tl-pad) + var(--tl-spine-x));
    top: 0.42em;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-link);
    transform: translate(-50%, 0);
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--color-bg) 92%, transparent),
      0 1px 3px color-mix(in srgb, var(--color-text) 8%, transparent);
    z-index: 2;
  }

  .speaking-year__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .speaking-entry {
    position: relative;
    display: grid;
    grid-template-columns: minmax(4.5rem, 6.5rem) minmax(0, 1fr);
    gap: 0.75rem 1.25rem;
    padding: 0.5rem 0 0.6rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
    align-items: baseline;
  }

  /* Event dot on spine */
  .speaking-entry::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--tl-pad) + var(--tl-spine-x));
    top: 0.85em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-muted) 55%, var(--color-bg));
    border: 1px solid color-mix(in srgb, var(--color-border) 70%, var(--color-bg));
    transform: translate(-50%, -50%);
    z-index: 1;
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-bg) 85%, transparent);
  }

  .speaking-year__list li:last-child {
    border-bottom: none;
  }

  .speaking-entry__meta {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-muted);
  }

  .speaking-entry__meta--empty {
    visibility: hidden;
  }

  .speaking-entry__title {
    font-size: 0.95rem;
    line-height: 1.45;
    letter-spacing: var(--letter-spacing-body);
    color: var(--color-text);
  }

  .featured-editorial .speaking-entry__title a.speaking-entry__link {
    color: var(--color-link);
    text-decoration: none;
    transition: color var(--duration-normal) ease;
  }

  .featured-editorial .speaking-entry__title a.speaking-entry__link:hover {
    color: var(--color-link-hover);
  }

  .media-stack {
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }

  @media (max-width: 900px) {
    .featured-editorial {
      grid-template-columns: 1fr;
    }

    .featured-editorial__media {
      padding-top: 0.5rem;
      border-top: 1px solid var(--color-border);
    }
  }
</style>

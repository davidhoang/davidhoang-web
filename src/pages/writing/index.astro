---
import WritingLayout from '../../layouts/WritingLayout.astro';
import { getCollection } from 'astro:content';
import WritingGraph from '../../components/WritingGraph.astro';
import { buildGraph } from '../../utils/writingGraph';
import { formatLongDate } from '../../utils/formatDate';
import { getWritingPostThumbnail } from '../../utils/writingPostImage';
import '../../styles/pages/writing-editorial.css';

const allPosts = await getCollection('writing');
const posts = (import.meta.env.PROD
  ? allPosts.filter((post) => !post.data.draft)
  : allPosts
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const graph = buildGraph(posts.map((p) => ({ id: p.id, data: p.data, body: p.body })));

const postsWithMeta = posts.map((post) => ({
  post,
  thumbnail: getWritingPostThumbnail({
    title: post.data.title,
    description: post.data.description,
    coverImage: post.data.coverImage,
    ogImage: post.data.ogImage,
    body: post.body,
  }),
  primaryTag: post.data.tags?.[0],
}));

const allTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();

const featured = postsWithMeta[0];
const feedPosts = postsWithMeta.slice(1);

const pageDescription =
  'Essays and articles on design, engineering, AI, and entrepreneurship. Exploring the future of software design and building better products.';
const ogImage = '/images/highlights/img-highlights-proof-of-concept.webp';
---

<WritingLayout title="Writing | David Hoang" description={pageDescription} ogImage={ogImage}>
  <header class="writing-masthead">
    <h1 class="writing-masthead__title">Writing</h1>
    <p class="writing-masthead__deck">
      Essays on design, engineering, AI, and building products.
    </p>
    <div class="writing-masthead__actions">
      <a href="/rss.xml" class="writing-masthead__rss">RSS feed</a>
      <div class="writing-view-tabs" role="tablist" aria-label="Writing view">
        <button
          type="button"
          class="writing-view-tab is-active"
          role="tab"
          aria-selected="true"
          data-view-tab="editorial"
        >
          Editorial
        </button>
        <button
          type="button"
          class="writing-view-tab"
          role="tab"
          aria-selected="false"
          data-view-tab="list"
        >
          List
        </button>
        <button
          type="button"
          class="writing-view-tab"
          role="tab"
          aria-selected="false"
          data-view-tab="graph"
        >
          Graph
        </button>
      </div>
    </div>
  </header>

  {allTags.length > 0 && (
    <div class="writing-toolbar" data-filterable>
      <p class="writing-toolbar__label" id="writing-tag-label">Topics</p>
      <div class="writing-filter-chips" role="group" aria-labelledby="writing-tag-label">
        <button type="button" class="writing-chip is-active" data-tag="all">All</button>
        {allTags.map((tag) => (
          <button type="button" class="writing-chip" data-tag={tag}>
            {tag}
          </button>
        ))}
      </div>
    </div>
  )}

  <div data-view-panel="editorial">
    {featured && (
      <section class="writing-spotlight" aria-label="Latest essay">
        <a
          href={`/writing/${featured.post.id}`}
          class="writing-spotlight__link link-plain"
          transition:name={`post-${featured.post.id}`}
          data-tags={(featured.post.data.tags || []).join(',')}
          data-filter-item
        >
          <div class="writing-spotlight__media">
            <img
              src={featured.thumbnail}
              alt=""
              loading="eager"
              decoding="async"
              width="1200"
              height="750"
            />
          </div>
          <div class="writing-spotlight__body">
            <span class="text-eyebrow text-eyebrow--accent">Latest</span>
            {featured.primaryTag && <span class="writing-spotlight__tag">{featured.primaryTag}</span>}
            <h2 class="writing-spotlight__title" transition:name={`title-${featured.post.id}`}>
              {featured.post.data.title}
            </h2>
            {featured.post.data.description && (
              <p class="writing-spotlight__deck">{featured.post.data.description}</p>
            )}
            <p class="writing-spotlight__meta">
              <time datetime={featured.post.data.pubDate.toISOString()}>
                {formatLongDate(featured.post.data.pubDate)}
              </time>
            </p>
          </div>
        </a>
      </section>
    )}

    {feedPosts.length > 0 && (
      <section class="writing-grid" aria-label="All essays">
        {feedPosts.map(({ post, thumbnail, primaryTag }) => (
          <a
            href={`/writing/${post.id}`}
            class="writing-card link-plain"
            transition:name={`post-${post.id}`}
            data-tags={(post.data.tags || []).join(',')}
            data-filter-item
          >
            <div class="writing-card__media">
              <img
                src={thumbnail}
                alt=""
                loading="lazy"
                decoding="async"
                width="800"
                height="500"
              />
            </div>
            <div class="writing-card__body">
              <div class="writing-card__meta">
                {primaryTag && <span class="writing-card__tag">{primaryTag}</span>}
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatLongDate(post.data.pubDate)}
                </time>
              </div>
              <h3 class="writing-card__title" transition:name={`title-${post.id}`}>
                {post.data.title}
              </h3>
              {post.data.description && (
                <p class="writing-card__deck">{post.data.description}</p>
              )}
            </div>
          </a>
        ))}
      </section>
    )}
  </div>

  <div data-view-panel="list" hidden>
    <section class="writing-feed" aria-label="Essay list">
      <ul class="writing-feed__list">
        {postsWithMeta.map(({ post, thumbnail }) => (
          <li>
            <a
              href={`/writing/${post.id}`}
              class="writing-feed__item link-plain"
              transition:name={`post-${post.id}`}
              data-tags={(post.data.tags || []).join(',')}
              data-filter-item
            >
              <div class="writing-feed__thumb">
                <img
                  src={thumbnail}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width="600"
                  height="600"
                />
              </div>
              <div class="writing-feed__content">
                <h3 class="writing-feed__title" transition:name={`title-${post.id}`}>
                  {post.data.title}
                </h3>
                {post.data.description && (
                  <p class="writing-feed__deck">{post.data.description}</p>
                )}
                <p class="writing-feed__meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatLongDate(post.data.pubDate)}
                  </time>
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <div data-view-panel="graph" hidden>
    <WritingGraph graph={graph} />
  </div>

  <p class="writing-feed__empty" id="writing-no-results" hidden>
    No essays in this topic.
  </p>
</WritingLayout>

<script>
  function initWritingFilters() {
    const noResults = document.getElementById('writing-no-results');
    const tagChips = Array.from(document.querySelectorAll<HTMLButtonElement>('.writing-chip'));
    const filterItems = Array.from(document.querySelectorAll<HTMLElement>('[data-filter-item]'));

    if (!filterItems.length) return;

    let activeTag = 'all';

    function applyFilters() {
      let visibleCount = 0;

      filterItems.forEach((item) => {
        const tags = (item.getAttribute('data-tags') || '').split(',').filter(Boolean);
        const visible = activeTag === 'all' || tags.includes(activeTag);

        item.hidden = !visible;
        const listRow = item.closest('li');
        if (listRow) listRow.hidden = !visible;

        if (visible) visibleCount++;
      });

      if (noResults) {
        const activePanel = document.querySelector<HTMLElement>('[data-view-panel]:not([hidden])');
        const isFilterableView =
          activePanel?.dataset.viewPanel === 'editorial' ||
          activePanel?.dataset.viewPanel === 'list';
        noResults.hidden = !isFilterableView || visibleCount > 0 || activeTag === 'all';
      }
    }

    tagChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        activeTag = chip.dataset.tag || 'all';
        tagChips.forEach((c) => c.classList.toggle('is-active', c === chip));
        applyFilters();
      });
    });
  }

  function initWritingViewTabs() {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-view-tab]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-view-panel]'));
    const filterable = Array.from(document.querySelectorAll<HTMLElement>('[data-filterable]'));
    const noResults = document.getElementById('writing-no-results');
    if (!tabs.length || !panels.length) return;

    function setView(view: string, push: boolean) {
      tabs.forEach((t) => {
        const active = t.dataset.viewTab === view;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        const active = p.dataset.viewPanel === view;
        p.hidden = !active;
        if (active && view === 'graph') {
          p.querySelector('[data-writing-graph]')?.dispatchEvent(new CustomEvent('graph:show'));
        }
      });

      const showFilters = view === 'editorial' || view === 'list';
      filterable.forEach((el) => {
        el.hidden = !showFilters;
      });
      if (!showFilters && noResults) noResults.hidden = true;

      if (push) {
        const url = new URL(window.location.href);
        if (view === 'editorial') url.searchParams.delete('view');
        else url.searchParams.set('view', view);
        window.history.replaceState({}, '', url.toString());
      }
    }

    tabs.forEach((t) => {
      t.addEventListener('click', () => setView(t.dataset.viewTab || 'editorial', true));
    });

    const viewParam = new URLSearchParams(window.location.search).get('view');
    const initial =
      viewParam === 'list' || viewParam === 'graph' || viewParam === 'garden'
        ? viewParam === 'garden'
          ? 'graph'
          : viewParam
        : 'editorial';
    setView(initial, false);
  }

  initWritingFilters();
  initWritingViewTabs();
  document.addEventListener('astro:page-load', () => {
    initWritingFilters();
    initWritingViewTabs();
  });
</script>

---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import SidebarWriting from '../../components/SidebarWriting.astro';
import PageHeader from '../../components/PageHeader.astro';
import SearchInput from '../../components/SearchInput.astro';
import WritingGraph from '../../components/WritingGraph.astro';
import { buildGraph } from '../../utils/writingGraph';
import { formatLongDate } from '../../utils/formatDate';
import { calculateReadingTime } from '../../utils/readingTime';
import { getWritingPostThumbnail } from '../../utils/writingPostImage';
import '../../styles/pages/writing-index.css';

const allPosts = await getCollection('writing');
const posts = (import.meta.env.PROD
  ? allPosts.filter((post) => !post.data.draft)
  : allPosts
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const graph = buildGraph(posts.map((p) => ({ id: p.id, data: p.data })));

const postsWithMeta = posts.map((post) => ({
  post,
  readingTime: calculateReadingTime(post.body),
  thumbnail: getWritingPostThumbnail({
    title: post.data.title,
    description: post.data.description,
    coverImage: post.data.coverImage,
    ogImage: post.data.ogImage,
    body: post.body,
  }),
}));

const featured = postsWithMeta[0];
const feedPosts = postsWithMeta.slice(1);

const pageDescription =
  'Essays and articles on design, engineering, AI, and entrepreneurship. Exploring the future of software design and building better products.';
const ogImage = '/images/highlights/img-highlights-proof-of-concept.webp';
---

<MainLayout title="Writing | David Hoang" description={pageDescription} ogImage={ogImage}>
  <div class="writing-index">
    <PageHeader
      title="Writing"
      variant="text-only"
      subtitle="Essays on design, engineering, AI, and building products."
    />

    <div class="content-grid">
      <div class="posts-column">
        <div class="view-tabs" role="tablist" aria-label="Writing view">
          <button
            type="button"
            class="view-tab is-active"
            role="tab"
            aria-selected="true"
            data-view-tab="list"
          >List</button>
          <button
            type="button"
            class="view-tab"
            role="tab"
            aria-selected="false"
            data-view-tab="garden"
          >Garden</button>
        </div>

        <div data-view-panel="garden" hidden>
          <WritingGraph graph={graph} />
        </div>

        <div data-view-panel="list">
          {featured && (
            <article class="writing-featured">
              <a
                href={`/writing/${featured.post.id}`}
                class="writing-featured__link link-plain"
                transition:name={`post-${featured.post.id}`}
              >
                <div class="writing-featured__media">
                  <img
                    src={featured.thumbnail}
                    alt=""
                    loading="eager"
                    decoding="async"
                    width="1200"
                    height="630"
                  />
                </div>
                <div class="writing-featured__body">
                  <span class="text-eyebrow text-eyebrow--accent">Latest</span>
                  <h2
                    class="writing-featured__title"
                    transition:name={`title-${featured.post.id}`}
                  >
                    {featured.post.data.title}
                  </h2>
                  {featured.post.data.description && (
                    <p class="writing-featured__deck">{featured.post.data.description}</p>
                  )}
                  <p class="writing-feed__meta">
                    <time datetime={featured.post.data.pubDate.toISOString()}>
                      {formatLongDate(featured.post.data.pubDate)}
                    </time>
                    <span aria-hidden="true"> · </span>
                    <span>{featured.readingTime} min read</span>
                  </p>
                </div>
              </a>
            </article>
          )}

          {feedPosts.length > 0 && (
            <section class="writing-feed" aria-label="All essays">
              <SearchInput id="writing-search" placeholder="Search essays…" />
              <ul class="writing-feed__list" id="writing-list">
                {feedPosts.map(({ post, readingTime, thumbnail }) => (
                  <li
                    data-title={post.data.title.toLowerCase()}
                    data-description={(post.data.description || '').toLowerCase()}
                  >
                    <a
                      href={`/writing/${post.id}`}
                      class="writing-feed__item link-plain"
                      transition:name={`post-${post.id}`}
                    >
                      <div class="writing-feed__thumb">
                        <img
                          src={thumbnail}
                          alt=""
                          loading="lazy"
                          decoding="async"
                          width="1200"
                          height="630"
                        />
                      </div>
                      <div class="writing-feed__content">
                        <h3
                          class="writing-feed__title"
                          transition:name={`title-${post.id}`}
                        >
                          {post.data.title}
                        </h3>
                        {post.data.description && (
                          <p class="writing-feed__deck">{post.data.description}</p>
                        )}
                        <p class="writing-feed__meta">
                          <time datetime={post.data.pubDate.toISOString()}>
                            {formatLongDate(post.data.pubDate)}
                          </time>
                          <span aria-hidden="true"> · </span>
                          <span>{readingTime} min read</span>
                        </p>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
              <p class="writing-feed__no-results" id="writing-no-results">
                No essays match your search.
              </p>
            </section>
          )}
        </div>
      </div>
      <SidebarWriting />
    </div>
  </div>
</MainLayout>

<style>
  .view-tabs {
    display: inline-flex;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-lg);
    padding: var(--spacing-xs);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-sidebar-bg, transparent);
  }

  .view-tab {
    appearance: none;
    border: none;
    background: transparent;
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-muted, currentColor);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition:
      background-color var(--duration-normal) var(--ease-standard),
      color var(--duration-normal) var(--ease-standard);
  }

  .view-tab:hover {
    color: var(--color-text);
  }

  .view-tab.is-active {
    background: var(--color-link);
    color: var(--color-bg);
  }

  .view-tab:focus-visible {
    outline: var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  @media (prefers-reduced-motion: reduce) {
    .view-tab {
      transition: none;
    }
  }
</style>

<script>
  function initWritingSearch() {
    const input = document.getElementById('writing-search') as HTMLInputElement;
    const list = document.getElementById('writing-list');
    const noResults = document.getElementById('writing-no-results');
    const clearBtn = input?.parentElement?.querySelector('.search-clear') as HTMLElement;

    if (!input || !list) return;

    const items = list.querySelectorAll('li');

    function filterPosts() {
      const query = input.value.toLowerCase().trim();
      let visibleCount = 0;

      if (clearBtn) {
        clearBtn.style.display = query ? 'flex' : 'none';
      }

      items.forEach((item) => {
        const title = item.getAttribute('data-title') || '';
        const description = item.getAttribute('data-description') || '';
        const matches = !query || title.includes(query) || description.includes(query);
        (item as HTMLElement).style.display = matches ? '' : 'none';
        if (matches) visibleCount++;
      });

      if (noResults) {
        (noResults as HTMLElement).style.display =
          visibleCount === 0 && query ? 'block' : 'none';
      }
    }

    input.addEventListener('input', filterPosts);

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        input.value = '';
        filterPosts();
        input.focus();
      });
    }
  }

  initWritingSearch();
  document.addEventListener('astro:page-load', initWritingSearch);

  function initWritingViewTabs() {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-view-tab]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-view-panel]'));
    if (!tabs.length || !panels.length) return;

    function setView(view: string, push: boolean) {
      tabs.forEach((t) => {
        const active = t.dataset.viewTab === view;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        const active = p.dataset.viewPanel === view;
        p.hidden = !active;
        if (active && view === 'garden') {
          p.querySelector('[data-writing-graph]')?.dispatchEvent(new CustomEvent('graph:show'));
        }
      });
      if (push) {
        const url = new URL(window.location.href);
        if (view === 'garden') url.searchParams.set('view', 'garden');
        else url.searchParams.delete('view');
        window.history.replaceState({}, '', url.toString());
      }
    }

    tabs.forEach((t) => {
      t.addEventListener('click', () => setView(t.dataset.viewTab || 'list', true));
    });

    const initial =
      new URLSearchParams(window.location.search).get('view') === 'garden' ? 'garden' : 'list';
    setView(initial, false);
  }

  initWritingViewTabs();
  document.addEventListener('astro:page-load', initWritingViewTabs);
</script>

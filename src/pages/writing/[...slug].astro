---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { calculateReadingTime } from '../../utils/readingTime';
import { filterPublished, findRelatedContent } from '../../utils/relatedContent';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  const filteredPosts = import.meta.env.PROD
    ? posts.filter((post) => !post.data.draft)
    : posts;
  return filteredPosts.map((post) => {
    return {
      params: { slug: post.id },
      props: { post }
    };
  });
}

const { post } = Astro.props;
if (!post) {
  throw new Error('Post is undefined');
}

const includeDrafts = !import.meta.env.PROD;
const allPosts = filterPublished(await getCollection('writing'), includeDrafts);
const allNotes = filterPublished(await getCollection('notes'), includeDrafts);

const relatedContent = findRelatedContent({
  kind: 'writing',
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  relatedWriting: post.data.relatedWriting,
  relatedNotes: post.data.relatedNotes,
  writingEntries: allPosts.filter((entry) => entry.id !== post.id),
  noteEntries: allNotes,
  limit: 4,
});

function extractFirstImageUrl(markdown: string | undefined): string | undefined {
  if (!markdown) return undefined;

  const mdImageMatch = markdown.match(/!\[[^\]]*]\(([^)]+)\)/m);
  if (mdImageMatch?.[1]) {
    const inner = mdImageMatch[1].trim();
    let url = inner.split(/\s+/)[0]?.trim();
    if (url?.startsWith('<') && url.endsWith('>')) url = url.slice(1, -1).trim();
    if (!url) return undefined;
    if (/^https?:\/\//i.test(url)) return url;
    if (url.startsWith('/')) return url;
    if (url.startsWith('./')) return `/${url.slice(2)}`;
    return `/${url}`;
  }

  const htmlImageMatch = markdown.match(/<img\b[^>]*\bsrc\s*=\s*["']([^"']+)["'][^>]*>/i);
  if (htmlImageMatch?.[1]) {
    const url = htmlImageMatch[1].trim();
    if (!url) return undefined;
    if (/^https?:\/\//i.test(url)) return url;
    if (url.startsWith('/')) return url;
    if (url.startsWith('./')) return `/${url.slice(2)}`;
    return `/${url}`;
  }

  return undefined;
}

const inferredOgImage = post.data.coverImage || extractFirstImageUrl(post.body) || post.data.ogImage;
const postData = {
  ...post.data,
  ogImage: inferredOgImage,
};

const readingTime = calculateReadingTime(post.body);
const { Content, headings } = await render(post);
---

<BlogPost
  data={postData}
  relatedContent={relatedContent}
  headings={headings}
  readingTime={readingTime}
>
  <Content />
</BlogPost>

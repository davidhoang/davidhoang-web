---
import MainLayout from '../layouts/MainLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import DesignStackGrid from '../components/DesignStackGrid.astro';

const pageDescription = "A curated collection of design tools, references, and resources I use and recommend.";
const ogImage = "/images/header-images/img-header-writing.webp";

/** Stack logos: cursor, replit, obsidian from Simple Icons (CC0); paper + ghostly are placeholders in /public/images/logos/stack/. */
const designStack = [
  {
    name: "Paper",
    url: "https://paper.design",
    description: "Connected canvas for design, agents, and code—HTML/CSS-native handoff without losing intent.",
    logo: "/images/logos/stack/paper.svg",
  },
  {
    name: "Cursor",
    url: "https://cursor.com",
    description: "The AI-native editor I use for day-to-day shipping: context-aware refactors and fast iteration.",
    logo: "/images/logos/stack/cursor.svg",
  },
  {
    name: "Replit",
    url: "https://replit.com",
    description: "Spin up ideas in the cloud when I need a full environment without local ceremony.",
    logo: "/images/logos/stack/replit.svg",
  },
  {
    name: "Ghostly",
    url: "https://getghostly.com",
    description: "OpenTelemetry-first observability—maps, context, and signal when systems get real.",
    logo: "/images/logos/stack/ghostly.svg",
  },
  {
    name: "Obsidian",
    url: "https://obsidian.md",
    description: "Local markdown graph for notes, writing, and long-running thinking—my second brain.",
    logo: "/images/logos/stack/obsidian.svg",
  },
];

const resources = [
  {
    category: "Books I Come Back To",
    items: [
      { name: "The Design of Everyday Things", url: "https://www.amazon.com/Design-Everyday-Things-Revised-Expanded/dp/0465050654", description: "Don Norman's classic on human-centered design thinking." },
      { name: "Thinking in Systems", url: "https://www.amazon.com/Thinking-Systems-Donella-H-Meadows/dp/1603580557", description: "Donella Meadows on understanding complex systems — applicable well beyond design." },
      { name: "Creative Selection", url: "https://www.amazon.com/Creative-Selection-Inside-Apples-Process/dp/1250194466", description: "Ken Kocienda's inside look at Apple's design process and demo culture." },
      { name: "Grid Systems in Graphic Design", url: "https://www.amazon.com/Grid-Systems-Graphic-Design-Communication/dp/3721201450", description: "Josef Müller-Brockmann's foundational work on typographic grids." },
    ]
  },
  {
    category: "Typography",
    items: [
      { name: "Dinamo Typefaces", url: "https://abcdinamo.com", description: "Independent foundry behind ABC Diatype, the typeface used on this site." },
      { name: "Google Fonts", url: "https://fonts.google.com", description: "Free, open-source fonts. Great for prototyping and web projects." },
      { name: "Future Fonts", url: "https://www.futurefonts.xyz", description: "Work-in-progress typefaces from independent designers. Support them early." },
      { name: "Typewolf", url: "https://www.typewolf.com", description: "Typography inspiration and font recommendations from real sites." },
      { name: "Fonts In Use", url: "https://fontsinuse.com", description: "A searchable archive of typography in the wild." },
    ]
  },
];
---

<MainLayout title="Design Resources | David Hoang" description={pageDescription} ogImage={ogImage}>
  <PageHeader
    title="Design Resources"
    image={ogImage}
    alt="Design tools, references, and resources"
    priority={true}
  />
  <div class="design-resources-layout">
    <section class="design-stack-section" aria-labelledby="design-stack-heading">
      <h2 id="design-stack-heading" class="section-heading">My design stack</h2>
      <p class="design-stack-lede">
        Design, build, run, observe, and think — the five products I keep in rotation right now.
      </p>
      <DesignStackGrid items={designStack} />
    </section>

    <div class="design-resources-sources">
      <section aria-labelledby="more-sources-heading">
        <h2 id="more-sources-heading" class="section-heading">More Sources</h2>
        <p class="resources-intro">Books and typography — go-to references I use and recommend.</p>

        {resources.map((section) => (
          <section class="resource-section">
            <h3>{section.category}</h3>
            {section.items.map((item) => (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="resource-item">
                <span class="resource-name">{item.name}</span>
                <span class="resource-description">{item.description}</span>
              </a>
            ))}
          </section>
        ))}
      </section>
    </div>
  </div>
</MainLayout>

<style>
  .design-resources-layout {
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: calc(100dvh - clamp(9rem, 22vh, 14rem));
  }

  .design-resources-sources {
    max-width: var(--container-narrow-width);
    width: 100%;
    margin-inline: auto;
    margin-top: auto;
    padding-block: var(--spacing-2xl);
    padding-inline: 0;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 55%, transparent);
  }

  .design-stack-section {
    width: 100%;
    max-width: min(100%, 960px);
    margin-inline: auto;
    padding: var(--spacing-xl) var(--container-padding, 1rem);
    box-sizing: border-box;
  }

  .section-heading {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    font-family: var(--font-heading, var(--font-primary));
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }

  .design-stack-lede {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-muted);
    margin: 0 0 1.5rem;
    max-width: 42rem;
  }

  .resources-intro {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: var(--spacing-2xl);
    max-width: 640px;
  }

  .resource-section {
    margin-bottom: var(--spacing-2xl);
  }

  .resource-section h3 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin: 0 0 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .resource-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
    transition: background-color 0.15s ease;
  }

  .resource-item::after {
    display: none;
  }

  .resource-item:last-child {
    border-bottom: none;
  }

  @media (hover: hover) {
    .resource-item:hover {
      background-color: color-mix(in srgb, var(--color-text) 3%, transparent);
      margin-inline: -0.75rem;
      padding-inline: 0.75rem;
      border-radius: var(--radius-sm);
    }

    .resource-item:hover .resource-name {
      color: var(--color-link);
    }
  }

  .resource-name {
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.15s ease;
  }

  .resource-description {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .design-resources-sources {
      padding: var(--spacing-md);
    }

    .resource-item {
      flex-direction: column;
      gap: 0.25rem;
      padding: 0.875rem 0;
    }

    .resource-name {
      font-size: 1.05rem;
    }

    .resource-description {
      font-size: 0.875rem;
    }
  }

  @media (max-width: 480px) {
    .design-resources-sources {
      padding: var(--spacing-sm);
    }
  }
</style>

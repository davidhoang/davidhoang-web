---
import MainLayout from '../layouts/MainLayout.astro';
import SubstackSignup from '../components/SubstackSignup.astro';
import PageHeader from '../components/PageHeader.astro';

const pageDescription =
  'Subscribe to Proof of Concept, a digital newsletter publication that explores experimentation and maximizing your creative output. Free issue every Sunday.';
const ogImage = '/images/highlights/img-highlights-proof-of-concept.webp';
---

<MainLayout title="Subscribe" description={pageDescription} ogImage={ogImage}>
  <PageHeader
    title="Subscribe"
    image="/images/header-images/img-header-subscribe.webp"
    alt="Subscribe to Proof of Concept"
  />

  <div class="container container-narrow subscribe-page">
    <div class="subscribe-page__stack">
      <header class="subscribe-page__intro">
        <p class="subscribe-page__eyebrow">Proof of Concept</p>
        <h2 class="subscribe-page__title">A newsletter about experimentation and creative output</h2>
        <p class="subscribe-page__lead">
          One free issue every Sunday — design, technology, and entrepreneurship. Thanks for reading.
        </p>
      </header>

      <section class="subscribe-page__panel" aria-labelledby="subscribe-form-title">
        <h3 class="subscribe-page__panel-title" id="subscribe-form-title">Join the list</h3>
        <p class="subscribe-page__panel-hint">Enter your email below. You can unsubscribe anytime.</p>
        <SubstackSignup showTitle={false} description="" compact />
      </section>
    </div>
  </div>
</MainLayout>

<style>
  .subscribe-page {
    padding-bottom: clamp(3rem, 8vw, 5rem);
  }

  .subscribe-page__stack {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 5vw, 3rem);
  }

  .subscribe-page__intro {
    padding-top: 0.25rem;
  }

  .subscribe-page__eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .subscribe-page__title {
    margin: 0 0 1rem;
    font-size: clamp(1.35rem, 2.8vw, 1.75rem);
    font-weight: var(--heading-weight, 600);
    line-height: 1.25;
    letter-spacing: var(--heading-letter-spacing, -0.02em);
    color: var(--color-text);
    max-width: 28ch;
  }

  .subscribe-page__lead {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-muted);
    max-width: 52ch;
  }

  .subscribe-page__panel {
    background: var(--color-card-bg, var(--color-bg));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg, 12px);
    padding: clamp(1.5rem, 4vw, 2.25rem);
    box-shadow: var(--card-shadow, 0 1px 0 color-mix(in srgb, var(--color-text) 6%, transparent));
  }

  .subscribe-page__panel-title {
    margin: 0 0 0.35rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .subscribe-page__panel-hint {
    margin: 0 0 1.5rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 42ch;
  }

  /* Form block: no top rule inside the card; compact variant already scales type */
  .subscribe-page__panel :global(.substack-signup) {
    border-top: none;
    padding: 0;
  }

  @media (max-width: 480px) {
    .subscribe-page__title {
      max-width: none;
    }
  }
</style>

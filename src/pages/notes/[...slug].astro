---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection, render } from 'astro:content';
import MarkdownIt from 'markdown-it';
import sanitizeHtml from 'sanitize-html';
import {
  resolveNoteStage,
  defaultNoteMetaDescription,
} from '../../content/noteStages';
import { noteStageInfo } from '../../utils/noteStageInfo';
import { parseYoutubeVideoId } from '../../utils/youtube';
import { filterPublished, findRelatedContent } from '../../utils/relatedContent';
import RelatedContentSection from '../../components/RelatedContentSection.astro';

const overviewMd = new MarkdownIt({ html: false, linkify: true, breaks: true });

function renderNoteOverview(source: string): string {
  return sanitizeHtml(overviewMd.render(source.trim()), {
    allowedTags: sanitizeHtml.defaults.allowedTags.concat(['img']),
  });
}

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const stageKey = resolveNoteStage(note.data.stage);
const stage = noteStageInfo[stageKey];
const tags = note.data.tags || [];
const inspirationLinks = note.data.links || [];

const pageDescription =
  note.data.description || defaultNoteMetaDescription(stageKey, note.data.title);

const includeDrafts = !import.meta.env.PROD;
const allPosts = filterPublished(await getCollection('writing'), includeDrafts);
const allNotes = filterPublished(await getCollection('notes'), includeDrafts);

const relatedContent = findRelatedContent({
  kind: 'notes',
  id: note.id,
  title: note.data.title,
  description: pageDescription,
  tags: note.data.tags,
  relatedWriting: note.data.relatedWriting,
  relatedNotes: note.data.relatedNotes,
  writingEntries: allPosts,
  noteEntries: allNotes.filter((entry) => entry.id !== note.id),
  limit: 4,
});

function linkAttrs(url: string) {
  return /^https?:\/\//i.test(url)
    ? { target: '_blank' as const, rel: 'noopener noreferrer' }
    : {};
}

const overviewSource = (note.data.overview ?? note.data.description ?? '').trim();
const overviewHtml = overviewSource ? renderNoteOverview(overviewSource) : '';
const overviewYoutubeId = parseYoutubeVideoId(note.data.overviewYoutube);
const coverImage = note.data.coverImage;
const ogImage =
  note.data.ogImage ||
  coverImage ||
  `/api/og?title=${encodeURIComponent(note.data.title)}&description=${encodeURIComponent(pageDescription)}&type=notes`;

// Structured data for notes
const siteUrl = 'https://www.davidhoang.com';
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const noteOgImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage.startsWith('/') ? ogImage : `/${ogImage}`}`;
const noteIsoDate = note.data.pubDate.toISOString();
const noteIsoModified = note.data.updatedDate ? note.data.updatedDate.toISOString() : noteIsoDate;

const noteJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": note.data.title,
  "description": pageDescription,
  "datePublished": noteIsoDate,
  "dateModified": noteIsoModified,
  "author": {
    "@type": "Person",
    "name": "David Hoang",
    "url": "https://www.davidhoang.com"
  },
  "image": noteOgImageUrl,
  "url": canonicalUrl,
  "publisher": {
    "@type": "Person",
    "name": "David Hoang"
  }
};
---

<MainLayout title={note.data.title} description={pageDescription} ogImage={ogImage}>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(noteJsonLd)} />
  {coverImage && (
    <div class="note-hero">
      <img
        src={coverImage}
        alt={note.data.title}
        loading="eager"
        decoding="async"
        width="1200"
        height="630"
      />
    </div>
  )}
  <article class:list={['note-article', { 'note-article--with-hero': !!coverImage }]}>
    <aside class="note-stage-callout" aria-label={`This note is in the ${stage.label} stage`}>
      <span class="note-stage-callout__icon" aria-hidden="true">{stage.icon}</span>
      <p>
        {stage.description} Like the rest of this garden, it may change as I learn.
      </p>
    </aside>

    <header class="note-header">
      <h1>{note.data.title}</h1>
      {tags.length > 0 && (
        <div class="note-meta-row">
          <span class="note-tags-inline">
            {tags.map((tag, i) => (
              <span class="tag">{tag}{i < tags.length - 1 ? ', ' : ''}</span>
            ))}
          </span>
        </div>
      )}
    </header>

    <section class="note-section note-section--overview" aria-labelledby="overview-heading">
      <h2 id="overview-heading" class="note-section__heading">Overview</h2>
      <div class="note-overview">
        {overviewHtml ? (
          <div class="note-content note-section__prose" set:html={overviewHtml} />
        ) : !overviewYoutubeId ? (
          <p class="note-section__empty">No overview yet.</p>
        ) : null}
        {overviewYoutubeId && (
          <>
            <div class="note-youtube">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${overviewYoutubeId}`}
                title={`Video — ${note.data.title}`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              />
            </div>
            <a
              class="note-youtube-fallback"
              href={`https://www.youtube.com/watch?v=${overviewYoutubeId}`}
              rel="noopener noreferrer"
              target="_blank"
            >
              Watch video on YouTube →
            </a>
          </>
        )}
      </div>
    </section>

    <section class="note-section note-section--notes" aria-labelledby="notes-heading">
      <h2 id="notes-heading" class="note-section__heading">Notes</h2>
      <div class="note-content">
        <Content />
      </div>
    </section>

    <RelatedContentSection items={relatedContent} heading="Related" />

    <section class="note-section" aria-labelledby="links-heading">
      <h2 id="links-heading" class="note-section__heading">Links</h2>
      {inspirationLinks.length > 0 ? (
        <ul class="note-links__list">
          {inspirationLinks.map((item) => (
            <li>
              <a href={item.url} {...linkAttrs(item.url)}>
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="note-section__empty">No links listed yet.</p>
      )}
    </section>
  </article>
</MainLayout>

<style>
  /* Flush + full-bleed: layout.css (.note-hero). Only page-specific sizing here. */
  .note-hero {
    max-height: min(52vh, 420px);
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .note-hero img {
    width: 100%;
    height: min(52vh, 420px);
    object-fit: cover;
    display: block;
  }

  .note-article {
    max-width: 720px;
    margin: 0 auto;
    padding-top: 6rem;
  }

  .note-article--with-hero {
    padding-top: 2rem;
  }

  @media (max-width: 640px) {
    .note-hero {
      max-height: 40vh;
    }

    .note-hero img {
      height: 40vh;
    }

    .note-article--with-hero {
      padding-top: 1.5rem;
    }
  }

  .note-stage-callout {
    display: flex;
    gap: calc(var(--spacing-sm) + var(--spacing-xs));
    padding: var(--spacing-md) calc(var(--spacing-md) + var(--spacing-xs));
    background: var(--color-sidebar-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    margin-bottom: 1.75rem;
  }

  .note-stage-callout__icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    line-height: 1.4;
    color: var(--color-muted);
  }

  .note-stage-callout p {
    font-size: 0.875rem;
    color: var(--color-text);
    margin: 0;
    line-height: 1.55;
  }

  .note-header {
    margin-bottom: 2rem;
  }

  .note-header h1 {
    margin: 0 0 calc(var(--spacing-sm) + var(--spacing-xs)) 0;
  }

  .note-meta-row {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .note-tags-inline {
    color: var(--color-muted);
  }

  .note-tags-inline .tag {
    color: var(--color-muted);
  }

  .note-section {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .note-section__heading {
    font-size: var(--section-heading-size);
    font-weight: var(--heading-weight);
    margin: 0 0 var(--spacing-md);
    line-height: 1.3;
    color: var(--color-text);
  }

  .note-section__empty {
    font-size: 0.9375rem;
    color: var(--color-muted);
    font-style: italic;
    margin: 0;
    line-height: 1.5;
  }

  .note-section--overview .note-section__heading {
    margin-bottom: 0.75rem;
  }

  .note-overview {
    position: relative;
    padding: calc(var(--spacing-md) + var(--spacing-xs)) 1.35rem 1.35rem var(--spacing-lg);
    background: color-mix(in srgb, var(--color-link) 5%, var(--color-sidebar-bg));
    border: 1px solid color-mix(in srgb, var(--color-link) 12%, var(--color-border));
    border-radius: var(--radius-md, 8px);
    box-shadow: 0 1px 0 color-mix(in srgb, var(--color-text) 5%, transparent);
  }

  .note-overview::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.85rem;
    bottom: 0.85rem;
    width: 3px;
    border-radius: 0 2px 2px 0;
    background: var(--color-link);
    opacity: 0.85;
  }

  .note-overview .note-section__empty {
    margin: 0;
  }

  .note-overview .note-section__prose + .note-youtube {
    margin-top: 1.25rem;
  }

  .note-youtube {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md, 8px);
    overflow: hidden;
    background: color-mix(in srgb, var(--color-text) 6%, var(--color-sidebar-bg));
    border: 1px solid var(--color-border);
  }

  .note-youtube iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .note-youtube-fallback {
    display: none;
    margin-top: 1.25rem;
    font-weight: 500;
  }

  .note-section--notes .note-content :global(.note-youtube) {
    margin: var(--spacing-lg) 0 calc(var(--spacing-lg) + var(--spacing-sm));
  }

  .note-content :global(p) {
    margin-bottom: 1.25rem;
  }

  /* Ordered lists — stepped rows with numeric badges */
  .note-article .note-content :global(ol) {
    list-style: none;
    padding-left: 0;
    margin: calc(var(--spacing-md) + var(--spacing-sm)) 0 var(--spacing-lg);
    counter-reset: note-ol;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing-sm) + 0.1rem);
  }

  .note-article .note-content :global(ol > li) {
    counter-increment: note-ol;
    margin: 0;
    position: relative;
    padding: calc(var(--spacing-md) - calc(var(--spacing-xs) - 0.1rem)) var(--spacing-md) calc(var(--spacing-md) - var(--spacing-xs)) 3.15rem;
    background: color-mix(in srgb, var(--color-bg) 55%, var(--color-sidebar-bg));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    box-shadow: 0 1px 3px color-mix(in srgb, var(--color-text) 5%, transparent);
    transition:
      border-color 0.2s var(--ease-inertia),
      box-shadow 0.2s var(--ease-inertia);
  }

  .note-overview .note-section__prose.note-content :global(ol > li) {
    background: color-mix(in srgb, var(--color-bg) 40%, var(--color-sidebar-bg));
  }

  .note-article .note-content :global(ol > li:hover) {
    border-color: color-mix(in srgb, var(--color-link) 35%, var(--color-border));
    box-shadow: 0 2px 8px color-mix(in srgb, var(--color-link) 8%, transparent);
  }

  .note-article .note-content :global(ol > li::before) {
    content: counter(note-ol);
    position: absolute;
    left: 0.75rem;
    top: 0.8rem;
    min-width: 1.65rem;
    height: 1.65rem;
    padding: 0 calc(var(--spacing-xs) + 0.1rem);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-bg);
    background: var(--color-link);
    border-radius: var(--radius-sm, 6px);
    line-height: 1;
  }

  .note-article .note-content :global(ol > li p) {
    margin: 0;
  }

  .note-article .note-content :global(ol > li p + p) {
    margin-top: 0.5rem;
  }

  .note-article .note-content :global(ol > li em) {
    display: inline;
    color: var(--color-muted);
    font-size: 0.9375rem;
    font-weight: 400;
  }

  .note-article .note-content :global(ol a) {
    color: var(--color-link);
    text-decoration: none;
    font-weight: 650;
    text-underline-offset: 0.14em;
  }

  .note-article .note-content :global(ol a:hover) {
    text-decoration: underline;
    color: var(--color-link-hover, var(--color-link));
  }

  .note-article .note-content :global(ol ol) {
    margin: calc(var(--spacing-sm) + calc(var(--spacing-xs) - 0.1rem)) 0 0;
    gap: calc(var(--spacing-sm) - calc(var(--spacing-xs) - 0.2rem));
  }

  .note-article .note-content :global(ol ol > li) {
    padding-left: 2.65rem;
    padding-top: 0.65rem;
    padding-bottom: 0.7rem;
    background: color-mix(in srgb, var(--color-sidebar-bg) 80%, var(--color-bg));
    box-shadow: none;
  }

  .note-article .note-content :global(ol ol > li::before) {
    font-size: 0.6875rem;
    min-width: 1.4rem;
    height: 1.4rem;
    left: 0.65rem;
    top: 0.65rem;
    opacity: 0.92;
  }

  /* Unordered lists */
  .note-article .note-content :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin: calc(var(--spacing-md) + var(--spacing-xs)) 0 1.35rem;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing-sm) - calc(var(--spacing-xs) - 0.2rem));
  }

  .note-article .note-content :global(ul > li) {
    margin: 0;
    padding: 0.var(--spacing-xl) 0;
  }

  .note-article .note-content :global(ul ul) {
    list-style: circle;
    margin: 0.var(--spacing-3xl) 0 0;
    gap: 0.var(--spacing-2xl);
  }

  .note-article .note-content :global(ul ul ul) {
    list-style: square;
  }

  @media (prefers-reduced-motion: reduce) {
    .note-article .note-content :global(ol > li) {
      transition: none;
    }

    .note-article .note-content :global(ol > li:hover) {
      box-shadow: 0 1px 3px color-mix(in srgb, var(--color-text) 5%, transparent);
    }
  }

  .note-section__prose.note-content :global(p:first-child) {
    margin-top: 0;
  }

  .note-section__prose.note-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .note-section--notes .note-content :global(> *:first-child) {
    margin-top: 0;
  }

  .note-links__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .note-links__list li {
    padding: 0.var(--spacing-3xl) 0;
  }

  .note-links__list a {
    font-size: 0.9375rem;
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .note-links__list a:hover {
    color: var(--color-link-hover, var(--color-link));
  }

  @media (max-width: 640px) {
    .note-header h1 {
      font-size: 1.75rem;
    }
  }
</style>

---
import MainLayout from '../layouts/MainLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ThemesExplorer from '../components/generative-ui/ThemesExplorer.tsx';
import dailyThemes from '../data/daily-themes.json';

const pageDescription =
  'Explore AI-generated daily themes for davidhoang.com — color palettes, typography, and layouts rendered with json-render.';
---

<MainLayout title="Daily Themes" description={pageDescription}>
  <PageHeader
    title="Daily Themes"
    variant="text-only"
    subtitle="AI-generated themes rendered with json-render"
  />
  <ThemesExplorer client:visible themes={dailyThemes.themes as any} />
</MainLayout>

<style>
  .themes-explorer {
    max-width: var(--container-max-width, 1100px);
    margin: 0 auto;
    padding: 0 var(--content-padding, 1.5rem) 3rem;
  }

  .themes-explorer__query {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .themes-explorer__input {
    flex: 1;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    font-family: var(--font-body);
    background: var(--color-card-bg, var(--color-sidebar-bg));
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    outline: none;
    transition: border-color 0.15s ease;
  }

  .themes-explorer__input:focus {
    border-color: var(--color-link);
  }

  .themes-explorer__input::placeholder {
    color: var(--color-muted);
  }

  .themes-explorer__submit {
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 500;
    font-family: var(--font-body);
    background: var(--color-link);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius-md, 8px);
    cursor: pointer;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .themes-explorer__submit:hover:not(:disabled) {
    opacity: 0.85;
  }

  .themes-explorer__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .themes-explorer__error {
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    color: #c53030;
    background: #fff5f5;
    border: 1px solid #fc8181;
    border-radius: var(--radius-md, 8px);
  }

  [data-theme="dark"] .themes-explorer__error {
    color: #feb2b2;
    background: #1a0000;
    border-color: #742a2a;
  }

  .themes-explorer__ai-result {
    margin-bottom: 2rem;
    border: 1px solid var(--color-link);
    border-radius: var(--radius-md, 8px);
    padding: 1rem;
    background: var(--color-card-bg, var(--color-sidebar-bg));
  }

  .themes-explorer__ai-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .themes-explorer__ai-label {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-link);
  }

  .themes-explorer__ai-dismiss {
    font-size: 0.75rem;
    color: var(--color-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.2rem 0.4rem;
    font-family: var(--font-body);
  }

  .themes-explorer__ai-dismiss:hover {
    color: var(--color-text);
  }

  .themes-explorer__toolbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .themes-explorer__search {
    flex: 1 1 220px;
    min-width: 0;
    padding: 0.55rem 0.85rem;
    font-size: 0.85rem;
    font-family: var(--font-body);
    background: var(--color-card-bg, var(--color-sidebar-bg));
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    outline: none;
  }

  .themes-explorer__search:focus {
    border-color: var(--color-link);
  }

  .themes-explorer__sort {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .themes-explorer__sort select {
    padding: 0.45rem 0.65rem;
    font-size: 0.8rem;
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
  }

  .themes-explorer__count {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .themes-explorer__filters {
    display: flex;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .themes-explorer__filter {
    padding: 0.3rem 0.7rem;
    font-size: 0.75rem;
    font-family: var(--font-body);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: var(--radius-lg, 999px);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .themes-explorer__filter:hover {
    border-color: var(--color-link);
  }

  .themes-explorer__filter.active {
    background: var(--color-link);
    color: var(--color-bg);
    border-color: var(--color-link);
  }

  .themes-explorer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .themes-explorer__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-radius: var(--radius-md, 8px);
    transition: box-shadow 0.2s ease, outline-color 0.2s ease;
  }

  .themes-explorer__card.is-compared {
    outline: 2px solid color-mix(in srgb, var(--color-link) 55%, transparent);
    outline-offset: 2px;
  }

  .themes-explorer__card.is-highlighted {
    animation: theme-card-highlight 2.4s ease;
  }

  @keyframes theme-card-highlight {
    0%, 100% { box-shadow: none; }
    15%, 45% { box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-link) 35%, transparent); }
  }

  .themes-explorer__compare {
    margin-bottom: 1.5rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 8px);
    background: var(--color-card-bg, var(--color-sidebar-bg));
  }

  .themes-explorer__compare-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .themes-explorer__compare-title {
    margin: 0;
    font-size: 1rem;
    font-family: var(--font-heading);
  }

  .themes-explorer__compare-subtitle {
    margin: 0.25rem 0 0;
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .themes-explorer__compare-actions {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .themes-explorer__compare-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .themes-explorer__compare-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .themes-explorer__compare-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.45rem;
    margin: 0;
  }

  .themes-explorer__compare-meta div {
    padding: 0.45rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 4px);
    background: var(--color-bg);
  }

  .themes-explorer__compare-meta dt {
    margin: 0 0 0.15rem;
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
  }

  .themes-explorer__compare-meta dd {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .theme-meta-row {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-size: 0.7rem;
    color: var(--color-muted);
    padding: 0 0.25rem;
  }

  .theme-meta-main {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .theme-meta-name {
    color: var(--color-text);
    font-size: 0.78rem;
  }

  .theme-meta-dot {
    opacity: 0.5;
  }

  .theme-meta-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .theme-meta-feedback {
    font-size: 0.65rem;
    color: var(--color-link);
  }

  .theme-action-btn,
  .theme-apply-btn {
    padding: 0.2rem 0.5rem;
    font-size: 0.65rem;
    font-family: var(--font-body);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-muted);
    border-radius: var(--radius-sm, 4px);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .theme-action-btn:hover:not(:disabled),
  .theme-apply-btn:hover:not(.active) {
    border-color: var(--color-link);
    color: var(--color-link);
  }

  .theme-action-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .theme-action-btn.active {
    border-color: var(--color-link);
    color: var(--color-link);
  }

  .theme-action-btn--ghost {
    background: transparent;
  }

  .theme-apply-btn {
    margin-left: auto;
  }

  .theme-apply-btn.active {
    background: var(--color-link);
    color: var(--color-bg);
    border-color: var(--color-link);
    cursor: default;
  }

  .themes-explorer__streaming-placeholder {
    display: flex;
    gap: 0.4rem;
    justify-content: center;
    padding: 2rem 0;
  }

  .streaming-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-link);
    opacity: 0.3;
    animation: streaming-pulse 1.2s ease-in-out infinite;
  }

  .streaming-dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .streaming-dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes streaming-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  .themes-explorer__empty {
    text-align: center;
    color: var(--color-muted);
    font-size: 0.9rem;
    padding: 2rem 0;
  }

  .themes-explorer__footer {
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: 2.5rem;
  }

  .themes-explorer__footer a {
    color: var(--color-link);
  }

  @media (max-width: 640px) {
    .themes-explorer__grid {
      grid-template-columns: 1fr;
    }

    .themes-explorer__compare-grid {
      grid-template-columns: 1fr;
    }

    .themes-explorer__compare-meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .themes-explorer__query {
      flex-direction: column;
    }

    .theme-apply-btn {
      margin-left: 0;
    }
  }
</style>
